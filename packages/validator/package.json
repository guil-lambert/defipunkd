{
  "name": "@defibeat/validator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "defibeat-validate": "./src/cli/validate.ts",
    "defibeat-quorum": "./src/cli/quorum.ts",
    "defibeat-priority-queue": "./src/cli/priority-queue.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "validate": "tsx src/cli/validate.ts",
    "quorum": "tsx src/cli/quorum.ts",
    "priority-queue": "tsx src/cli/priority-queue.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@defibeat/prompts": "workspace:*",
    "@defibeat/registry": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "tsx": "^4.19.2",
    "@types/node": "^22.10.2"
  }
}
