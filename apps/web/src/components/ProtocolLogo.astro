---
interface Props {
  src: string | null;
  name: string;
  size?: number;
}
const { src, name, size = 20 } = Astro.props;
const initial = name.charAt(0).toUpperCase();
const fontSize = Math.round(size * 0.55);
---
<span
  class="logo"
  aria-hidden="true"
  style={`width:${size}px;height:${size}px;font-size:${fontSize}px`}
>
  {initial}
  {src && (
    <img src={src} alt="" loading="lazy" decoding="async" width={size} height={size} />
  )}
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    background: var(--surface-raised);
    color: var(--text-muted);
    font-weight: 500;
    flex-shrink: 0;
    overflow: hidden;
    position: relative;
    vertical-align: middle;
  }
  .logo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
