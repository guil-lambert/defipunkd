---
// Sticky "← DeFiPunk'd" link rendered at the top of a page's <main>.
// Visible at narrow widths where SideNav's home link isn't on screen;
// hide it on wide pages by adding (in the page's own <style>):
//
//   @media (min-width: <SideNav-visible-threshold + 1>px) {
//     .back-home { display: none; }
//   }
//
// where the threshold is `contentMaxWidth + 300` (see SideNav.astro).
---

<a href="/" class="back-home" aria-label="Back to DeFiPunk'd">
  <span class="back-arrow" aria-hidden="true">←</span>
  <svg class="back-logo" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M3 3h4v2h-2v6h2v2h-4zM13 3h-4v2h2v6h-2v2h4zM7 6h2v2h-2zM7 9h2v2h-2z" fill="currentColor"/>
  </svg>
  <span class="back-word">DeFiPunk'<span class="back-mark">d</span></span>
</a>

<style is:global>
  .back-home {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: -2rem -1.5rem 0.9rem -1.5rem;
    padding: 0.75rem 1.5rem;
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in oklab, var(--surface) 92%, transparent);
    backdrop-filter: blur(6px);
    border-bottom: 1px solid var(--surface-raised);
    color: var(--text);
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.015em;
    text-decoration: none;
  }
  .back-arrow { color: var(--text-muted); font-weight: 500; }
  .back-logo { width: 1em; height: 1em; flex-shrink: 0; color: var(--brand-oxblood); }
  .back-word { color: var(--text); }
  .back-mark { color: var(--brand-oxblood); }
  .back-home:hover .back-arrow { color: var(--text); }
</style>
