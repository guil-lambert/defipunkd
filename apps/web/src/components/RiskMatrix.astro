---
import type { EnrichmentDefiScan } from "@defipunkd/registry";
import { isUncertain, type SliceAssessment } from "../lib/rationale";
import { TIER_RIM_COLOR, TIER_STOPS, type Tier } from "../lib/tier";
import { defiscanBadgeUrl, defiscanStageLabel } from "../lib/defiscan";

interface Props {
  slices: SliceAssessment[];
  variant?: "hero" | "full";
  tier?: Tier;
  idPrefix?: string;
  defiscan?: EnrichmentDefiScan | null;
}
const { slices, variant = "full", tier = "none", idPrefix = "", defiscan = null } = Astro.props;
const defiscanUrl = defiscan ? defiscanBadgeUrl(defiscan) : null;
const defiscanLabel = defiscan ? defiscanStageLabel(defiscan.headline_stage) : null;
const defiscanRated = defiscan?.deployments.filter((d) => d.stage != null) ?? [];
const defiscanHeadline = defiscan
  ? defiscanRated.length === 0
    ? "Listed on defiscan.info"
    : defiscanRated.length === 1
      ? `Rated on ${defiscanRated[0]!.chain}`
      : `Rated across ${defiscanRated.length} deployments`
  : null;
const idp = idPrefix ? `${idPrefix}-` : "";

const TIER_ROW_LABEL: Record<Exclude<Tier, "none">, string> = {
  wood: "At least one model submission, no quorum yet",
  bronze: "AI consensus on at least one dimension",
  silver: "Weak AI consensus on all dimensions",
  gold: "Strong AI consensus on all dimensions",
};
const TIER_CHIP_TEXT: Record<Exclude<Tier, "none">, string> = {
  wood: "wood",
  bronze: "bronze",
  silver: "silver",
  gold: "gold",
};

const SLICE_ORDER: Record<string, number> = {
  verifiability: 0,
  control: 1,
  "ability-to-exit": 2,
  autonomy: 3,
  "open-access": 4,
};
const sorted = [...slices].sort(
  (a, b) => (SLICE_ORDER[a.id] ?? 9) - (SLICE_ORDER[b.id] ?? 9),
);

function truncate(s: string, n = 100): string {
  if (!s) return "";
  return s.length <= n ? s : s.slice(0, n - 1).trimEnd() + "…";
}

function chipLabel(grade: string): string {
  return grade === "gray" ? "unknown" : grade;
}

function partialFillGrade(s: SliceAssessment): string {
  if (!s.partial || !s.partialModelGrades || s.partialModelGrades.length === 0) return s.grade;
  const order: Record<string, number> = { red: 0, orange: 1, gray: 2, green: 3 };
  const sorted = [...s.partialModelGrades].sort(
    (a, b) => (order[a.grade] ?? 9) - (order[b.grade] ?? 9),
  );
  return sorted[0]?.grade ?? "gray";
}
---
<div class="risk-matrix-stack">
{defiscan && (
  <ul class:list={["risk-matrix", "defiscan-matrix", `variant-${variant}`, `defiscan-stage-${defiscan.headline_stage ?? "none"}`]}>
    <li class="row defiscan-row" data-defiscan-row>
      <a href={defiscanUrl ?? "#"} class="row-link" rel="noopener noreferrer" target="_blank"
         title={`defiscan.info — ${defiscanLabel ?? "listed"}`}>
        <span class="swatch defiscan-swatch" aria-hidden="true"></span>
        <span class="dim">DefiScan</span>
        <span class="chip defiscan-chip">{defiscanLabel ?? "Listed"}</span>
        <span class="headline">{defiscanHeadline} ↗</span>
      </a>
    </li>
  </ul>
)}
<ul class:list={["risk-matrix", `variant-${variant}`]}>
  {tier !== "none" && (() => {
    const stops = TIER_STOPS[tier];
    const tierGradient = `linear-gradient(135deg, ${stops.map((s, i) => `${s.color} ${i === 0 ? 0 : i === stops.length - 1 ? 100 : 50}%`).join(", ")})`;
    return (
      <li class:list={["row", "tier-row", `tier-${tier}`]} data-tier-row={tier}>
        <div class="row-link" role="presentation">
          <span class="swatch tier-swatch" aria-hidden="true" style={`background: ${tierGradient};`}></span>
          <span class="dim">Tier</span>
          <span class="chip tier-chip" style={`background: ${tierGradient}; border: 1px solid ${TIER_RIM_COLOR[tier]}`}>{TIER_CHIP_TEXT[tier]}</span>
          <span class="headline">{TIER_ROW_LABEL[tier]}</span>
        </div>
      </li>
    );
  })()}
  {sorted.map((s) => {
    const fillGrade = partialFillGrade(s);
    return (
    <li class:list={["row", `grade-${fillGrade}`, { partial: isUncertain(s) }]} data-slice-row={s.id} title={!s.partial && s.tentative_reasons && s.tentative_reasons.length > 0 ? `Tentative consensus — ${s.tentative_reasons.join("; ")}` : undefined}>
      <a href={`#${idp}${s.id}`} class="row-link">
        <span class="swatch" aria-hidden="true"></span>
        <span class="dim">{s.label}</span>
        {s.partial ? (
          <span
            class="chip chip-partial"
            title={`tentative — ${s.models?.length ?? 0}/3 models submitted`}
          >
            {chipLabel(fillGrade)}<span class="chip-suffix"> · {s.models?.length ?? 0}/3</span>
          </span>
        ) : s.tentative ? (
          <span
            class="chip chip-partial"
            title={`tentative consensus${s.tentative_reasons?.length ? ` — ${s.tentative_reasons.join("; ")}` : ""}`}
          >
            tentative
          </span>
        ) : (
          <span class="chip">{chipLabel(s.grade)}</span>
        )}
        <span class="headline" title={s.headline}>{s.short_headline ?? truncate(s.headline, 100)}</span>
      </a>
    </li>
    );
  })}
</ul>
</div>

<style>
  /* Most call sites place RiskMatrix in a CSS grid (e.g. ProtocolSummary's
     pizza/matrix two-column row). The stack wrapper keeps the defiscan <ul>
     and the slice <ul> in the same grid cell — without it, the slice matrix
     wraps onto a new grid row below the pizza. */
  .risk-matrix-stack { display: block; min-width: 0; }
  .risk-matrix {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--surface-raised);
    border-radius: 4px;
    overflow: hidden;
    background: var(--surface);
  }
  .row { position: relative; }
  .row + .row { border-top: 1px solid var(--surface-raised); }
  .row-link {
    display: grid;
    grid-template-columns: 0.35rem minmax(8rem, auto) auto minmax(0, 1fr);
    align-items: center;
    gap: 0 0.9rem;
    padding: 0.75rem 1rem 0.75rem 0;
    color: var(--text);
    text-decoration: none;
    transition: background 120ms ease;
  }
  .row-link:hover { background: color-mix(in oklab, var(--surface-raised) 50%, transparent); }
  .swatch {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 0.35rem;
    display: block;
  }
  .row-link > .dim { grid-column: 2; }
  .row-link > .chip { grid-column: 3; }
  .row-link > .headline { grid-column: 4; }
  .row.grade-red    .swatch { background: var(--grade-red,    oklch(0.52 0.170 22)); }
  .row.grade-orange .swatch { background: var(--grade-orange, oklch(0.65 0.120 75)); }
  .row.grade-green  .swatch { background: var(--grade-green,  oklch(0.60 0.130 150)); }
  .row.grade-gray   .swatch { background: oklch(0.55 0.015 235); }

  .dim {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--text);
    white-space: nowrap;
  }
  .chip {
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    white-space: nowrap;
    color: #111;
  }
  .grade-red    .chip { background: oklch(0.62 0.170 22);  color: #fff; }
  .grade-orange .chip { background: oklch(0.78 0.140 75);  color: #1a1208; }
  .grade-green  .chip { background: oklch(0.74 0.140 150); color: #081610; }
  .grade-gray   .chip { background: oklch(0.72 0.015 235); color: #0d1114; }

  .row.partial .swatch {
    background-image: repeating-linear-gradient(
      135deg,
      transparent 0 4px,
      rgba(255,255,255,0.35) 4px 8px
    );
  }
  .chip.chip-partial,
  .row .chip.chip-partial {
    color: #171717;
    border: 1px dashed rgba(255,255,255,0.55);
    background-image: repeating-linear-gradient(
      135deg,
      transparent 0 4px,
      rgba(255,255,255,0.35) 4px 7px
    );
  }
  .chip-tentative {
    background: oklch(0.88 0.085 75);
    color: #2a1a00;
    border: 1px dashed oklch(0.65 0.120 75);
  }
  .chip-suffix {
    font-weight: 600;
    opacity: 0.8;
    margin-left: 0.15rem;
  }

  .tier-chip { color: #1a1208; }

  /* DefiScan verdict — rendered as its own standalone matrix above the slice
     matrix so it reads as a separate, third-party verdict rather than another
     consensus row. Uses defiscan.info's solid red/yellow/green palette so the
     badge color in the matrix matches what users see on defiscan.info itself. */
  .defiscan-matrix { margin-bottom: 0.75rem; }
  .defiscan-matrix .defiscan-swatch { background: #6b7280; }
  .defiscan-matrix.defiscan-stage-0 .defiscan-swatch { background: #ef4444; }
  .defiscan-matrix.defiscan-stage-1 .defiscan-swatch { background: #eab308; }
  .defiscan-matrix.defiscan-stage-2 .defiscan-swatch { background: #22c55e; }
  .defiscan-chip {
    background: #6b7280;
    color: #fff;
    border-radius: 4px;
  }
  .defiscan-matrix.defiscan-stage-0 .defiscan-chip { background: #ef4444; }
  .defiscan-matrix.defiscan-stage-1 .defiscan-chip { background: #eab308; }
  .defiscan-matrix.defiscan-stage-2 .defiscan-chip { background: #22c55e; }

  .headline {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.3;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .variant-hero .row-link { padding: 0.55rem 0.75rem 0.55rem 0; }
  .variant-hero .dim { font-size: 0.72rem; }
  .variant-hero .headline { font-size: 0.82rem; }

  @media (max-width: 720px) {
    .row-link {
      grid-template-columns: 0.35rem minmax(0, 1fr) auto;
      grid-template-rows: auto auto;
      row-gap: 0.2rem;
      padding: 0.7rem 0.9rem 0.7rem 0;
    }
    .row-link > .dim {
      grid-column: 2;
      grid-row: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      min-width: 0;
    }
    .row-link > .chip { grid-column: 3; grid-row: 1; justify-self: end; }
    .row-link > .headline {
      grid-column: 2 / -1;
      grid-row: 2;
      white-space: normal;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .swatch { grid-row: 1 / 3; }
  }
</style>
