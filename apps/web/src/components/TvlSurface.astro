---
/**
 * Renders the contract surface for a protocol. Combines:
 *   - DeFiLlama TVL adapter contracts (mechanical) with verification +
 *     ownership metadata read from explorers / Sourcify / RPC.
 *   - DEFI@home discovery submissions (LLM-curated): admin/owner/proxy
 *     addresses and any other contracts the discovery prompt catalogues.
 *
 * IMPORTANT: this section is reviewer/audit context, NOT a slice score.
 * For a lending protocol, the TVL adapter set will include third-party
 * collateral tokens; attribution is the grader's job, not the table's.
 */
import type {
  EnrichmentAdapterAddress,
  EnrichmentControlAddress,
  EnrichmentSourceCodeAddress,
  ProtocolEnrichment,
  LoadedSubmission,
  AssessmentSliceId,
} from "@defipunkd/registry";

interface Props {
  enrichment: ProtocolEnrichment;
  /** Discovery-slice submissions whose evidence rows seed additional
   * (chain, address) entries, deduped against the adapter set. */
  submissions?: Map<AssessmentSliceId, LoadedSubmission[]>;
  /** Optional prefix for the section ID, used on family pages so multiple
   * deployment surfaces don't collide on `#tvl-surface`. */
  idPrefix?: string;
}
const { enrichment, submissions, idPrefix = "" } = Astro.props;
const sectionId = idPrefix ? `${idPrefix}-tvl-surface` : "tvl-surface";

const adapter = enrichment.adapter;
const sourcecode = enrichment.sourcecode;
const control = enrichment.control;

type RowSource = "tvl" | "discovery" | "both";
interface Row {
  chain: string;
  address: string;
  context: string | null;
  contract_name: string | null;
  verified_etherscan: boolean | null;
  sourcify: "perfect" | "partial" | "false" | null;
  is_proxy: boolean;
  implementation: string | null;
  owner: string | null;
  owner_is_safe: boolean | null;
  owner_safe_threshold: number | null;
  owner_safe_owners_count: number | null;
  self_is_safe: boolean | null;
  self_safe_threshold: number | null;
  self_safe_owners_count: number | null;
  source: RowSource;
  discovery_url?: string;
  discovery_shows?: string;
  /** actor_class declared by the discovery prompt's admin_addresses entry,
   * surfaced as a label in the Multisig column when on-chain Safe data is
   * unavailable (e.g. discovery-only rows). */
  discovery_actor_class?: "eoa" | "multisig" | "timelock" | "governance" | "unknown";
}

function buildRows(): Row[] {
  // Address-keyed merge across the three files.
  const addrMap = new Map<string, Row>();
  function put(chain: string | null, address: string, context: string | null, source: RowSource = "tvl") {
    if (!chain) return;
    const key = `${chain.toLowerCase()}|${address.toLowerCase()}`;
    const existing = addrMap.get(key);
    if (!existing) {
      addrMap.set(key, {
        chain,
        address: address.toLowerCase(),
        context,
        contract_name: null,
        verified_etherscan: null,
        sourcify: null,
        is_proxy: false,
        implementation: null,
        owner: null,
        owner_is_safe: null,
        owner_safe_threshold: null,
        owner_safe_owners_count: null,
        self_is_safe: null,
        self_safe_threshold: null,
        self_safe_owners_count: null,
        source,
      });
    } else if (source !== existing.source) {
      existing.source = "both";
      if (!existing.context && context) existing.context = context;
    }
  }
  if (adapter) {
    for (const a of adapter.static_addresses ?? []) put(a.chain, a.address, a.context);
  }
  if (sourcecode) {
    for (const a of sourcecode.addresses ?? []) {
      put(a.chain, a.address, a.context);
      const row = addrMap.get(`${a.chain}|${a.address.toLowerCase()}`);
      if (!row) continue;
      if (a.etherscan?.fetched) {
        row.verified_etherscan = a.etherscan.verified;
        row.contract_name = a.etherscan.contract_name;
        row.is_proxy = a.etherscan.is_proxy;
        row.implementation = a.etherscan.implementation;
      }
      if (a.sourcify?.fetched) row.sourcify = a.sourcify.status;
    }
  }
  if (control) {
    for (const a of control.addresses ?? []) {
      put(a.chain, a.address, a.context);
      const row = addrMap.get(`${a.chain}|${a.address.toLowerCase()}`);
      if (!row) continue;
      row.owner = a.owner;
      if (a.fetched.owner_safe) {
        row.owner_is_safe = a.owner_is_safe;
        if (a.owner_safe) {
          row.owner_safe_threshold = a.owner_safe.threshold;
          row.owner_safe_owners_count = a.owner_safe.owners_count;
        }
      }
      if (a.fetched.self) {
        row.self_is_safe = a.self_is_safe;
        if (a.self_safe) {
          row.self_safe_threshold = a.self_safe.threshold;
          row.self_safe_owners_count = a.self_safe.owners_count;
        }
      }
    }
  }
  // Layer in discovery evidence rows (chain + address) on top of the
  // mechanical adapter set. New rows tag source="discovery"; matches on an
  // existing row promote it to source="both" and fill in context if empty.
  const discoverySubs = submissions?.get("discovery") ?? [];
  for (const sub of discoverySubs) {
    for (const ev of sub.evidence ?? []) {
      if (!ev.chain || !ev.address) continue;
      put(ev.chain, ev.address, ev.shows ?? null, "discovery");
      const row = addrMap.get(`${ev.chain.toLowerCase()}|${ev.address.toLowerCase()}`);
      if (!row) continue;
      if (!row.discovery_url) row.discovery_url = ev.url;
      if (!row.discovery_shows) row.discovery_shows = ev.shows;
    }
    // Also seed rows from protocol_metadata.admin_addresses — the discovery
    // prompt's structured catalogue. Each entry has chain/address/role and is
    // typically much larger than evidence[] (e.g. Lido has ~119). Without
    // this pass, the surface table hides the bulk of discovery work.
    for (const a of sub.protocol_metadata?.admin_addresses ?? []) {
      if (!a.chain || !a.address) continue;
      put(a.chain, a.address, a.role ?? null, "discovery");
      const row = addrMap.get(`${a.chain.toLowerCase()}|${a.address.toLowerCase()}`);
      if (!row) continue;
      if (!row.discovery_shows && a.role) row.discovery_shows = a.role;
      if (!row.discovery_actor_class && a.actor_class) row.discovery_actor_class = a.actor_class;
    }
  }
  return [...addrMap.values()].sort((x, y) => {
    if (x.chain !== y.chain) return x.chain.localeCompare(y.chain);
    return (x.context ?? "").localeCompare(y.context ?? "");
  });
}

const rows: Row[] = (adapter || (submissions?.get("discovery")?.length ?? 0) > 0) ? buildRows() : [];

const explorerBase: Record<string, string> = {
  ethereum: "https://etherscan.io/address/",
  arbitrum: "https://arbiscan.io/address/",
  optimism: "https://optimistic.etherscan.io/address/",
  base: "https://basescan.org/address/",
  polygon: "https://polygonscan.com/address/",
  bsc: "https://bscscan.com/address/",
  avalanche: "https://snowtrace.io/address/",
  avax: "https://snowtrace.io/address/",
  fantom: "https://ftmscan.com/address/",
  gnosis: "https://gnosisscan.io/address/",
  xdai: "https://gnosisscan.io/address/",
  celo: "https://celoscan.io/address/",
  linea: "https://lineascan.build/address/",
  mantle: "https://mantlescan.xyz/address/",
  scroll: "https://scrollscan.com/address/",
  blast: "https://blastscan.io/address/",
  zksync: "https://era.zksync.network/address/",
  era: "https://era.zksync.network/address/",
  moonbeam: "https://moonbeam.moonscan.io/address/",
  moonriver: "https://moonriver.moonscan.io/address/",
};
function explorerUrl(chain: string, address: string): string | null {
  const base = explorerBase[chain.toLowerCase()];
  return base ? `${base}${address}` : null;
}
function shortAddr(addr: string): string {
  return `${addr.slice(0, 6)}…${addr.slice(-4)}`;
}

// Coverage stats for the disclaimer / summary
const totalCount = rows.length;
const verifiedCount = rows.filter((r) => r.verified_etherscan).length;
const proxyCount = rows.filter((r) => r.is_proxy).length;
const ownerSafeCount = rows.filter((r) => r.owner_is_safe).length;
const ownerCount = rows.filter((r) => r.owner).length;
---
{rows.length > 0 && (
  <section id={sectionId} class="tvl-surface">
    <header class="head">
      <h2>Contract surface</h2>
      <p class="lede">
        Every contract in scope for this protocol — pooled from DeFiLlama's
        TVL adapter (mechanical) and DEFI@home discovery submissions
        (LLM-curated). Verified-source flags come from Etherscan + Sourcify;
        owner / multisig metadata is read on-chain when available.
        <strong> Reviewer audit context, not a slice score.</strong> A
        lending protocol's adapter set will list third-party collateral
        tokens alongside its own contracts; attribution is the grader's job.
      </p>
      <ul class="stat-row">
        <li><span class="stat-num">{totalCount}</span> <span>addresses</span></li>
        <li><span class="stat-num">{verifiedCount}</span> <span>verified source</span></li>
        <li><span class="stat-num">{proxyCount}</span> <span>proxies</span></li>
        {ownerCount > 0 && (
          <li><span class="stat-num">{ownerSafeCount}</span> <span>of {ownerCount} owners are Safes</span></li>
        )}
      </ul>
      <p class="meta">
        {adapter && (
          <>
            TVL adapter pinned at
            {" "}<a href={adapter.adapter_url} rel="noopener noreferrer" target="_blank"><code>{adapter.adapter_commit?.slice(0, 7)}</code></a>.
          </>
        )}
        {sourcecode && <span> Sourcecode fetched {sourcecode.fetched_at.slice(0, 10)}.</span>}
        {control && <span> Control fetched {control.fetched_at.slice(0, 10)}.</span>}
      </p>
    </header>

    <div class="table-wrap">
      <table class="addrs sortable">
        <thead>
          <tr>
            <th class="th-chain"    data-sort="0"><button type="button" class="sort-btn">Chain</button></th>
            <th class="th-name"     data-sort="1"><button type="button" class="sort-btn">Contract</button></th>
            <th class="th-addr"     data-sort="2"><button type="button" class="sort-btn">Address</button></th>
            <th class="th-source"   data-sort="3"><button type="button" class="sort-btn">Source</button></th>
            <th class="th-verified" data-sort="4"><button type="button" class="sort-btn">Verified</button></th>
            <th class="th-proxy"    data-sort="5"><button type="button" class="sort-btn">Proxy</button></th>
            <th class="th-owner"    data-sort="6"><button type="button" class="sort-btn">Owner</button></th>
            <th class="th-multi"    data-sort="7"><button type="button" class="sort-btn">Multisig</button></th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => {
            const url = explorerUrl(r.chain, r.address);
            const ownerUrl = r.owner ? explorerUrl(r.chain, r.owner) : null;
            return (
              <tr>
                <td class="td-chain">{r.chain}</td>
                <td class="td-name">
                  <span class="name">{r.contract_name ?? <span class="muted">{r.context ?? "—"}</span>}</span>
                </td>
                <td class="td-addr">
                  {url ? (
                    <a href={url} rel="noopener noreferrer" target="_blank"><code>{shortAddr(r.address)}</code></a>
                  ) : (
                    <code>{shortAddr(r.address)}</code>
                  )}
                </td>
                <td class="td-source">
                  {r.source === "tvl" && <span class="pill src-tvl" title="DeFiLlama TVL adapter">TVL</span>}
                  {r.source === "discovery" && <span class="pill src-disc" title={r.discovery_shows ?? "DEFI@home discovery"}>discovery</span>}
                  {r.source === "both" && <span class="pill src-both" title="In both TVL adapter and discovery submission">TVL + disc</span>}
                </td>
                <td class="td-verified">
                  {r.verified_etherscan === true && (
                    <span class={`pill verified${r.sourcify === "perfect" ? " sourcify" : ""}`} title={r.sourcify === "perfect" ? "Verified on Etherscan and Sourcify" : "Verified on Etherscan"}>✓</span>
                  )}
                  {r.verified_etherscan === false && (
                    <span class="pill unverified" title="Source not verified">✗</span>
                  )}
                  {r.verified_etherscan === null && <span class="muted">—</span>}
                </td>
                <td class="td-proxy">
                  {r.is_proxy ? (
                    r.implementation ? (
                      <span class="pill proxy" title={`Implementation: ${r.implementation}`}>proxy</span>
                    ) : (
                      <span class="pill proxy">proxy</span>
                    )
                  ) : (
                    <span class="muted">—</span>
                  )}
                </td>
                <td class="td-owner">
                  {r.owner ? (
                    ownerUrl ? (
                      <a href={ownerUrl} rel="noopener noreferrer" target="_blank"><code>{shortAddr(r.owner)}</code></a>
                    ) : (
                      <code>{shortAddr(r.owner)}</code>
                    )
                  ) : (
                    <span class="muted">—</span>
                  )}
                </td>
                <td class="td-multi">
                  {r.owner_is_safe && r.owner_safe_threshold !== null ? (
                    <span class="pill safe" title="Owner is a Safe multisig">{r.owner_safe_threshold}/{r.owner_safe_owners_count} Safe</span>
                  ) : r.self_is_safe && r.self_safe_threshold !== null ? (
                    <span class="pill safe" title="Address itself is a Safe multisig">self {r.self_safe_threshold}/{r.self_safe_owners_count}</span>
                  ) : r.discovery_actor_class && r.discovery_actor_class !== "eoa" && r.discovery_actor_class !== "unknown" ? (
                    <span class="pill actor" title={`Reported by discovery as ${r.discovery_actor_class} (not verified on-chain)`}>{r.discovery_actor_class}</span>
                  ) : (
                    <span class="muted">—</span>
                  )}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>
)}

<script>
  for (const table of document.querySelectorAll<HTMLTableElement>("table.addrs.sortable")) {
    const tbody = table.tBodies[0];
    if (!tbody) continue;
    const ths = table.querySelectorAll<HTMLTableCellElement>("thead th[data-sort]");
    let activeIdx = -1;
    let dir: 1 | -1 = 1;
    const cellKey = (tr: HTMLTableRowElement, idx: number): string => {
      const td = tr.cells[idx];
      if (!td) return "";
      const t = (td.textContent ?? "").trim();
      return t === "—" ? "" : t.toLowerCase();
    };
    for (const th of ths) {
      th.addEventListener("click", () => {
        const idx = parseInt(th.dataset.sort ?? "0", 10);
        if (idx === activeIdx) {
          dir = (dir === 1 ? -1 : 1);
        } else {
          activeIdx = idx;
          dir = 1;
        }
        for (const t of ths) {
          t.removeAttribute("data-sort-dir");
        }
        th.setAttribute("data-sort-dir", dir === 1 ? "asc" : "desc");
        const rows = Array.from(tbody.rows);
        rows.sort((a, b) => {
          const ka = cellKey(a, idx);
          const kb = cellKey(b, idx);
          // Empty / "—" cells sort to the bottom regardless of direction.
          if (ka === "" && kb === "") return 0;
          if (ka === "") return 1;
          if (kb === "") return -1;
          return ka < kb ? -dir : ka > kb ? dir : 0;
        });
        for (const r of rows) tbody.appendChild(r);
      });
    }
  }
</script>

<style>
  .tvl-surface {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 2px solid var(--brand-oxblood);
    scroll-margin-top: 1rem;
  }
  .head h2 {
    margin: 0 0 0.75rem 0;
    color: var(--text);
    font-size: 2.25rem;
    scroll-margin-top: 1rem;
  }
  .lede {
    font-size: 0.825rem;
    color: var(--muted, #6b7785);
    margin: 0 0 0.75rem;
    max-width: 70ch;
    line-height: 1.5;
  }
  .lede strong { color: var(--text, #d8e4ec); }
  .stat-row {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0 0 0.5rem;
    font-size: 0.825rem;
    color: var(--muted, #6b7785);
    flex-wrap: wrap;
  }
  .stat-num {
    font-family: "IBM Plex Mono", monospace;
    font-variant-numeric: tabular-nums;
    color: var(--text, #d8e4ec);
    margin-right: 0.25rem;
  }
  .meta {
    font-size: 0.75rem;
    color: var(--muted, #6b7785);
    margin: 0 0 1rem;
  }
  .meta code { color: var(--accent, #7bb4cc); }

  .table-wrap { overflow-x: auto; }
  table.addrs {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
    font-family: "IBM Plex Mono", monospace;
    font-variant-numeric: tabular-nums;
  }
  table.addrs th {
    text-align: left;
    padding: 0;
    font-weight: 500;
    color: var(--muted, #6b7785);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--surface-3, #1e2330);
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    white-space: nowrap;
  }
  table.addrs.sortable th .sort-btn {
    width: 100%;
    text-align: left;
    padding: 0.4rem 0.5rem;
    background: none;
    border: 0;
    color: inherit;
    font: inherit;
    text-transform: inherit;
    letter-spacing: inherit;
    cursor: pointer;
  }
  table.addrs.sortable th .sort-btn:hover { color: var(--text, #d8e4ec); }
  table.addrs.sortable th[data-sort-dir] .sort-btn { color: var(--text, #d8e4ec); }
  table.addrs.sortable th[data-sort-dir="asc"] .sort-btn::after { content: " ▴"; }
  table.addrs.sortable th[data-sort-dir="desc"] .sort-btn::after { content: " ▾"; }
  table.addrs td {
    padding: 0.35rem 0.5rem;
    border-bottom: 1px solid var(--surface-2, #10131a);
    vertical-align: top;
  }
  table.addrs tr:hover td { background: var(--surface-1, #0c0e14); }
  .td-chain { color: var(--muted, #6b7785); white-space: nowrap; }
  .td-name { font-family: "IBM Plex Sans", system-ui, sans-serif; }
  .td-name .name { color: var(--text, #d8e4ec); }
  .td-addr a, .td-owner a { color: var(--accent, #7bb4cc); text-decoration: none; }
  .td-addr a:hover, .td-owner a:hover { text-decoration: underline; }
  .muted { color: var(--muted, #6b7785); }

  .pill {
    display: inline-block;
    padding: 0.05rem 0.4rem;
    border-radius: 2px;
    font-size: 0.7rem;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    border: 1px solid transparent;
  }
  .pill.verified  { color: oklch(0.60 0.130 150); border-color: oklch(0.45 0.080 150); }
  .pill.verified.sourcify { background: oklch(0.20 0.060 150 / 0.3); }
  .pill.unverified { color: oklch(0.52 0.170 22); border-color: oklch(0.40 0.100 22); }
  .pill.proxy { color: oklch(0.65 0.120 75); border-color: oklch(0.45 0.080 75); }
  .pill.safe { color: oklch(0.60 0.130 150); border-color: oklch(0.45 0.080 150); background: oklch(0.20 0.060 150 / 0.3); }
  .pill.actor { color: var(--text-muted); border-color: var(--surface-raised); font-style: italic; }
  .pill.src-tvl  { color: var(--text-muted); border-color: var(--surface-raised); }
  .pill.src-disc { color: oklch(0.65 0.110 245); border-color: oklch(0.45 0.080 245); background: oklch(0.20 0.060 245 / 0.3); }
  .pill.src-both { color: oklch(0.65 0.110 245); border-color: oklch(0.45 0.080 245); }
</style>
