---
/**
 * Renders the contract surface that DeFiLlama's TVL adapter walks for a
 * protocol, plus mechanically-fetched verification + ownership metadata.
 *
 * IMPORTANT: this section is reviewer/audit context, NOT a slice score.
 * The TVL adapter enumerates every contract value flows through, which
 * for a lending protocol means every collateral token (deployed by other
 * protocols) plus the protocol's own contracts. We surface the raw set
 * here; the slice grader is responsible for distinguishing "the protocol's
 * own surface" from "third-party collateral exposure".
 */
import type {
  EnrichmentAdapterAddress,
  EnrichmentControlAddress,
  EnrichmentSourceCodeAddress,
  ProtocolEnrichment,
} from "@defipunkd/registry";

interface Props {
  enrichment: ProtocolEnrichment;
}
const { enrichment } = Astro.props;

const adapter = enrichment.adapter;
const sourcecode = enrichment.sourcecode;
const control = enrichment.control;

interface Row {
  chain: string;
  address: string;
  context: string | null;
  contract_name: string | null;
  verified_etherscan: boolean | null;
  sourcify: "perfect" | "partial" | "false" | null;
  is_proxy: boolean;
  implementation: string | null;
  owner: string | null;
  owner_is_safe: boolean | null;
  owner_safe_threshold: number | null;
  owner_safe_owners_count: number | null;
  self_is_safe: boolean | null;
  self_safe_threshold: number | null;
  self_safe_owners_count: number | null;
}

function buildRows(): Row[] {
  // Address-keyed merge across the three files.
  const addrMap = new Map<string, Row>();
  function put(chain: string | null, address: string, context: string | null) {
    if (!chain) return;
    const key = `${chain}|${address.toLowerCase()}`;
    if (!addrMap.has(key)) {
      addrMap.set(key, {
        chain,
        address: address.toLowerCase(),
        context,
        contract_name: null,
        verified_etherscan: null,
        sourcify: null,
        is_proxy: false,
        implementation: null,
        owner: null,
        owner_is_safe: null,
        owner_safe_threshold: null,
        owner_safe_owners_count: null,
        self_is_safe: null,
        self_safe_threshold: null,
        self_safe_owners_count: null,
      });
    }
  }
  if (adapter) {
    for (const a of adapter.static_addresses ?? []) put(a.chain, a.address, a.context);
  }
  if (sourcecode) {
    for (const a of sourcecode.addresses ?? []) {
      put(a.chain, a.address, a.context);
      const row = addrMap.get(`${a.chain}|${a.address.toLowerCase()}`);
      if (!row) continue;
      if (a.etherscan?.fetched) {
        row.verified_etherscan = a.etherscan.verified;
        row.contract_name = a.etherscan.contract_name;
        row.is_proxy = a.etherscan.is_proxy;
        row.implementation = a.etherscan.implementation;
      }
      if (a.sourcify?.fetched) row.sourcify = a.sourcify.status;
    }
  }
  if (control) {
    for (const a of control.addresses ?? []) {
      put(a.chain, a.address, a.context);
      const row = addrMap.get(`${a.chain}|${a.address.toLowerCase()}`);
      if (!row) continue;
      row.owner = a.owner;
      if (a.fetched.owner_safe) {
        row.owner_is_safe = a.owner_is_safe;
        if (a.owner_safe) {
          row.owner_safe_threshold = a.owner_safe.threshold;
          row.owner_safe_owners_count = a.owner_safe.owners_count;
        }
      }
      if (a.fetched.self) {
        row.self_is_safe = a.self_is_safe;
        if (a.self_safe) {
          row.self_safe_threshold = a.self_safe.threshold;
          row.self_safe_owners_count = a.self_safe.owners_count;
        }
      }
    }
  }
  return [...addrMap.values()].sort((x, y) => {
    if (x.chain !== y.chain) return x.chain.localeCompare(y.chain);
    return (x.context ?? "").localeCompare(y.context ?? "");
  });
}

const rows: Row[] = adapter ? buildRows() : [];

const explorerBase: Record<string, string> = {
  ethereum: "https://etherscan.io/address/",
  arbitrum: "https://arbiscan.io/address/",
  optimism: "https://optimistic.etherscan.io/address/",
  base: "https://basescan.org/address/",
  polygon: "https://polygonscan.com/address/",
  bsc: "https://bscscan.com/address/",
  avalanche: "https://snowtrace.io/address/",
  avax: "https://snowtrace.io/address/",
  fantom: "https://ftmscan.com/address/",
  gnosis: "https://gnosisscan.io/address/",
  xdai: "https://gnosisscan.io/address/",
  celo: "https://celoscan.io/address/",
  linea: "https://lineascan.build/address/",
  mantle: "https://mantlescan.xyz/address/",
  scroll: "https://scrollscan.com/address/",
  blast: "https://blastscan.io/address/",
  zksync: "https://era.zksync.network/address/",
  era: "https://era.zksync.network/address/",
  moonbeam: "https://moonbeam.moonscan.io/address/",
  moonriver: "https://moonriver.moonscan.io/address/",
};
function explorerUrl(chain: string, address: string): string | null {
  const base = explorerBase[chain.toLowerCase()];
  return base ? `${base}${address}` : null;
}
function shortAddr(addr: string): string {
  return `${addr.slice(0, 6)}…${addr.slice(-4)}`;
}

// Coverage stats for the disclaimer / summary
const totalCount = rows.length;
const verifiedCount = rows.filter((r) => r.verified_etherscan).length;
const proxyCount = rows.filter((r) => r.is_proxy).length;
const ownerSafeCount = rows.filter((r) => r.owner_is_safe).length;
const ownerCount = rows.filter((r) => r.owner).length;
---
{adapter && rows.length > 0 && (
  <section id="tvl-surface" class="tvl-surface">
    <header class="head">
      <h2>TVL contract surface</h2>
      <p class="lede">
        Every contract DeFiLlama's TVL adapter walks for this protocol, with
        verified-source flags from Etherscan + Sourcify and owner / multisig
        metadata when readable on-chain. <strong>This is reviewer audit
        context, not a slice score.</strong> A lending protocol's TVL surface
        will list third-party collateral tokens alongside its own contracts;
        attribution is the grader's job, not the table's.
      </p>
      <ul class="stat-row">
        <li><span class="stat-num">{totalCount}</span> <span>addresses</span></li>
        <li><span class="stat-num">{verifiedCount}</span> <span>verified source</span></li>
        <li><span class="stat-num">{proxyCount}</span> <span>proxies</span></li>
        {ownerCount > 0 && (
          <li><span class="stat-num">{ownerSafeCount}</span> <span>of {ownerCount} owners are Safes</span></li>
        )}
      </ul>
      <p class="meta">
        Adapter pinned at
        {" "}<a href={adapter.adapter_url} rel="noopener noreferrer" target="_blank"><code>{adapter.adapter_commit?.slice(0, 7)}</code></a>.
        {sourcecode && <span> Sourcecode fetched {sourcecode.fetched_at.slice(0, 10)}.</span>}
        {control && <span> Control fetched {control.fetched_at.slice(0, 10)}.</span>}
      </p>
    </header>

    <div class="table-wrap">
      <table class="addrs">
        <thead>
          <tr>
            <th class="th-chain">Chain</th>
            <th class="th-name">Contract</th>
            <th class="th-addr">Address</th>
            <th class="th-verified">Verified</th>
            <th class="th-proxy">Proxy</th>
            <th class="th-owner">Owner</th>
            <th class="th-multi">Multisig</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => {
            const url = explorerUrl(r.chain, r.address);
            const ownerUrl = r.owner ? explorerUrl(r.chain, r.owner) : null;
            return (
              <tr>
                <td class="td-chain">{r.chain}</td>
                <td class="td-name">
                  <span class="name">{r.contract_name ?? <span class="muted">{r.context ?? "—"}</span>}</span>
                </td>
                <td class="td-addr">
                  {url ? (
                    <a href={url} rel="noopener noreferrer" target="_blank"><code>{shortAddr(r.address)}</code></a>
                  ) : (
                    <code>{shortAddr(r.address)}</code>
                  )}
                </td>
                <td class="td-verified">
                  {r.verified_etherscan === true && (
                    <span class={`pill verified${r.sourcify === "perfect" ? " sourcify" : ""}`} title={r.sourcify === "perfect" ? "Verified on Etherscan and Sourcify" : "Verified on Etherscan"}>✓</span>
                  )}
                  {r.verified_etherscan === false && (
                    <span class="pill unverified" title="Source not verified">✗</span>
                  )}
                  {r.verified_etherscan === null && <span class="muted">—</span>}
                </td>
                <td class="td-proxy">
                  {r.is_proxy ? (
                    r.implementation ? (
                      <span class="pill proxy" title={`Implementation: ${r.implementation}`}>proxy</span>
                    ) : (
                      <span class="pill proxy">proxy</span>
                    )
                  ) : (
                    <span class="muted">—</span>
                  )}
                </td>
                <td class="td-owner">
                  {r.owner ? (
                    ownerUrl ? (
                      <a href={ownerUrl} rel="noopener noreferrer" target="_blank"><code>{shortAddr(r.owner)}</code></a>
                    ) : (
                      <code>{shortAddr(r.owner)}</code>
                    )
                  ) : (
                    <span class="muted">—</span>
                  )}
                </td>
                <td class="td-multi">
                  {r.owner_is_safe && r.owner_safe_threshold !== null ? (
                    <span class="pill safe" title="Owner is a Safe multisig">{r.owner_safe_threshold}/{r.owner_safe_owners_count} Safe</span>
                  ) : r.self_is_safe && r.self_safe_threshold !== null ? (
                    <span class="pill safe" title="Address itself is a Safe multisig">self {r.self_safe_threshold}/{r.self_safe_owners_count}</span>
                  ) : (
                    <span class="muted">—</span>
                  )}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>
)}

<style>
  .tvl-surface {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 2px solid var(--brand-oxblood);
    scroll-margin-top: 1rem;
  }
  .head h2 {
    margin: 0 0 0.75rem 0;
    color: var(--text);
    font-size: 2.25rem;
    scroll-margin-top: 1rem;
  }
  .lede {
    font-size: 0.825rem;
    color: var(--muted, #6b7785);
    margin: 0 0 0.75rem;
    max-width: 70ch;
    line-height: 1.5;
  }
  .lede strong { color: var(--text, #d8e4ec); }
  .stat-row {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0 0 0.5rem;
    font-size: 0.825rem;
    color: var(--muted, #6b7785);
    flex-wrap: wrap;
  }
  .stat-num {
    font-family: "IBM Plex Mono", monospace;
    font-variant-numeric: tabular-nums;
    color: var(--text, #d8e4ec);
    margin-right: 0.25rem;
  }
  .meta {
    font-size: 0.75rem;
    color: var(--muted, #6b7785);
    margin: 0 0 1rem;
  }
  .meta code { color: var(--accent, #7bb4cc); }

  .table-wrap { overflow-x: auto; }
  table.addrs {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
    font-family: "IBM Plex Mono", monospace;
    font-variant-numeric: tabular-nums;
  }
  table.addrs th {
    text-align: left;
    padding: 0.4rem 0.5rem;
    font-weight: 500;
    color: var(--muted, #6b7785);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--surface-3, #1e2330);
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    white-space: nowrap;
  }
  table.addrs td {
    padding: 0.35rem 0.5rem;
    border-bottom: 1px solid var(--surface-2, #10131a);
    vertical-align: top;
  }
  table.addrs tr:hover td { background: var(--surface-1, #0c0e14); }
  .td-chain { color: var(--muted, #6b7785); white-space: nowrap; }
  .td-name { font-family: "IBM Plex Sans", system-ui, sans-serif; }
  .td-name .name { color: var(--text, #d8e4ec); }
  .td-addr a, .td-owner a { color: var(--accent, #7bb4cc); text-decoration: none; }
  .td-addr a:hover, .td-owner a:hover { text-decoration: underline; }
  .muted { color: var(--muted, #6b7785); }

  .pill {
    display: inline-block;
    padding: 0.05rem 0.4rem;
    border-radius: 2px;
    font-size: 0.7rem;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    border: 1px solid transparent;
  }
  .pill.verified  { color: oklch(0.60 0.130 150); border-color: oklch(0.45 0.080 150); }
  .pill.verified.sourcify { background: oklch(0.20 0.060 150 / 0.3); }
  .pill.unverified { color: oklch(0.52 0.170 22); border-color: oklch(0.40 0.100 22); }
  .pill.proxy { color: oklch(0.65 0.120 75); border-color: oklch(0.45 0.080 75); }
  .pill.safe { color: oklch(0.60 0.130 150); border-color: oklch(0.45 0.080 150); background: oklch(0.20 0.060 150 / 0.3); }
</style>
