---
// Inline SVG family logos for the Model breakdown card. All paths use
// currentColor so the icon picks up its parent's color (we tint to the
// family swatch — claude/gpt/gemini/grok/other).
import type { ModelFamily } from "../lib/stats";

interface Props {
  family: ModelFamily;
  size?: number;
}
const { family, size = 14 } = Astro.props;
---
{family === "claude" && (
  <svg class="model-logo" width={size} height={size} viewBox="0 0 46 32" aria-hidden="true">
    <path d="M32.73 0H25.7846L38.4499 32H45.3953L32.73 0Z" fill="currentColor" />
    <path d="M12.6653 0L0 32H7.08167L9.67193 25.28H22.9219L25.5122 32H32.5939L19.9286 0H12.6653ZM11.9626 19.3371L16.2969 8.09143L20.6313 19.3371H11.9626Z" fill="currentColor" />
  </svg>
)}
{family === "gpt" && (
  <svg class="model-logo" width={size} height={size} viewBox="0 0 320 320" aria-hidden="true">
