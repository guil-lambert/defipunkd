<footer>
  <div class="inner">
    <a href="/methodology">Methodology</a>
    <a href="/contribute">Contribute (DEFI@home)</a>
    <a href="https://github.com/guil-lambert/defipunkd/issues" rel="noreferrer" target="_blank">
      Corrections / takedowns (GitHub issues)
    </a>
    <span>
      Curators: edit <code>data/overlays/</code> and open a PR.
    </span>
    <span class="spacer">
      Rubric adapted from{" "}
      <a href="https://www.defiscan.info/framework" rel="noreferrer" target="_blank">Defiscan</a>.
    </span>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--surface-raised);
    margin-top: 4rem;
    /* The large bottom padding gives the side-nav scroll-spy enough scroll
       headroom to highlight the last section as active when the user
       reaches the page bottom — without it, max-scroll never carries the
       last section above the spy's 25% viewport line, so the active pill
       never moves to the final entry. */
    padding: 2rem 1.5rem 50vh;
    color: var(--text-muted);
    font-size: 0.85rem;
  }
  .inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  .spacer { margin-left: auto; }
  a { text-decoration: none; }
  code { color: var(--text); }
</style>
