---
import type { Protocol, LoadedAssessment, AssessmentSliceId, Finding, LoadedSubmission, ProtocolMetadata } from "@defipunkd/registry";
import { getProtocolMetadata } from "@defipunkd/registry";
import { assessProtocol, cexAssessment, isUncertain, type SliceAssessment } from "../lib/rationale";
import { buildPrompt, PROMPT_VERSION, type SliceId } from "@defipunkd/prompts";

interface Props {
  protocol: Protocol;
  snapshotGeneratedAt: string;
  assessments?: Map<AssessmentSliceId, LoadedAssessment>;
  submissions?: Map<AssessmentSliceId, LoadedSubmission[]>;
  children?: Protocol[];
  /** Optional prefix for section/card/anchor IDs. Set to the protocol slug
   * when this component is rendered alongside siblings (family page) so IDs
   * remain unique across deployments. */
  idPrefix?: string;
}
const { protocol, snapshotGeneratedAt, assessments, submissions, children = [], idPrefix = "" } = Astro.props;
const idp = idPrefix ? `${idPrefix}-` : "";
const isFamily = protocol.is_parent && children.length > 0;
const familyMembers = isFamily
  ? [...children].sort((a, b) => (b.tvl ?? -1) - (a.tvl ?? -1))
  : [];
const metadata = getProtocolMetadata(protocol.slug);
const rawSlices: SliceAssessment[] = protocol.category === "CEX" ? cexAssessment() : assessProtocol(protocol, assessments, submissions, metadata);

const SLICE_ORDER: Record<string, number> = {
  verifiability: 0,
  control: 1,
  "ability-to-exit": 2,
  autonomy: 3,
  "open-access": 4,
};
const slices = [...rawSlices].sort(
  (a, b) => (SLICE_ORDER[a.id] ?? 9) - (SLICE_ORDER[b.id] ?? 9),
);
const gradedSlices = slices.filter((s) => s.grade !== "gray" || s.partial);
const graySlices = slices.filter((s) => s.grade === "gray" && !s.partial);

const ANALYSIS_DATE = new Date().toISOString().slice(0, 10);
const REPO = "guil-lambert/defipunkd";
const addressBook = buildAddressBook(metadata);

function promptFor(sliceId: SliceId): string {
  return buildPrompt(sliceId, {
    slug: protocol.slug,
    name: protocol.name,
    chains: protocol.chains,
    category: protocol.category || null,
    website: protocol.website,
    github: protocol.github ?? [],
    auditLinks: protocol.audit_links ?? [],
    snapshotGeneratedAt,
    analysisDate: ANALYSIS_DATE,
    addressBook,
  });
}

/**
 * Build the prompt's address_book from prior LLM-curated metadata, NOT from
 * the TVL adapter surface. Sources:
 *   1. protocol_metadata.admin_addresses[] — multisigs, timelocks, governance
 *      contracts, owners. LLM-recorded across prior slice submissions and
 *      union-merged by aggregateProtocolMetadata in the registry.
 *   2. protocol_metadata.voting_token — governance token address; useful for
 *      C5 voting-rule reads.
 *
 * No filtering / capping needed: these are already curated by hand (or by a
 * prior LLM run that passed quorum). For a cold-start protocol with no prior
 * submissions, addressBook is null and the prompt falls through to its
 * "no addresses pinned — use the URL FETCH REQUEST escape hatch" message.
 */
function buildAddressBook(
  meta: ProtocolMetadata | undefined,
): Array<{ chain: string; address: string; role?: string }> | null {
  if (!meta) return null;
  const out: Array<{ chain: string; address: string; role?: string }> = [];
  const seen = new Set<string>();
  const key = (c: string, a: string) => `${c.toLowerCase()}:${a.toLowerCase()}`;

  for (const aa of meta.admin_addresses ?? []) {
    if (!aa.chain || !aa.address) continue;
    const k = key(aa.chain, aa.address);
    if (seen.has(k)) continue;
    seen.add(k);
    // Prefer the human-written role over the actor_class enum, but fall back
    // to the enum if role is empty / null. Both sourced from the LLM submission.
    const role = aa.role?.trim() || aa.actor_class || undefined;
    out.push({ chain: aa.chain, address: aa.address, ...(role ? { role } : {}) });
  }

  if (meta.voting_token) {
    const vt = meta.voting_token;
    if (vt.chain && vt.address) {
      const k = key(vt.chain, vt.address);
      if (!seen.has(k)) {
        seen.add(k);
        const role = vt.symbol ? `${vt.symbol} governance token` : "governance token";
        out.push({ chain: vt.chain, address: vt.address, role });
      }
    }
  }

  return out.length > 0 ? out : null;
}

function stubFor(sliceId: SliceId): string {
  return JSON.stringify(
    {
      schema_version: 2,
      slug: protocol.slug,
      slice: sliceId,
      snapshot_generated_at: snapshotGeneratedAt,
      prompt_version: PROMPT_VERSION,
      analysis_date: ANALYSIS_DATE,
      model: "",
      chat_url: null,
      grade: "",
      headline: "",
      rationale: { findings: [], steelman: { red: "", orange: "", green: "" }, verdict: "" },
      evidence: [],
      unknowns: [],
    },
    null,
    2,
  );
}

function submitUrl(sliceId: SliceId): string {
  const params = new URLSearchParams({
    filename: `data/submissions/${protocol.slug}/${sliceId}/your-model-${ANALYSIS_DATE}.json`,
    value: stubFor(sliceId),
  });
  return `https://github.com/${REPO}/new/main?${params.toString()}`;
}

const QUORUM_MIN = 3;
const auditSlices = slices.map((s) => ({
  id: s.id as SliceId,
  label: s.label,
  prompt: promptFor(s.id as SliceId),
  submitUrl: submitUrl(s.id as SliceId),
  modelCount: s.models?.length ?? 0,
  modelsWithChatUrl: s.models_with_chat_url ?? 0,
  hasQuorum: (s.models?.length ?? 0) >= QUORUM_MIN && !s.partial,
  isPartial: !!s.partial,
  isTentative: !s.partial && !!s.tentative,
  tentativeReasons: s.tentative_reasons ?? [],
  grade: s.grade,
}));

// Address discovery is a cataloguing slice that runs before the 5 risk
// slices and seeds their addressBook via protocol_metadata.admin_addresses.
// Only show it for on-chain, non-family protocols — CEXes have no contract
// surface to discover, and family pages redirect to sub-products.
const isCex = protocol.category === "CEX";
const showDiscovery = !isCex && !isFamily;
const discoverySubmissions = submissions?.get("discovery") ?? [];
const discoverySubmissionCount = discoverySubmissions.length;

const discoveredEvidenceCount = (() => {
  const seen = new Set<string>();
  for (const s of discoverySubmissions) {
    for (const ev of s.evidence ?? []) {
      if (!ev.address || !ev.chain) continue;
      seen.add(`${ev.chain.toLowerCase()}|${ev.address.toLowerCase()}`);
    }
  }
  return seen.size;
})();
const discoveredAddressCount = Math.max(metadata?.admin_addresses?.length ?? 0, discoveredEvidenceCount);

const discoveryPrompt = showDiscovery ? promptFor("discovery") : "";
const discoverySubmitUrl = showDiscovery ? submitUrl("discovery") : "";
const discoveryNeedsBootstrap = showDiscovery && discoveredAddressCount === 0;

const TAXONOMY_LABEL: Record<string, string> = {
  red: "Steelman argument",
  orange: "Steelman argument",
  green: "Steelman argument",
};

function chipLabel(grade: string): string {
  return grade === "gray" ? "unknown" : grade;
}

function partialPillText(modelCount: number): string {
  return `${modelCount}/${QUORUM_MIN} model${modelCount === 1 ? "" : "s"} submitted`;
}

function partialFillGrade(s: SliceAssessment): string {
  if (!s.partial || !s.partialModelGrades || s.partialModelGrades.length === 0) return s.grade;
  const order: Record<string, number> = { red: 0, orange: 1, gray: 2, green: 3 };
  const sorted = [...s.partialModelGrades].sort(
    (a, b) => (order[a.grade] ?? 9) - (order[b.grade] ?? 9),
  );
  return sorted[0]?.grade ?? "gray";
}
---
<section class="risk-analysis" id={`${idp}risk-analysis`}>
  <h2>Risk analysis</h2>
  {isFamily ? (
    <div class="family-redirect">
      <p class="family-redirect-lede">
        <strong>{protocol.name}</strong> is a product family that bundles several sub-products under one roof. Family-level prompts span too many smart-contract layers to produce a meaningful verdict, so risk analysis is performed per sub-product instead.
      </p>
      <p class="family-redirect-cta">Pick a sub-product to see its risk analysis and run prompts:</p>
      <ul class="family-redirect-list">
        {familyMembers.map((c) => (
          <li>
            <a href={`/protocol/${c.slug}#risk-analysis`} class="link">{c.name}</a>
            {c.category && <span class="family-redirect-cat"> · {c.category}</span>}
          </li>
        ))}
      </ul>
    </div>
  ) : (
  <>
  <p class="lede">
    One card per dimension, sorted by severity. Only <em>Verifiability</em> and <em>Autonomy</em> carry automated signals in Phase 0. See <a href="/methodology#what-is-graded-today" class="link">methodology</a> for scope.
  </p>

  <details class="audit-top" id={`${idp}audit-yourself`}>
    <summary>
      <span class="audit-top-title">Audit a dimension yourself · DEFI@home</span>
      <span class="audit-top-tagline">Contribute an LLM-run assessment — any model, any dimension. Three agreeing runs merge automatically into the public record.</span>
    </summary>
    <div class="audit-top-body">
      <p>
        DEFI@home is a distributed audit network modeled on SETI@home: instead of CPU cycles, it crowdsources LLM reasoning. Paste a slice prompt into Claude, ChatGPT, Gemini, or any browsing-capable model, and submit the JSON output as a pull request. The quorum bot merges it once ≥3 independent runs (from different models) reach the same grade — no single model, and no single contributor, can move the needle alone. <a href="/contribute" class="link">How it works →</a>
      </p>
      <ul class="audit-list">
        {showDiscovery && (
          <li class="discovery-row" title="Address discovery catalogues every contract before the 5 risk slices grade them. Run this first if no addresses are on file.">
            <span class="audit-list-label">
              <span class="discovery-label">Address discovery</span>
              <span class="discovery-state">
                {discoveredAddressCount} address{discoveredAddressCount === 1 ? "" : "es"} on file
                <span class="discovery-sep">·</span>
                {discoverySubmissionCount} run{discoverySubmissionCount === 1 ? "" : "s"}
              </span>
              {discoveryNeedsBootstrap && (
                <span class="discovery-bootstrap" title="No addresses on file — run discovery first so the 5 evaluation slices below have a seeded addressBook.">
                  ⚑ Run first
                </span>
              )}
            </span>
            <button type="button" class="copy-btn" data-copy-target={`#prompt-${idp}discovery`}>Copy prompt</button>
            <a href={discoverySubmitUrl} rel="noreferrer" target="_blank" class="submit-btn">Submit run ↗</a>
            <pre id={`prompt-${idp}discovery`} class="prompt-hidden" hidden>{discoveryPrompt}</pre>
          </li>
        )}
        {auditSlices.map((a) => (
          <li>
            <span class="audit-list-label">
              {a.label}
              {a.hasQuorum && (
                <span class="audit-quorum" title={`${a.modelCount} independent runs agreed — quorum reached`}>
                  ✓ {a.modelCount}/{a.modelCount} models agree
                </span>
              )}
              {a.hasQuorum && (
                <span class="audit-ai-only" title="All submissions are LLM model runs — no human auditor sign-off yet.">
                  AI-only
                </span>
              )}
              {a.modelCount === 0 && (
                <span class="audit-unverified" title="No model has submitted a run for this dimension yet.">
                  Unverified
                </span>
              )}
              {a.hasQuorum && a.isTentative ? (
                <span
                  class="audit-tentative"
                  title={a.tentativeReasons.join("; ")}
                >
                  weak {chipLabel(a.grade)} — {a.tentativeReasons.join("; ")}
                </span>
              ) : a.hasQuorum && (
                <span
                  class="audit-chat-url"
                  title={`${a.modelsWithChatUrl} of ${a.modelCount} runs included a public chat share link (chat_url)`}
                >
                  {a.modelsWithChatUrl}/{a.modelCount} with chat share link
                </span>
              )}
              {a.isPartial && (
                <span class="audit-partial" title={`${a.modelCount} of ${QUORUM_MIN} models needed for quorum`}>
                  {a.modelCount}/{QUORUM_MIN} submitted
                </span>
              )}
            </span>
            <button type="button" class="copy-btn" data-copy-target={`#prompt-${idp}${a.id}`}>Copy prompt</button>
            <a href={a.submitUrl} rel="noreferrer" target="_blank" class="submit-btn">Submit run ↗</a>
            <pre id={`prompt-${idp}${a.id}`} class="prompt-hidden" hidden>{a.prompt}</pre>
          </li>
        ))}
      </ul>
    </div>
  </details>

  <ol class="cards">
    {gradedSlices.map((s) => (
      <li id={`${idp}${s.id}`} class:list={["card", `grade-${partialFillGrade(s)}`, { partial: isUncertain(s) }]} title={!s.partial && s.tentative_reasons && s.tentative_reasons.length > 0 ? `Tentative consensus — ${s.tentative_reasons.join("; ")}` : undefined}>
        <details class="body card-details">
          <summary class="card-summary">
            <div class="meta">
              <span class="label">{s.label}</span>
              {s.partial ? (
                <span class="chip chip-partial" title={`${s.models?.length ?? 0} of ${QUORUM_MIN} models needed for quorum`}>
                  {partialPillText(s.models?.length ?? 0)}
                </span>
              ) : s.tentative ? (
                <span class="chip chip-partial" title={s.tentative_reasons?.length ? `Tentative — ${s.tentative_reasons.join("; ")}` : "Heuristic-derived; not yet reviewed"}>
                  tentative
                </span>
              ) : (
                <span class:list={["chip", `grade-${s.grade}`]}>{chipLabel(s.grade)}</span>
              )}
              {!s.partial && s.models && s.models.length > 0 && (
                <span
                  class:list={["consensus", s.models.length >= 2 ? "consensus-agree" : "consensus-single"]}
                  title={s.strength ? `${s.strength} consensus` : undefined}
                >
                  {s.models.length >= 2
                    ? `${s.models.length}/${s.models.length} models agree`
                    : "1 model"}
                </span>
              )}
              {!s.partial && s.models && s.models.length > 0 && (
                <span class="audit-ai-only" title="All submissions are LLM model runs — no human auditor sign-off yet.">
                  AI-only
                </span>
              )}
              {!s.partial && s.models && s.models.length > 0 && (
                <span
                  class="consensus consensus-chat-url"
                  title={`${s.models_with_chat_url ?? 0} of ${s.models.length} runs included a public chat share link (chat_url)`}
                >
                  {s.models_with_chat_url ?? 0}/{s.models.length} with chat share link
                </span>
              )}
              <span class="card-toggle" aria-hidden="true">▸</span>
            </div>
            <div class="headline">{s.headline}</div>
          </summary>
          {s.structured ? (
            <div class="structured">
              {!s.partial && s.structured.verdict && s.structured.verdict.trim().length > 0 && (
                <details class="drawer" open>
                  <summary>Verdict</summary>
                  <p class="verdict">{s.structured.verdict}</p>
                </details>
              )}
              {!s.partial && s.structured.steelman && s.structured.steelman[s.grade as "red" | "orange" | "green"] && (
                <details class="drawer">
                  <summary>Steelman argument</summary>
                  <div class:list={["steelman-chosen", `grade-${s.grade}`]}>
                    <span class="steelman-label">{TAXONOMY_LABEL[s.grade] ?? "Argument"}</span>
                    <span class="steelman-text">{s.structured.steelman[s.grade as "red" | "orange" | "green"]}</span>
                  </div>
                </details>
              )}
              {s.partial && s.partialModelGrades && s.partialModelGrades.length > 0 && (
                <div class="partial-grades">
                  <span class="partial-grades-label">Tentative grades</span>
                  <ul class="partial-grades-list">
                    {s.partialModelGrades.map((mg) => (
                      <li>
                        <span class="model-badge">{mg.model}</span>
                        <span class:list={["chip", `grade-${mg.grade}`]}>{chipLabel(mg.grade)}</span>
                      </li>
                    ))}
                  </ul>
                  <p class="partial-grades-note">No quorum yet — verdict and steelman hidden until ≥{QUORUM_MIN} models agree.</p>
                </div>
              )}
              {s.structured.findings.length > 0 && (
                <details class="drawer evidence-drawer">
                  <summary>Evidence ({s.structured.findings.length})</summary>
                  <div class="evidence">
                    <dl class="findings">
                      {s.structured.findings.map((f: Finding) => (
                        <div class="finding">
                          <dt>{f.code}</dt>
                          <dd>{f.text}</dd>
                        </div>
                      ))}
                    </dl>
                  </div>
                </details>
              )}
            </div>
          ) : (
            <p class="rationale">{s.rationale}</p>
          )}

          {!s.partial && s.tentative && s.tentative_reasons && s.tentative_reasons.length > 0 && (
            <div class="tentative-reasons">
              <span class="tentative-reasons-label">Why is this consensus tentative?</span>
              <ul class="tentative-reasons-list">
                {s.tentative_reasons.map((r) => (
                  <li>{r}</li>
                ))}
              </ul>
              <p class="tentative-reasons-note">A fresh independent run can strengthen (or overturn) the verdict.</p>
            </div>
          )}

          {s.partial && (
            <div class="tentative-reasons">
              <span class="tentative-reasons-label">Why is this slice uncertain?</span>
              <ul class="tentative-reasons-list">
                <li>only {s.models?.length ?? 0} of {QUORUM_MIN} model submissions on record — quorum requires ≥{QUORUM_MIN} agreeing models</li>
                {s.partialModelGrades && s.partialModelGrades.length > 1 && new Set(s.partialModelGrades.map((g) => g.grade)).size > 1 && (
                  <li>submitted models do not yet agree on a single grade</li>
                )}
              </ul>
              <p class="tentative-reasons-note">A fresh independent run can establish (or overturn) a verdict.</p>
            </div>
          )}

          {isUncertain(s) && (
            <div class="partial-cta">
              <span class="partial-cta-label">Run your own prompt</span>
              <button type="button" class="copy-btn" data-copy-target={`#prompt-partial-${idp}${s.id}`}>Copy prompt</button>
              <a href={submitUrl(s.id as SliceId)} rel="noreferrer" target="_blank" class="submit-btn">Submit run ↗</a>
              <pre id={`prompt-partial-${idp}${s.id}`} class="prompt-hidden" hidden>{promptFor(s.id as SliceId)}</pre>
            </div>
          )}

          {s.models && s.models.length > 0 && (
            <div class="sources">
              <span class="sources-label">Sources</span>
              <span class="model-badges">
                {(s.model_sources && s.model_sources.length > 0
                  ? s.model_sources
                  : s.models.map((m) => ({ model: m, chat_url: null }))
                ).map((src) => (
                  <span class="model-badge">
                    {src.model}
                    {src.chat_url ? (
                      <a class="model-source-link" href={src.chat_url} rel="noreferrer" target="_blank" title="Open public chat share link">url ↗</a>
                    ) : (
                      <span class="model-source-missing" title="No public chat share link — submission weight reduced by 95%">no url</span>
                    )}
                  </span>
                ))}
              </span>
              <a class="sources-link" href={`https://github.com/guil-lambert/defipunkd/tree/main/data/submissions/${protocol.slug}/${s.id}`} rel="noreferrer" target="_blank">View raw submissions ↗</a>
            </div>
          )}
        </details>
      </li>
    ))}
  </ol>

  {graySlices.length > 0 && (
    <details class="unknowns">
      <summary>
        <span class="unknowns-summary">
          {graySlices.length} dimension{graySlices.length === 1 ? "" : "s"} not yet assessed ({graySlices.map((s) => s.label).join(", ")})
        </span>
      </summary>
      <ol class="cards unknowns-list">
        {graySlices.map((s) => {
          const sliceId = s.id as SliceId;
          return (
          <li id={s.id} class="card grade-gray">
            <div class="body">
              <div class="meta">
                <span class="label">{s.label}</span>
                <span class="chip grade-gray">unknown</span>
                <span class="audit-unverified" title="No model has submitted a run for this dimension yet.">
                  Unverified
                </span>
              </div>
              <div class="headline">{s.headline}</div>
              <p class="rationale">{s.rationale}</p>
              <div class="unknown-cta">
                <p class="unknown-cta-blurb">
                  No model has graded this dimension yet. Run the slice prompt through any LLM and submit the JSON — once ≥3 independent runs agree, the quorum bot merges the verdict here.
                </p>
                <div class="unknown-cta-actions">
                  <button type="button" class="copy-btn" data-copy-target={`#prompt-unknown-${idp}${sliceId}`}>Copy prompt</button>
                  <a href={submitUrl(sliceId)} rel="noreferrer" target="_blank" class="submit-btn">Submit run ↗</a>
                </div>
                <pre id={`prompt-unknown-${idp}${sliceId}`} class="prompt-hidden" hidden>{promptFor(sliceId)}</pre>
              </div>
            </div>
          </li>
          );
        })}
      </ol>
    </details>
  )}
  </>
  )}
</section>

<script>
  document.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement)?.closest?.("[data-copy-target],[data-copy-text]") as HTMLButtonElement | null;
    if (!btn) return;
    let text = btn.getAttribute("data-copy-text") ?? "";
    if (!text) {
      const sel = btn.getAttribute("data-copy-target");
      const target = sel ? (document.querySelector(sel) as HTMLElement | null) : null;
      if (!target) return;
      text = target.textContent ?? "";
    }
    navigator.clipboard.writeText(text).then(() => {
      const prev = btn.textContent;
      btn.textContent = "Copied ✓";
      setTimeout(() => {
        btn.textContent = prev;
      }, 1500);
    });
  });

  // Expand the right card on hash navigation:
  //  - "...-audit-yourself"  → the <details> element itself is the target
  //  - slice cards (#control, #ability-to-exit, family-prefixed variants…)
  //    → wrap is an <li id="…"> that contains <details class="card-details">
  function openHashedCard() {
    const h = location.hash.slice(1);
    if (!h) return;
    const el = document.getElementById(h);
    if (!el) return;
    // Only act when the hash points to a card inside this section. Deployment
    // tabs also push slug hashes (e.g. #morpho-blue) and we don't want their
    // navigation to scroll-jump the page or re-open a card.
    if (!el.closest(".risk-analysis")) return;
    if (el instanceof HTMLDetailsElement) {
      el.open = true;
    } else {
      const details = el.querySelector("details.card-details") as HTMLDetailsElement | null;
      if (details) details.open = true;
    }
    el.scrollIntoView({ behavior: "smooth", block: "start" });
  }
  document.addEventListener("DOMContentLoaded", openHashedCard);
  window.addEventListener("hashchange", openHashedCard);
  if (document.readyState !== "loading") openHashedCard();
</script>

<style>
  .risk-analysis {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 2px solid var(--brand-oxblood);
  }
  h2 { margin: 0 0 0.25rem 0; color: var(--text); font-size: 2.25rem; scroll-margin-top: 1rem; }
  .lede { color: var(--text-muted); margin: 0 0 1.25rem 0; font-size: 0.9rem; }
  .link { color: var(--accent-link); }

  .audit-top {
    position: relative;
    margin: 1rem 0 1.5rem 0;
    background: var(--surface);
    border: 1px solid var(--surface-raised);
    border-radius: 6px;
    padding: 1rem 1.25rem 1.15rem 1.25rem;
    background: linear-gradient(to right, var(--accent-link) 10px, var(--surface) 10px);
    box-shadow: 0 1px 0 rgba(0,0,0,0.35);
    overflow: hidden;
  }
  .audit-top > summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin: -1rem -1.25rem 0 -1.25rem;
    padding: 1rem 1.25rem 1rem calc(1.25rem + 10px);
  }
  .audit-top:not([open]) > summary {
    margin-bottom: -1.15rem;
    padding-bottom: 1.15rem;
  }
  .audit-top > summary::-webkit-details-marker { display: none; }
