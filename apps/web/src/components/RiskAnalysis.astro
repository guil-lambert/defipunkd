---
import type { Protocol, LoadedAssessment, AssessmentSliceId, Finding, LoadedSubmission } from "@defipunkd/registry";
import { assessProtocol, cexAssessment, type SliceAssessment } from "../lib/rationale";
import { buildPrompt, PROMPT_VERSION, type SliceId } from "@defipunkd/prompts";

interface Props {
  protocol: Protocol;
  snapshotGeneratedAt: string;
  assessments?: Map<AssessmentSliceId, LoadedAssessment>;
  submissions?: Map<AssessmentSliceId, LoadedSubmission[]>;
  children?: Protocol[];
}
const { protocol, snapshotGeneratedAt, assessments, submissions, children = [] } = Astro.props;
const isFamily = protocol.is_parent && children.length > 0;
const familyMembers = isFamily
  ? [...children].sort((a, b) => (b.tvl ?? -1) - (a.tvl ?? -1))
  : [];
const rawSlices: SliceAssessment[] = protocol.category === "CEX" ? cexAssessment() : assessProtocol(protocol, assessments, submissions);

const SLICE_ORDER: Record<string, number> = {
  verifiability: 0,
  control: 1,
  "ability-to-exit": 2,
  autonomy: 3,
  "open-access": 4,
};
const slices = [...rawSlices].sort(
  (a, b) => (SLICE_ORDER[a.id] ?? 9) - (SLICE_ORDER[b.id] ?? 9),
);
const gradedSlices = slices.filter((s) => s.grade !== "gray" || s.partial);
const graySlices = slices.filter((s) => s.grade === "gray" && !s.partial);

const ANALYSIS_DATE = new Date().toISOString().slice(0, 10);
const REPO = "guil-lambert/defipunkd";

function promptFor(sliceId: SliceId): string {
  return buildPrompt(sliceId, {
    slug: protocol.slug,
    name: protocol.name,
    chains: protocol.chains,
    category: protocol.category || null,
    website: protocol.website,
    github: protocol.github ?? [],
    auditLinks: protocol.audit_links ?? [],
    snapshotGeneratedAt,
    analysisDate: ANALYSIS_DATE,
    addressBook: null,
  });
}

function stubFor(sliceId: SliceId): string {
  return JSON.stringify(
    {
      schema_version: 2,
      slug: protocol.slug,
      slice: sliceId,
      snapshot_generated_at: snapshotGeneratedAt,
      prompt_version: PROMPT_VERSION,
      analysis_date: ANALYSIS_DATE,
      model: "",
      chat_url: null,
      grade: "",
      headline: "",
      rationale: { findings: [], steelman: { red: "", orange: "", green: "" }, verdict: "" },
      evidence: [],
      unknowns: [],
    },
    null,
    2,
  );
}

function submitUrl(sliceId: SliceId): string {
  const params = new URLSearchParams({
    filename: `data/submissions/${protocol.slug}/${sliceId}/your-model-${ANALYSIS_DATE}.json`,
    value: stubFor(sliceId),
  });
  return `https://github.com/${REPO}/new/main?${params.toString()}`;
}

const QUORUM_MIN = 3;
const auditSlices = slices.map((s) => ({
  id: s.id as SliceId,
  label: s.label,
  prompt: promptFor(s.id as SliceId),
  submitUrl: submitUrl(s.id as SliceId),
  modelCount: s.models?.length ?? 0,
  modelsWithChatUrl: s.models_with_chat_url ?? 0,
  hasQuorum: (s.models?.length ?? 0) >= QUORUM_MIN && !s.partial,
  isPartial: !!s.partial,
}));

const TAXONOMY_LABEL: Record<string, string> = {
  red: "Steel-man argument",
  orange: "Steel-man argument",
  green: "Steel-man argument",
};

function chipLabel(grade: string): string {
  return grade === "gray" ? "unknown" : grade;
}

const GRADE_VAR: Record<string, string> = {
  red: "var(--grade-red)",
  orange: "var(--grade-orange)",
  green: "var(--grade-green)",
  gray: "var(--grade-gray)",
};

function partialStripeStyle(s: SliceAssessment): string {
  // Build a diagonal repeating stripe alternating each tentative grade with gray.
  const grades = (s.partialModelGrades ?? []).map((g) => g.grade);
  const uniq = Array.from(new Set(grades));
  const colors = uniq.length > 0 ? uniq.map((g) => GRADE_VAR[g] ?? "var(--grade-gray)") : ["var(--grade-gray)"];
  const band = 8;
  const grayBand = "var(--surface)";
  const segments: string[] = [];
  let pos = 0;
  for (const c of colors) {
    segments.push(`${c} ${pos}px ${pos + band}px`);
    pos += band;
    segments.push(`${grayBand} ${pos}px ${pos + band}px`);
    pos += band;
  }
  return `background: repeating-linear-gradient(135deg, ${segments.join(", ")});`;
}

const TOP_EVIDENCE = 2;

function partialPillText(modelCount: number): string {
  return `${modelCount}/${QUORUM_MIN} model${modelCount === 1 ? "" : "s"} submitted`;
}
---
<section class="risk-analysis" id="risk-analysis">
  <h2>Risk analysis</h2>
  {isFamily ? (
    <div class="family-redirect">
      <p class="family-redirect-lede">
        <strong>{protocol.name}</strong> is a product family that bundles several sub-products under one roof. Family-level prompts span too many smart-contract layers to produce a meaningful verdict, so risk analysis is performed per sub-product instead.
      </p>
      <p class="family-redirect-cta">Pick a sub-product to see its risk analysis and run prompts:</p>
      <ul class="family-redirect-list">
        {familyMembers.map((c) => (
          <li>
            <a href={`/protocol/${c.slug}#risk-analysis`} class="link">{c.name}</a>
            {c.category && <span class="family-redirect-cat"> · {c.category}</span>}
          </li>
        ))}
      </ul>
    </div>
  ) : (
  <>
  <p class="lede">
    One card per dimension, sorted by severity. Only <em>Verifiability</em> and <em>Autonomy</em> carry automated signals in Phase 0. See <a href="/methodology#what-is-graded-today" class="link">methodology</a> for scope.
  </p>

  <details class="audit-top" id="audit-yourself">
    <summary>
      <span class="audit-top-title">Audit a dimension yourself · DEFI@home</span>
      <span class="audit-top-tagline">Contribute an LLM-run assessment — any model, any dimension. Three agreeing runs merge automatically into the public record.</span>
    </summary>
    <div class="audit-top-body">
      <p>
        DEFI@home is a distributed audit network modeled on SETI@home: instead of CPU cycles, it crowdsources LLM reasoning. Paste a slice prompt into Claude, ChatGPT, Gemini, or any browsing-capable model, and submit the JSON output as a pull request. The quorum bot merges it once ≥3 independent runs (from different models) reach the same grade — no single model, and no single contributor, can move the needle alone. <a href="/contribute" class="link">How it works →</a>
      </p>
      <ul class="audit-list">
        {auditSlices.map((a) => (
          <li>
            <span class="audit-list-label">
              {a.label}
              {a.hasQuorum && (
                <span class="audit-quorum" title={`${a.modelCount} independent runs agreed — quorum reached`}>
                  ✓ {a.modelCount}/{a.modelCount} models agree
                </span>
              )}
              {a.hasQuorum && (
                <span
                  class="audit-chat-url"
                  title={`${a.modelsWithChatUrl} of ${a.modelCount} runs included a public chat share link (chat_url)`}
                >
                  {a.modelsWithChatUrl}/{a.modelCount} with chat share link
                </span>
              )}
              {a.isPartial && (
                <span class="audit-partial" title={`${a.modelCount} of ${QUORUM_MIN} models needed for quorum`}>
                  {a.modelCount}/{QUORUM_MIN} submitted
                </span>
              )}
            </span>
            <button type="button" class="copy-btn" data-copy-target={`#prompt-${a.id}`}>Copy prompt</button>
            <a href={a.submitUrl} rel="noreferrer" target="_blank" class="submit-btn">Submit run ↗</a>
            <pre id={`prompt-${a.id}`} class="prompt-hidden" hidden>{a.prompt}</pre>
          </li>
        ))}
      </ul>
    </div>
  </details>

  <ol class="cards">
    {gradedSlices.map((s) => (
      <li id={s.id} class:list={["card", `grade-${s.grade}`, { partial: s.partial }]} style={s.partial ? partialStripeStyle(s) : undefined}>
        <details class="body card-details">
          <summary class="card-summary">
            <div class="meta">
              <span class="label">{s.label}</span>
              {s.partial ? (
                <span class="chip chip-partial" title={`${s.models?.length ?? 0} of ${QUORUM_MIN} models needed for quorum`}>
                  {partialPillText(s.models?.length ?? 0)}
                </span>
              ) : (
                <span class:list={["chip", `grade-${s.grade}`]}>{chipLabel(s.grade)}</span>
              )}
              {!s.partial && s.models && s.models.length > 0 && (
                <span
                  class:list={["consensus", s.models.length >= 2 ? "consensus-agree" : "consensus-single"]}
                  title={s.strength ? `${s.strength} consensus` : undefined}
                >
                  {s.models.length >= 2
                    ? `${s.models.length}/${s.models.length} models agree`
                    : "1 model"}
                </span>
              )}
              {!s.partial && s.models && s.models.length > 0 && (
                <span
                  class="consensus consensus-chat-url"
                  title={`${s.models_with_chat_url ?? 0} of ${s.models.length} runs included a public chat share link (chat_url)`}
                >
                  {s.models_with_chat_url ?? 0}/{s.models.length} with chat share link
                </span>
              )}
              <span class="card-toggle" aria-hidden="true">▸</span>
            </div>
            <div class="headline">{s.headline}</div>
          </summary>
          {s.structured ? (
            <div class="structured">
              {!s.partial && s.structured.steelman && s.structured.steelman[s.grade as "red" | "orange" | "green"] && (
                <div class:list={["steelman-chosen", `grade-${s.grade}`]}>
                  <span class="steelman-label">{TAXONOMY_LABEL[s.grade] ?? "Argument"}</span>
                  <span class="steelman-text">{s.structured.steelman[s.grade as "red" | "orange" | "green"]}</span>
                </div>
              )}
              {!s.partial && s.structured.verdict && s.structured.verdict.trim().length > 0 && (
                <details class="drawer">
                  <summary>Verdict</summary>
                  <p class="verdict">{s.structured.verdict}</p>
                </details>
              )}
              {s.partial && s.partialModelGrades && s.partialModelGrades.length > 0 && (
                <div class="partial-grades">
                  <span class="partial-grades-label">Tentative grades</span>
                  <ul class="partial-grades-list">
                    {s.partialModelGrades.map((mg) => (
                      <li>
                        <span class="model-badge">{mg.model}</span>
                        <span class:list={["chip", `grade-${mg.grade}`]}>{chipLabel(mg.grade)}</span>
                      </li>
                    ))}
                  </ul>
                  <p class="partial-grades-note">No quorum yet — verdict and steel-man hidden until ≥{QUORUM_MIN} models agree.</p>
                </div>
              )}
              {s.structured.findings.length > 0 && (
                <div class="evidence">
                  <div class="evidence-head">
                    Evidence ({s.structured.findings.length})
                  </div>
                  <dl class="findings">
                    {s.structured.findings.slice(0, TOP_EVIDENCE).map((f: Finding) => (
                      <div class="finding">
                        <dt>{f.code}</dt>
                        <dd>{f.text}</dd>
                      </div>
                    ))}
                  </dl>
                  {s.structured.findings.length > TOP_EVIDENCE && (
                    <details class="more-evidence">
                      <summary>Show all {s.structured.findings.length} ▸</summary>
                      <dl class="findings">
                        {s.structured.findings.slice(TOP_EVIDENCE).map((f: Finding) => (
                          <div class="finding">
                            <dt>{f.code}</dt>
                            <dd>{f.text}</dd>
                          </div>
                        ))}
                      </dl>
                    </details>
                  )}
                </div>
              )}
            </div>
          ) : (
            <p class="rationale">{s.rationale}</p>
          )}

          {s.partial && (
            <div class="partial-cta">
              <button type="button" class="copy-btn" data-copy-target={`#prompt-partial-${s.id}`}>Copy prompt</button>
              <a href={submitUrl(s.id as SliceId)} rel="noreferrer" target="_blank" class="submit-btn">Submit run ↗</a>
              <pre id={`prompt-partial-${s.id}`} class="prompt-hidden" hidden>{promptFor(s.id as SliceId)}</pre>
            </div>
          )}

          {s.models && s.models.length > 0 && (
            <div class="sources">
              <span class="sources-label">Sources</span>
              <span class="model-badges">
                {s.models.map((m) => <span class="model-badge">{m}</span>)}
              </span>
              <a class="sources-link" href={`https://github.com/guil-lambert/defipunkd/tree/main/data/submissions/${protocol.slug}/${s.id}`} rel="noreferrer" target="_blank">View raw submissions ↗</a>
            </div>
          )}
        </details>
      </li>
    ))}
  </ol>

  {graySlices.length > 0 && (
    <details class="unknowns">
      <summary>
        <span class="unknowns-summary">
          {graySlices.length} dimension{graySlices.length === 1 ? "" : "s"} not yet assessed ({graySlices.map((s) => s.label).join(", ")})
        </span>
      </summary>
      <ol class="cards unknowns-list">
        {graySlices.map((s) => {
          const sliceId = s.id as SliceId;
          return (
          <li id={s.id} class="card grade-gray">
            <div class="body">
              <div class="meta">
                <span class="label">{s.label}</span>
                <span class="chip grade-gray">unknown</span>
              </div>
              <div class="headline">{s.headline}</div>
              <p class="rationale">{s.rationale}</p>
              <div class="unknown-cta">
                <p class="unknown-cta-blurb">
                  No model has graded this dimension yet. Run the slice prompt through any LLM and submit the JSON — once ≥3 independent runs agree, the quorum bot merges the verdict here.
                </p>
                <div class="unknown-cta-actions">
                  <button type="button" class="copy-btn" data-copy-target={`#prompt-unknown-${sliceId}`}>Copy prompt</button>
                  <a href={submitUrl(sliceId)} rel="noreferrer" target="_blank" class="submit-btn">Submit run ↗</a>
                </div>
                <pre id={`prompt-unknown-${sliceId}`} class="prompt-hidden" hidden>{promptFor(sliceId)}</pre>
              </div>
            </div>
          </li>
          );
        })}
      </ol>
    </details>
  )}
  </>
  )}
</section>

<script>
  document.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement)?.closest?.("[data-copy-target],[data-copy-text]") as HTMLButtonElement | null;
    if (!btn) return;
    let text = btn.getAttribute("data-copy-text") ?? "";
    if (!text) {
      const sel = btn.getAttribute("data-copy-target");
      const target = sel ? (document.querySelector(sel) as HTMLElement | null) : null;
      if (!target) return;
      text = target.textContent ?? "";
    }
    navigator.clipboard.writeText(text).then(() => {
      const prev = btn.textContent;
      btn.textContent = "Copied ✓";
      setTimeout(() => {
        btn.textContent = prev;
      }, 1500);
    });
  });

  function openAuditDrawerIfHashed() {
    if (location.hash !== "#audit-yourself") return;
    const el = document.getElementById("audit-yourself") as HTMLDetailsElement | null;
    if (!el) return;
    el.open = true;
    el.scrollIntoView({ behavior: "smooth", block: "start" });
  }
  document.addEventListener("DOMContentLoaded", openAuditDrawerIfHashed);
  window.addEventListener("hashchange", openAuditDrawerIfHashed);
  if (document.readyState !== "loading") openAuditDrawerIfHashed();
</script>

<style>
  .risk-analysis {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 2px solid var(--brand-oxblood);
  }
  h2 { margin: 0 0 0.25rem 0; color: var(--text); font-size: 2.25rem; scroll-margin-top: 1rem; }
  .lede { color: var(--text-muted); margin: 0 0 1.25rem 0; font-size: 0.9rem; }
  .link { color: var(--accent-link); }

  .audit-top {
    position: relative;
    margin: 1rem 0 1.5rem 0;
    background: var(--surface);
    border: 1px solid var(--surface-raised);
    border-radius: 6px;
    padding: 1rem 1.25rem 1.15rem 1.25rem;
    background: linear-gradient(to right, var(--accent-link) 10px, var(--surface) 10px);
    box-shadow: 0 1px 0 rgba(0,0,0,0.35);
    overflow: hidden;
  }
  .audit-top > summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin: -1rem -1.25rem 0 -1.25rem;
    padding: 1rem 1.25rem 1rem calc(1.25rem + 10px);
  }
  .audit-top:not([open]) > summary {
    margin-bottom: -1.15rem;
    padding-bottom: 1.15rem;
  }
  .audit-top > summary::-webkit-details-marker { display: none; }
  .audit-top-title {
    color: var(--accent-link);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
  }
  .audit-top-title::after {
    content: "▸";
    margin-left: auto;
    color: var(--text-muted);
    font-size: 0.85rem;
    transition: transform 150ms ease;
    display: inline-block;
  }
  .audit-top[open] .audit-top-title::after { transform: rotate(90deg); }
  .audit-top-tagline {
    color: var(--text);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
  }
  .audit-top-body { margin-top: 0.5rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .audit-top-body p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.82rem;
    line-height: 1.5;
  }
  .audit-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.4rem;
  }
  .audit-list li {
    display: grid;
    grid-template-columns: minmax(8rem, 1fr) auto auto;
    align-items: center;
    gap: 0.5rem;
  }
  .audit-list-label {
    color: var(--text);
    font-size: 0.85rem;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .audit-partial {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    color: var(--text-muted);
    border: 1px dashed var(--surface-raised);
    background: transparent;
    white-space: nowrap;
  }
  .audit-quorum {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    color: var(--grade-green);
    border: 1px solid color-mix(in oklab, var(--grade-green) 40%, var(--surface-raised));
    background: color-mix(in oklab, var(--grade-green) 8%, transparent);
    white-space: nowrap;
  }
  .audit-chat-url {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    color: var(--text-muted);
    border: 1px solid var(--surface-raised);
    background: transparent;
    white-space: nowrap;
  }
  .consensus-chat-url { color: var(--text-muted); }

  .cards {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.75rem;
  }
  .card {
    position: relative;
    background: linear-gradient(to right, var(--grade-gray) 10px, var(--surface) 10px);
    border: 1px solid var(--surface-raised);
    border-radius: 6px;
    overflow: hidden;
    scroll-margin-top: 1rem;
    box-shadow: 0 1px 0 rgba(0,0,0,0.35);
  }
  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg, currentColor 0%, transparent 72px);
    opacity: 0.08;
    color: var(--grade-gray);
  }
  .card.grade-green { background: linear-gradient(to right, var(--grade-green) 10px, var(--surface) 10px); }
  .card.grade-orange { background: linear-gradient(to right, var(--grade-orange) 10px, var(--surface) 10px); }
  .card.grade-red { background: linear-gradient(to right, var(--grade-red) 10px, var(--surface) 10px); }
  .card.grade-gray { background: linear-gradient(to right, var(--grade-gray) 10px, var(--surface) 10px); }
  .card.grade-green::before { color: var(--grade-green); }
  .card.grade-orange::before { color: var(--grade-orange); }
  .card.grade-red::before { color: var(--grade-red); }
  .card.grade-gray::before { color: var(--grade-gray); }
  .body { position: relative; padding: 1rem 1.25rem 1.15rem 1.25rem; }
  .card-details { display: flex; flex-direction: column; gap: 0.7rem; }
  .card-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin: -1rem -1.25rem 0 -1.25rem;
    padding: 1rem 1.25rem 1rem calc(1.25rem + 10px);
  }
  .card-details:not([open]) .card-summary {
    margin-bottom: -1.15rem;
    padding-bottom: 1.15rem;
  }
  .card-summary::-webkit-details-marker { display: none; }
  .card-summary .headline { margin-bottom: 0; }
  .card-toggle {
    margin-left: auto;
    color: var(--text-muted);
    font-size: 0.85rem;
    transition: transform 150ms ease;
    display: inline-block;
  }
  .card-details[open] .card-toggle { transform: rotate(90deg); }
  .meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.55rem 0.75rem;
    margin-bottom: 0.25rem;
  }
  .label {
    color: var(--text);
    font-size: 1.2rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .card.grade-green .label { color: var(--grade-green); }
  .card.grade-orange .label { color: var(--grade-orange); }
  .card.grade-red .label { color: var(--grade-red); }
  .chip {
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 0.18rem 0.55rem;
    border-radius: 999px;
  }
  .chip.grade-red    { background: oklch(0.62 0.170 22);  color: #fff; }
  .chip.grade-orange { background: oklch(0.78 0.140 75);  color: #1a1208; }
  .chip.grade-green  { background: oklch(0.74 0.140 150); color: #081610; }
  .chip.grade-gray   { background: oklch(0.72 0.015 235); color: #0d1114; }
  .chip-partial {
    background: var(--surface-raised);
    color: var(--text);
    border: 1px dashed color-mix(in oklab, var(--text-muted) 50%, transparent);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-transform: none;
    font-weight: 600;
  }
  .card.partial {
    /* inline `style` provides the diagonal stripes; clear the side bar overlay */
    background-blend-mode: normal;
  }
  .card.partial::before { display: none; }
  .card.partial .body {
    /* Slight inner panel so text remains legible over stripes */
    background: color-mix(in oklab, var(--surface) 88%, transparent);
    border-radius: 4px;
    margin: 0.35rem;
    padding: 0.65rem 0.9rem 0.8rem 0.9rem;
  }
  .card.partial .card-summary {
