---
import type { Protocol, LoadedAssessment, AssessmentSliceId, Finding } from "@defipunkd/registry";
import { assessProtocol, cexAssessment, type SliceAssessment } from "../lib/rationale";
import { GRADE_FILL } from "../lib/pizza";
import { buildPrompt, PROMPT_VERSION, type SliceId } from "@defipunkd/prompts";

interface Props {
  protocol: Protocol;
  snapshotGeneratedAt: string;
  assessments?: Map<AssessmentSliceId, LoadedAssessment>;
}
const { protocol, snapshotGeneratedAt, assessments } = Astro.props;
const slices: SliceAssessment[] = protocol.category === "CEX" ? cexAssessment() : assessProtocol(protocol, assessments);

const ANALYSIS_DATE = new Date().toISOString().slice(0, 10);
const REPO = "guil-lambert/defipunkd";

function promptFor(sliceId: SliceId): string {
  return buildPrompt(sliceId, {
    slug: protocol.slug,
    name: protocol.name,
    chains: protocol.chains,
    category: protocol.category || null,
    website: protocol.website,
    github: protocol.github ?? [],
    auditLinks: protocol.audit_links ?? [],
    snapshotGeneratedAt,
    analysisDate: ANALYSIS_DATE,
    addressBook: null,
  });
}

function stubFor(sliceId: SliceId): string {
  return JSON.stringify(
    {
      schema_version: 2,
      slug: protocol.slug,
      slice: sliceId,
      snapshot_generated_at: snapshotGeneratedAt,
      prompt_version: PROMPT_VERSION,
      analysis_date: ANALYSIS_DATE,
      model: "",
      chat_url: null,
      grade: "",
      headline: "",
      rationale: {
        findings: [],
        steelman: { red: "", orange: "", green: "" },
        verdict: "",
      },
      evidence: [],
      unknowns: [],
    },
    null,
    2,
  );
}

function submitUrl(sliceId: SliceId): string {
  const params = new URLSearchParams({
    filename: `data/submissions/${protocol.slug}/${sliceId}/your-model-${ANALYSIS_DATE}.json`,
    value: stubFor(sliceId),
  });
  return `https://github.com/${REPO}/new/main?${params.toString()}`;
}

function suggestedCommit(sliceId: SliceId): string {
  return `[DEFI@home] ${protocol.slug} / ${sliceId} submission`;
}

function suggestedBranch(sliceId: SliceId): string {
  return `defi-at-home/${protocol.slug}-${sliceId}`;
}

const promptsBySlice = Object.fromEntries(
  slices
    .filter((s): s is SliceAssessment & { id: SliceId } => s.id !== undefined)
    .map((s) => [s.id, promptFor(s.id as SliceId)]),
) as Record<SliceId, string>;

const VIEW = 360;
const CENTER = VIEW / 2;
const RADIUS = 110;
const LABEL_RADIUS = 150;

type SlicePath = {
  assessment: SliceAssessment;
  d: string;
  labelLeftPct: number;
  labelTopPct: number;
};

const slicePaths: SlicePath[] = slices.map((s, i) => {
  const angle = (2 * Math.PI) / slices.length;
  const a0 = -Math.PI / 2 + i * angle;
  const a1 = a0 + angle;
  const x0 = CENTER + RADIUS * Math.cos(a0);
  const y0 = CENTER + RADIUS * Math.sin(a0);
  const x1 = CENTER + RADIUS * Math.cos(a1);
  const y1 = CENTER + RADIUS * Math.sin(a1);
  const aMid = a0 + angle / 2;
  const labelX = CENTER + LABEL_RADIUS * Math.cos(aMid);
  const labelY = CENTER + LABEL_RADIUS * Math.sin(aMid);
  return {
    assessment: s,
    d: `M${CENTER},${CENTER} L${x0},${y0} A${RADIUS},${RADIUS} 0 0,1 ${x1},${y1} Z`,
    labelLeftPct: (labelX / VIEW) * 100,
    labelTopPct: (labelY / VIEW) * 100,
  };
});
---
<section class="risk-analysis" id="risk-analysis">
  <h2>Risk analysis</h2>
  <p class="lede">
    One card per dimension. At Phase 0 most cards read <em>not yet assessed</em>; only Verifiability and Dependencies carry automated signals. See <a href="/methodology#what-is-graded-today" class="link">methodology</a> for scope.
  </p>

  <div class="rosette-wrap">
    <div class="rosette">
      <svg viewBox={`0 0 ${VIEW} ${VIEW}`} role="img" aria-label="Risk rosette" preserveAspectRatio="xMidYMid meet">
        {slicePaths.map(({ assessment, d }) => (
          <a href={`#${assessment.id}`} data-slice={assessment.id} class="slice">
            <path d={d} fill={GRADE_FILL[assessment.grade]} stroke="var(--bg)" stroke-width="8" stroke-linejoin="round">
              <title>{`${assessment.label} \u2014 ${assessment.grade === "gray" ? "unknown" : assessment.grade}`}</title>
            </path>
          </a>
        ))}
      </svg>
      {slicePaths.map(({ assessment, labelLeftPct, labelTopPct }) => (
        <span class="rlabel" data-rlabel={assessment.id} style={`left:${labelLeftPct}%;top:${labelTopPct}%`}>
          {assessment.label}
        </span>
      ))}
    </div>

    <div class="tip-slot">
      <div class="tip-default">
        <span>Hover a slice to see the rationale · click to jump to the card below.</span>
      </div>
      {slices.map((s) => (
        <div class:list={["tip", `grade-${s.grade}`]} data-tip={s.id}>
          <div class="tip-meta">
            <span class="tip-label">{s.label}</span>
            <span class="tip-grade">{s.grade === "gray" ? "unknown" : s.grade}</span>
            {s.strength && <span class:list={["strength", `strength-${s.strength}`]}>{s.strength}</span>}
          </div>
          <div class="tip-headline">{s.headline}</div>
        </div>
      ))}
    </div>
  </div>

  <ol class="cards">
    {slices.map((s) => (
      <li id={s.id} class:list={["card", `grade-${s.grade}`]}>
        <div class="stripe" aria-hidden="true"></div>
        <div class="body">
          <div class="meta">
            <span class="label">{s.label}</span>
            <span class="grade">{s.grade === "gray" ? "unknown" : s.grade}</span>
            {s.strength && <span class:list={["strength", `strength-${s.strength}`]}>{s.strength} consensus</span>}
          </div>
          <div class="headline">{s.headline}</div>
          {s.structured ? (
            <div class="structured">
              {s.structured.steelman && s.grade !== "gray" && (
                <div class:list={["steelman-chosen", `grade-${s.grade}`]}>
                  <span class="steelman-label">Steel-man {s.grade}</span>
                  <span class="steelman-text">{s.structured.steelman[s.grade as "red" | "orange" | "green"]}</span>
                </div>
              )}
              <details class="drawer">
                <summary>Verdict</summary>
                <p class="verdict">{s.structured.verdict}</p>
              </details>
              {s.structured.findings.length > 0 && (
                <details class="drawer">
                  <summary>Evidence ({s.structured.findings.length})</summary>
                  <dl class="findings">
                    {s.structured.findings.map((f: Finding) => (
                      <div class="finding">
                        <dt>{f.code}</dt>
                        <dd>{f.text}</dd>
                      </div>
                    ))}
                  </dl>
                </details>
              )}
            </div>
          ) : (
            <p class="rationale">{s.rationale}</p>
          )}

          {s.models && s.models.length > 0 && (
            <div class="sources">
              <span class="sources-label">Sources</span>
              <span class="model-badges">
                {s.models.map((m) => <span class="model-badge">{m}</span>)}
              </span>
              <a class="sources-link" href={`https://github.com/guil-lambert/defipunkd/tree/main/data/submissions/${protocol.slug}/${s.id}`} rel="noreferrer" target="_blank">View raw submissions ↗</a>
            </div>
          )}

          <details class="audit-panel">
            <summary>Audit this slice yourself · DEFI@home</summary>
            <div class="audit-body">
              <p class="audit-intro">
                Paste the prompt below into Claude, ChatGPT, Gemini, or any LLM with browsing. Your JSON output becomes a pull request; the quorum bot merges it once ≥3 independent runs agree. <a href="/contribute" class="link">How it works →</a>
              </p>
              <p class="audit-intro audit-share">
                <strong>Before submitting:</strong> enable <em>Share publicly</em> on your chat session and paste the resulting URL into the <code>chat_url</code> field. Submissions with a verifiable public transcript get extra weight from the quorum bot. <a href="/contribute#sharing-your-chat" class="link">Per-platform instructions →</a>
              </p>
              <p class="audit-intro audit-branch">
                <strong>On the GitHub commit page</strong> (URL params only prefill file content, not the commit form):
              </p>
              <ul class="audit-hints">
                <li>
                  Commit message: <code>{suggestedCommit(s.id as SliceId)}</code>
                  <button type="button" class="mini-copy" data-copy-text={suggestedCommit(s.id as SliceId)} aria-label="Copy commit message">copy</button>
                </li>
                <li>Radio: pick <em>"Create a new branch for this commit and start a pull request"</em></li>
                <li>
                  Branch name: <code>{suggestedBranch(s.id as SliceId)}</code>
                  <button type="button" class="mini-copy" data-copy-text={suggestedBranch(s.id as SliceId)} aria-label="Copy branch name">copy</button>
                </li>
              </ul>
              <div class="audit-toolbar">
                <button type="button" class="copy-btn" data-copy-target={`#prompt-${s.id}`}>
                  Copy prompt
                </button>
                <a href={submitUrl(s.id as SliceId)} rel="noreferrer" target="_blank" class="submit-btn">
                  Submit your run ↗
                </a>
              </div>
              <pre id={`prompt-${s.id}`} class="prompt">{promptsBySlice[s.id as SliceId]}</pre>
            </div>
          </details>
        </div>
      </li>
    ))}
  </ol>
</section>

<script>
  document.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement)?.closest?.("[data-copy-target],[data-copy-text]") as HTMLButtonElement | null;
    if (!btn) return;
    let text = btn.getAttribute("data-copy-text") ?? "";
    if (!text) {
      const sel = btn.getAttribute("data-copy-target");
      const target = sel ? (document.querySelector(sel) as HTMLElement | null) : null;
      if (!target) return;
      text = target.textContent ?? "";
    }
    navigator.clipboard.writeText(text).then(() => {
      const prev = btn.textContent;
      btn.textContent = "Copied ✓";
      setTimeout(() => {
        btn.textContent = prev;
      }, 1500);
    });
  });
</script>

<style>
  .risk-analysis {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 2px solid var(--brand-oxblood);
  }
  h2 { margin: 0 0 0.25rem 0; color: var(--text); font-size: 2.25rem; }
  .lede { color: var(--text-muted); margin: 0 0 1.25rem 0; font-size: 0.9rem; }
  .link { color: var(--accent-link); }

  .rosette-wrap {
    display: grid;
    grid-template-columns: minmax(0, 360px) minmax(0, 1fr);
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  @media (max-width: 720px) {
    .rosette-wrap {
      grid-template-columns: 1fr;
      justify-items: center;
    }
  }

  .rosette {
    position: relative;
    width: 100%;
    max-width: 360px;
    aspect-ratio: 1 / 1;
  }
  .rosette svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  .slice { cursor: pointer; }
  .slice path { transition: opacity 150ms ease; }
  .rosette:has(.slice:hover) .slice:not(:hover) path { opacity: 0.25; }

  .rlabel {
    position: absolute;
    transform: translate(-50%, -50%);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-align: center;
    width: 6rem;
    font-weight: 600;
    pointer-events: none;
    transition: color 150ms ease;
    line-height: 1.2;
  }

  .tip-slot {
    display: grid;
    width: min(420px, 100%);
  }
  .tip,
  .tip-default {
    grid-area: 1 / 1;
    background: var(--surface);
    border: 1px solid var(--surface-raised);
    border-left-width: 3px;
    border-radius: 4px;
    padding: 0.75rem 1rem;
    transition: opacity 150ms ease;
  }
  .tip { opacity: 0; pointer-events: none; }
  .tip-default {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    font-size: 0.82rem;
    font-style: italic;
    text-align: center;
    border-left-color: var(--surface-raised);
  }
  .rosette-wrap:has(.slice:hover) .tip-default { opacity: 0; }

  .tip.grade-gray { border-left-color: var(--grade-gray); }
  .tip.grade-green { border-left-color: var(--grade-green); }
  .tip.grade-orange { border-left-color: var(--grade-orange); }
  .tip.grade-red { border-left-color: var(--grade-red); }

  .tip-meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }
  .tip-label {
    color: var(--text-muted);
    font-size: 0.66rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .tip-grade {
    font-size: 0.66rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .tip.grade-green .tip-grade { color: var(--grade-green); }
  .tip.grade-orange .tip-grade { color: var(--grade-orange); }
  .tip.grade-red .tip-grade { color: var(--grade-red); }
  .tip-headline {
    color: var(--text);
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
  }
  .tip-rationale {
    color: var(--text-muted);
    font-size: 0.82rem;
    line-height: 1.45;
    margin: 0;
  }

  /* Hover-to-highlight wiring — one :has() pair per slice */
  .rosette-wrap:has([data-slice="control"]:hover) [data-rlabel="control"] { color: var(--text); }
  .rosette-wrap:has([data-slice="control"]:hover) [data-tip="control"] { opacity: 1; }
  .rosette-wrap:has([data-slice="ability-to-exit"]:hover) [data-rlabel="ability-to-exit"] { color: var(--text); }
  .rosette-wrap:has([data-slice="ability-to-exit"]:hover) [data-tip="ability-to-exit"] { opacity: 1; }
  .rosette-wrap:has([data-slice="dependencies"]:hover) [data-rlabel="dependencies"] { color: var(--text); }
  .rosette-wrap:has([data-slice="dependencies"]:hover) [data-tip="dependencies"] { opacity: 1; }
  .rosette-wrap:has([data-slice="access"]:hover) [data-rlabel="access"] { color: var(--text); }
  .rosette-wrap:has([data-slice="access"]:hover) [data-tip="access"] { opacity: 1; }
  .rosette-wrap:has([data-slice="verifiability"]:hover) [data-rlabel="verifiability"] { color: var(--text); }
  .rosette-wrap:has([data-slice="verifiability"]:hover) [data-tip="verifiability"] { opacity: 1; }

  .cards {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.75rem;
  }
  .card {
    position: relative;
    display: grid;
    grid-template-columns: 10px 1fr;
    background: var(--surface);
    border: 1px solid var(--surface-raised);
    border-radius: 6px;
    overflow: hidden;
    scroll-margin-top: 1rem;
    box-shadow: 0 1px 0 rgba(0,0,0,0.35);
  }
  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg, currentColor 0%, transparent 72px);
    opacity: 0.08;
    color: var(--grade-gray);
  }
  .card.grade-green::before { color: var(--grade-green); }
  .card.grade-orange::before { color: var(--grade-orange); }
  .card.grade-red::before { color: var(--grade-red); }
  .card.grade-gray::before { color: var(--grade-gray); }
  .stripe { width: 10px; background: var(--grade-gray); }
  .card.grade-green .stripe { background: var(--grade-green); }
  .card.grade-orange .stripe { background: var(--grade-orange); }
  .card.grade-red .stripe { background: var(--grade-red); }
  .card.grade-gray .stripe { background: var(--grade-gray); }
  .body { position: relative; padding: 1rem 1.25rem 1.15rem 1.25rem; }
  .meta {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.2rem;
  }
  .label {
    color: var(--text);
    font-size: 1.2rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .card.grade-green .label { color: var(--grade-green); }
  .card.grade-orange .label { color: var(--grade-orange); }
  .card.grade-red .label { color: var(--grade-red); }
  .grade {
    color: var(--text-muted);
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .card.grade-green .grade { color: var(--grade-green); }
  .card.grade-orange .grade { color: var(--grade-orange); }
  .card.grade-red .grade { color: var(--grade-red); }
  .strength {
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
    padding: 0.12rem 0.45rem;
    border-radius: 999px;
    border: 1px solid var(--surface-raised);
    color: var(--text-muted);
  }
  .strength-strong { color: var(--text); border-color: var(--text-muted); }
  .strength-weak { opacity: 0.75; }
  .headline {
    color: var(--text);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
  }
  .rationale {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.5;
    margin: 0;
  }
  .structured { display: flex; flex-direction: column; gap: 0.6rem; }
  .steelman-chosen {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.6rem;
    padding: 0.6rem 0.8rem;
    background: var(--surface-raised);
    border-radius: 4px;
    font-size: 0.85rem;
    line-height: 1.5;
  }
  .steelman-label {
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--text-muted);
    align-self: start;
    padding-top: 0.15rem;
    white-space: nowrap;
  }
  .steelman-chosen.grade-red .steelman-label { color: var(--grade-red); }
  .steelman-chosen.grade-orange .steelman-label { color: var(--grade-orange); }
  .steelman-chosen.grade-green .steelman-label { color: var(--grade-green); }
  .steelman-text { color: var(--text-muted); }

  .drawer {
    border: 1px solid var(--surface-raised);
    border-radius: 4px;
    background: var(--surface-raised);
  }
  .drawer[open] { padding-bottom: 0.5rem; }
  .drawer > summary {
    list-style: none;
    cursor: pointer;
    padding: 0.35rem 0.8rem;
    color: var(--text-muted);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    font-weight: 600;
    text-transform: uppercase;
  }
  .drawer > summary::-webkit-details-marker { display: none; }
  .drawer > summary::after {
    content: " ▸";
    color: var(--text-muted);
    font-size: 0.7rem;
    transition: transform 150ms ease;
    display: inline-block;
  }
  .drawer[open] > summary::after { transform: rotate(90deg); }
  .verdict {
    margin: 0.1rem 0.8rem 0.3rem 0.8rem;
    color: var(--text);
    font-size: 0.88rem;
    font-weight: 500;
    line-height: 1.5;
  }
  .findings {
    margin: 0.1rem 0.8rem 0.3rem 0.8rem;
    padding: 0;
    display: grid;
    grid-template-columns: min-content 1fr;
    gap: 0.35rem 0.75rem;
    font-size: 0.85rem;
    line-height: 1.5;
  }
  .finding { display: contents; }
  .findings dt {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.72rem;
    color: var(--text-muted);
    background: var(--bg);
    padding: 0.05rem 0.45rem;
    border-radius: 3px;
    align-self: start;
    white-space: nowrap;
    font-weight: 600;
  }
  .findings dd { margin: 0; color: var(--text-muted); }

  .sources {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    font-size: 0.75rem;
  }
  .sources-label {
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
    font-size: 0.68rem;
  }
  .model-badges { display: inline-flex; flex-wrap: wrap; gap: 0.35rem; }
  .model-badge {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    background: var(--surface-raised);
    color: var(--text);
    font-size: 0.72rem;
    font-weight: 500;
    font-family: var(--font-mono), ui-monospace, monospace;
  }
  .sources-link {
    color: var(--accent-link);
    font-size: 0.75rem;
    text-decoration: none;
    margin-left: auto;
  }
  .sources-link:hover { text-decoration: underline; }

  .audit-panel {
    margin-top: 0.75rem;
    background: var(--surface-raised);
    border-radius: 4px;
    padding: 0.5rem 0.85rem;
  }
  .audit-panel[open] { padding-bottom: 0.85rem; }
  .audit-panel > summary {
    list-style: none;
    cursor: pointer;
    color: var(--accent-link);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding: 0.2rem 0;
  }
  .audit-panel > summary::-webkit-details-marker { display: none; }
  .audit-panel > summary::after {
    content: " ▸";
    color: var(--text-muted);
    font-size: 0.7rem;
    transition: transform 150ms ease;
    display: inline-block;
  }
  .audit-panel[open] > summary::after { transform: rotate(90deg); }

  .audit-body {
    margin-top: 0.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .audit-intro {
    color: var(--text-muted);
    font-size: 0.82rem;
    line-height: 1.5;
    margin: 0;
  }
  .audit-hints {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--text-muted);
    font-size: 0.82rem;
    line-height: 1.6;
  }
  .audit-hints li { display: flex; align-items: center; flex-wrap: wrap; gap: 0.4rem; }
  .mini-copy {
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.1rem 0.45rem;
    border-radius: 3px;
