---
import type { Protocol, LoadedAssessment, AssessmentSliceId, Finding } from "@defipunkd/registry";
import { assessProtocol, cexAssessment, type SliceAssessment } from "../lib/rationale";
import { buildPrompt, PROMPT_VERSION, type SliceId } from "@defipunkd/prompts";
import RiskMatrix from "./RiskMatrix.astro";

interface Props {
  protocol: Protocol;
  snapshotGeneratedAt: string;
  assessments?: Map<AssessmentSliceId, LoadedAssessment>;
}
const { protocol, snapshotGeneratedAt, assessments } = Astro.props;
const rawSlices: SliceAssessment[] = protocol.category === "CEX" ? cexAssessment() : assessProtocol(protocol, assessments);

const SEVERITY_ORDER: Record<string, number> = { red: 0, orange: 1, green: 2, gray: 3 };
const slices = [...rawSlices].sort(
  (a, b) => (SEVERITY_ORDER[a.grade] ?? 9) - (SEVERITY_ORDER[b.grade] ?? 9),
);
const gradedSlices = slices.filter((s) => s.grade !== "gray");
const graySlices = slices.filter((s) => s.grade === "gray");

const ANALYSIS_DATE = new Date().toISOString().slice(0, 10);
const REPO = "guil-lambert/defipunkd";

function promptFor(sliceId: SliceId): string {
  return buildPrompt(sliceId, {
    slug: protocol.slug,
    name: protocol.name,
    chains: protocol.chains,
    category: protocol.category || null,
    website: protocol.website,
    github: protocol.github ?? [],
    auditLinks: protocol.audit_links ?? [],
    snapshotGeneratedAt,
    analysisDate: ANALYSIS_DATE,
    addressBook: null,
  });
}

function stubFor(sliceId: SliceId): string {
  return JSON.stringify(
    {
      schema_version: 2,
      slug: protocol.slug,
      slice: sliceId,
      snapshot_generated_at: snapshotGeneratedAt,
      prompt_version: PROMPT_VERSION,
      analysis_date: ANALYSIS_DATE,
      model: "",
      chat_url: null,
      grade: "",
      headline: "",
      rationale: { findings: [], steelman: { red: "", orange: "", green: "" }, verdict: "" },
      evidence: [],
      unknowns: [],
    },
    null,
    2,
  );
}

function submitUrl(sliceId: SliceId): string {
  const params = new URLSearchParams({
    filename: `data/submissions/${protocol.slug}/${sliceId}/your-model-${ANALYSIS_DATE}.json`,
    value: stubFor(sliceId),
  });
  return `https://github.com/${REPO}/new/main?${params.toString()}`;
}

const auditSlices = slices.map((s) => ({
  id: s.id as SliceId,
  label: s.label,
  prompt: promptFor(s.id as SliceId),
  submitUrl: submitUrl(s.id as SliceId),
}));

const TAXONOMY_LABEL: Record<string, string> = {
  red: "Steel-man argument",
  orange: "Steel-man argument",
  green: "Steel-man argument",
};

function chipLabel(grade: string): string {
  return grade === "gray" ? "unknown" : grade;
}

const TOP_EVIDENCE = 2;
---
<section class="risk-analysis" id="risk-analysis">
  <h2>Risk analysis</h2>
  <p class="lede">
    One card per dimension, sorted by severity. Only <em>Verifiability</em> and <em>Dependencies</em> carry automated signals in Phase 0. See <a href="/methodology#what-is-graded-today" class="link">methodology</a> for scope.
  </p>

  <RiskMatrix slices={slices} variant="full" />

  <details class="audit-top">
    <summary><span class="audit-top-title">Audit a dimension yourself · DEFI@home</span></summary>
    <div class="audit-top-body">
      <p>
        Paste a slice prompt into Claude, ChatGPT, Gemini, or any LLM with browsing. Your JSON output becomes a pull request; the quorum bot merges it once ≥3 independent runs agree. <a href="/contribute" class="link">How it works →</a>
      </p>
      <ul class="audit-list">
        {auditSlices.map((a) => (
          <li>
            <span class="audit-list-label">{a.label}</span>
            <button type="button" class="copy-btn" data-copy-target={`#prompt-${a.id}`}>Copy prompt</button>
            <a href={a.submitUrl} rel="noreferrer" target="_blank" class="submit-btn">Submit run ↗</a>
            <pre id={`prompt-${a.id}`} class="prompt-hidden" hidden>{a.prompt}</pre>
          </li>
        ))}
      </ul>
    </div>
  </details>

  <ol class="cards">
    {gradedSlices.map((s) => (
      <li id={s.id} class:list={["card", `grade-${s.grade}`]}>
        <div class="stripe" aria-hidden="true"></div>
        <div class="body">
          <div class="meta">
            <span class="label">{s.label}</span>
            <span class:list={["chip", `grade-${s.grade}`]}>{chipLabel(s.grade)}</span>
            {s.models && s.models.length > 0 && (
              <span
                class:list={["consensus", s.models.length >= 2 ? "consensus-agree" : "consensus-single"]}
                title={s.strength ? `${s.strength} consensus` : undefined}
              >
                {s.models.length >= 2
                  ? `${s.models.length}/${s.models.length} models agree`
                  : "1 model"}
              </span>
            )}
          </div>
          <div class="headline">{s.headline}</div>
          {s.structured ? (
            <div class="structured">
              {s.structured.steelman && s.structured.steelman[s.grade as "red" | "orange" | "green"] && (
                <div class:list={["steelman-chosen", `grade-${s.grade}`]}>
                  <span class="steelman-label">{TAXONOMY_LABEL[s.grade] ?? "Argument"}</span>
                  <span class="steelman-text">{s.structured.steelman[s.grade as "red" | "orange" | "green"]}</span>
                </div>
              )}
              {s.structured.verdict && s.structured.verdict.trim().length > 0 && (
                <details class="drawer">
                  <summary>Verdict</summary>
                  <p class="verdict">{s.structured.verdict}</p>
                </details>
              )}
              {s.structured.findings.length > 0 && (
                <div class="evidence">
                  <div class="evidence-head">
                    Evidence ({s.structured.findings.length})
                  </div>
                  <dl class="findings">
                    {s.structured.findings.slice(0, TOP_EVIDENCE).map((f: Finding) => (
                      <div class="finding">
                        <dt>{f.code}</dt>
                        <dd>{f.text}</dd>
                      </div>
                    ))}
                  </dl>
                  {s.structured.findings.length > TOP_EVIDENCE && (
                    <details class="more-evidence">
                      <summary>Show all {s.structured.findings.length} ▸</summary>
                      <dl class="findings">
                        {s.structured.findings.slice(TOP_EVIDENCE).map((f: Finding) => (
                          <div class="finding">
                            <dt>{f.code}</dt>
                            <dd>{f.text}</dd>
                          </div>
                        ))}
                      </dl>
                    </details>
                  )}
                </div>
              )}
            </div>
          ) : (
            <p class="rationale">{s.rationale}</p>
          )}

          {s.models && s.models.length > 0 && (
            <div class="sources">
              <span class="sources-label">Sources</span>
              <span class="model-badges">
                {s.models.map((m) => <span class="model-badge">{m}</span>)}
              </span>
              <a class="sources-link" href={`https://github.com/guil-lambert/defipunkd/tree/main/data/submissions/${protocol.slug}/${s.id}`} rel="noreferrer" target="_blank">View raw submissions ↗</a>
            </div>
          )}
        </div>
      </li>
    ))}
  </ol>

  {graySlices.length > 0 && (
    <details class="unknowns">
      <summary>
        <span class="unknowns-summary">
          {graySlices.length} dimension{graySlices.length === 1 ? "" : "s"} not yet assessed ({graySlices.map((s) => s.label).join(", ")})
        </span>
      </summary>
      <ol class="cards unknowns-list">
        {graySlices.map((s) => (
          <li id={s.id} class="card grade-gray">
            <div class="stripe" aria-hidden="true"></div>
            <div class="body">
              <div class="meta">
                <span class="label">{s.label}</span>
                <span class="chip grade-gray">unknown</span>
              </div>
              <div class="headline">{s.headline}</div>
              <p class="rationale">{s.rationale}</p>
            </div>
          </li>
        ))}
      </ol>
    </details>
  )}
</section>

<script>
  document.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement)?.closest?.("[data-copy-target],[data-copy-text]") as HTMLButtonElement | null;
    if (!btn) return;
    let text = btn.getAttribute("data-copy-text") ?? "";
    if (!text) {
      const sel = btn.getAttribute("data-copy-target");
      const target = sel ? (document.querySelector(sel) as HTMLElement | null) : null;
      if (!target) return;
      text = target.textContent ?? "";
    }
    navigator.clipboard.writeText(text).then(() => {
      const prev = btn.textContent;
      btn.textContent = "Copied ✓";
      setTimeout(() => {
        btn.textContent = prev;
      }, 1500);
    });
  });
</script>

<style>
  .risk-analysis {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 2px solid var(--brand-oxblood);
  }
  h2 { margin: 0 0 0.25rem 0; color: var(--text); font-size: 2.25rem; scroll-margin-top: 1rem; }
  .lede { color: var(--text-muted); margin: 0 0 1.25rem 0; font-size: 0.9rem; }
  .link { color: var(--accent-link); }

  .audit-top {
    margin: 1rem 0 1.5rem 0;
    background: var(--surface);
    border: 1px solid var(--surface-raised);
    border-radius: 4px;
    padding: 0.5rem 0.9rem;
  }
  .audit-top[open] { padding-bottom: 0.9rem; }
  .audit-top > summary {
    list-style: none;
    cursor: pointer;
    padding: 0.25rem 0;
  }
  .audit-top > summary::-webkit-details-marker { display: none; }
  .audit-top-title {
    color: var(--accent-link);
    font-size: 0.82rem;
    font-weight: 500;
  }
  .audit-top > summary::after {
    content: " ▸";
    color: var(--text-muted);
    font-size: 0.7rem;
    transition: transform 150ms ease;
    display: inline-block;
  }
  .audit-top[open] > summary::after { transform: rotate(90deg); }
  .audit-top-body { margin-top: 0.5rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .audit-top-body p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.82rem;
    line-height: 1.5;
  }
  .audit-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.4rem;
  }
  .audit-list li {
    display: grid;
    grid-template-columns: minmax(8rem, 1fr) auto auto;
    align-items: center;
    gap: 0.5rem;
  }
  .audit-list-label {
    color: var(--text);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .cards {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.75rem;
  }
  .card {
    position: relative;
    display: grid;
    grid-template-columns: 10px 1fr;
    background: var(--surface);
    border: 1px solid var(--surface-raised);
    border-radius: 6px;
    overflow: hidden;
    scroll-margin-top: 1rem;
    box-shadow: 0 1px 0 rgba(0,0,0,0.35);
  }
  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg, currentColor 0%, transparent 72px);
    opacity: 0.08;
    color: var(--grade-gray);
  }
  .card.grade-green::before { color: var(--grade-green); }
  .card.grade-orange::before { color: var(--grade-orange); }
  .card.grade-red::before { color: var(--grade-red); }
  .card.grade-gray::before { color: var(--grade-gray); }
  .stripe { width: 10px; background: var(--grade-gray); }
  .card.grade-green .stripe { background: var(--grade-green); }
  .card.grade-orange .stripe { background: var(--grade-orange); }
  .card.grade-red .stripe { background: var(--grade-red); }
  .card.grade-gray .stripe { background: var(--grade-gray); }
  .body { position: relative; padding: 1rem 1.25rem 1.15rem 1.25rem; }
  .meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.55rem 0.75rem;
    margin-bottom: 0.25rem;
  }
  .label {
    color: var(--text);
    font-size: 1.2rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .card.grade-green .label { color: var(--grade-green); }
  .card.grade-orange .label { color: var(--grade-orange); }
  .card.grade-red .label { color: var(--grade-red); }
  .chip {
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 0.18rem 0.55rem;
    border-radius: 999px;
  }
  .chip.grade-red    { background: oklch(0.62 0.170 22);  color: #fff; }
  .chip.grade-orange { background: oklch(0.78 0.140 75);  color: #1a1208; }
  .chip.grade-green  { background: oklch(0.74 0.140 150); color: #081610; }
  .chip.grade-gray   { background: oklch(0.72 0.015 235); color: #0d1114; }
  .consensus {
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    font-weight: 600;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    border: 1px solid var(--surface-raised);
    color: var(--text-muted);
    white-space: nowrap;
  }
  .consensus-agree { color: var(--grade-green); border-color: color-mix(in oklab, var(--grade-green) 40%, var(--surface-raised)); }
  .consensus-single { color: var(--text-muted); }
  .headline {
    color: var(--text);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .rationale {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.5;
    margin: 0;
  }
  .structured { display: flex; flex-direction: column; gap: 0.7rem; }
  .steelman-chosen {
    padding: 0.7rem 0.9rem;
    background: var(--surface-raised);
    border-radius: 4px;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--text);
  }
  .steelman-label {
    display: block;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--text-muted);
    margin-bottom: 0.3rem;
  }
  .steelman-text { color: var(--text); }

  .drawer {
    border: 1px solid var(--surface-raised);
    border-radius: 4px;
    background: var(--surface-raised);
  }
  .drawer[open] { padding-bottom: 0.5rem; }
  .drawer > summary {
    list-style: none;
    cursor: pointer;
    padding: 0.4rem 0.85rem;
    color: var(--text-muted);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    font-weight: 700;
    text-transform: uppercase;
  }
  .drawer > summary::-webkit-details-marker { display: none; }
  .drawer > summary::after {
    content: " ▸";
    color: var(--text-muted);
    font-size: 0.7rem;
    transition: transform 150ms ease;
    display: inline-block;
  }
  .drawer[open] > summary::after { transform: rotate(90deg); }
  .verdict {
    margin: 0.1rem 0.85rem 0.35rem 0.85rem;
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.5;
  }

  .evidence { display: flex; flex-direction: column; gap: 0.35rem; }
  .evidence-head {
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .findings {
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: min-content 1fr;
    gap: 0.4rem 0.75rem;
    font-size: 0.88rem;
    line-height: 1.5;
  }
  .finding { display: contents; }
  .findings dt {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.72rem;
    color: var(--text-muted);
    background: var(--bg);
    padding: 0.05rem 0.45rem;
    border-radius: 3px;
    align-self: start;
    white-space: nowrap;
    font-weight: 600;
  }
  .findings dd { margin: 0; color: var(--text); }
  .more-evidence > summary {
    list-style: none;
    cursor: pointer;
    color: var(--accent-link);
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.15rem 0;
  }
  .more-evidence > summary::-webkit-details-marker { display: none; }
  .more-evidence > .findings { margin-top: 0.35rem; }

  .sources {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.6rem;
    font-size: 0.75rem;
  }
  .sources-label {
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
    font-size: 0.68rem;
  }
  .model-badges { display: inline-flex; flex-wrap: wrap; gap: 0.35rem; }
  .model-badge {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    background: var(--surface-raised);
    color: var(--text);
    font-size: 0.72rem;
    font-weight: 500;
    font-family: var(--font-mono), ui-monospace, monospace;
  }
  .sources-link {
    color: var(--accent-link);
    font-size: 0.75rem;
    text-decoration: none;
    margin-left: auto;
  }
  .sources-link:hover { text-decoration: underline; }

  .unknowns {
    margin-top: 1.5rem;
    border: 1px solid var(--surface-raised);
    border-radius: 4px;
    padding: 0.5rem 0.9rem;
    background: var(--surface);
  }
  .unknowns[open] { padding-bottom: 1rem; }
  .unknowns > summary {
    list-style: none;
    cursor: pointer;
    padding: 0.3rem 0;
    color: var(--text-muted);
  }
  .unknowns > summary::-webkit-details-marker { display: none; }
  .unknowns > summary::before {
    content: "▸ ";
    color: var(--text-muted);
    display: inline-block;
    transition: transform 150ms ease;
  }
  .unknowns[open] > summary::before { transform: rotate(90deg); }
  .unknowns-summary {
    font-size: 0.88rem;
    color: var(--text);
    font-weight: 500;
  }
  .unknowns-list { margin-top: 0.75rem; gap: 1rem; }

  .copy-btn,
  .submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem 0.75rem;
    border-radius: 4px;
    font-size: 0.76rem;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    border: 1px solid var(--surface-raised);
    background: var(--surface-raised);
    color: var(--text);
    min-height: 28px;
    white-space: nowrap;
  }
  .submit-btn { color: var(--accent-link); background: transparent; }
  .copy-btn:hover,
  .submit-btn:hover { background: var(--accent-link); color: var(--bg); border-color: var(--accent-link); }

  .prompt-hidden { display: none; }

  @media (max-width: 720px) {
    .audit-list li {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
