---
import type { Protocol } from "@defibeat/registry";
import { formatUtc } from "../lib/format";

interface Props {
  protocol: Protocol;
}
const { protocol } = Astro.props;
---
<main class="delisted">
  <div class="back">
    <a href="/">← back to index</a>
  </div>
  <h1>{protocol.name}</h1>
  <p class="warn">
    This protocol has been delisted from DeFiLlama as of {formatUtc(protocol.delisted_at)}.
  </p>
  <p class="muted">
    DefiBeat mirrors DeFiLlama. See the{" "}
    <a href={`https://defillama.com/protocol/${protocol.slug}`} class="link" rel="noreferrer" target="_blank">
      DeFiLlama page
    </a>{" "}
    for the last known data.
  </p>
</main>

<style>
  .delisted {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
    color: var(--text);
  }
  .back { margin-bottom: 1rem; }
  .back a { color: var(--accent-link); font-size: 0.85rem; text-decoration: none; }
  h1 { color: var(--text); }
  .warn { color: var(--grade-red); }
  .muted { color: var(--text-muted); }
  .link { color: var(--accent-link); }
</style>
