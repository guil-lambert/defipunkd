---
// SVG line chart of {timestamp, value} points. Pure SSR — no client JS.
// Auto-scales y to its own data so small series stay legible. Renders an
// invisible hover rail above the SVG: each commit gets a Voronoi-bucketed
// hit zone that surfaces a date+value tooltip and a dot on the line.

interface Point {
  timestamp: string;
  value: number;
}

interface Props {
  points: Point[];
  label: string;
  stroke: string;
  height?: number;
}

const { points, label, stroke, height = 64 } = Astro.props;

const width = 240;
const padX = 4;
const padY = 6;

const xs = points.map((p) => new Date(p.timestamp).getTime());
const ys = points.map((p) => p.value);
const minX = Math.min(...xs);
const maxX = Math.max(...xs);
const minY = 0;
const maxY = Math.max(1, ...ys);

const innerW = width - padX * 2;
const innerH = height - padY * 2;

const scaleX = (t: number) =>
  padX + (maxX === minX ? innerW / 2 : ((t - minX) / (maxX - minX)) * innerW);
const scaleY = (v: number) =>
  padY + innerH - (maxY === minY ? 0 : ((v - minY) / (maxY - minY)) * innerH);

const linePath = points
  .map((p, i) => `${i === 0 ? "M" : "L"} ${scaleX(xs[i]!).toFixed(2)} ${scaleY(p.value).toFixed(2)}`)
  .join(" ");

const areaPath = `${linePath} L ${scaleX(maxX).toFixed(2)} ${(padY + innerH).toFixed(2)} L ${scaleX(minX).toFixed(2)} ${(padY + innerH).toFixed(2)} Z`;

// Per-tick % positions in the rendered chart's box. Voronoi midpoints between
// neighbors give each commit its own hit zone whose center IS the data point.
const xPct = points.map((_, i) => (scaleX(xs[i]!) / width) * 100);
const yPct = points.map((p) => (scaleY(p.value) / height) * 100);
const ticks = points.map((p, i) => {
  const left = i === 0 ? 0 : (xPct[i - 1]! + xPct[i]!) / 2;
  const right = i === points.length - 1 ? 100 : (xPct[i]! + xPct[i + 1]!) / 2;
  return { p, left, width: right - left, y: yPct[i]! };
});

const last = points[points.length - 1];
const first = points[0];
const fmt = (n: number) => n.toLocaleString();
const fmtDate = (iso: string) => {
  const d = new Date(iso);
  const pad = (n: number) => String(n).padStart(2, "0");
  return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
};
---

<div class="growth-chart" style={`--gc-stroke: ${stroke};`}>
  <div class="growth-chart-header">
    <span class="growth-chart-value">{fmt(last?.value ?? 0)}</span>
    <span class="growth-chart-label">{label}</span>
  </div>
  <div class="growth-chart-plot">
    <svg
      viewBox={`0 0 ${width} ${height}`}
      preserveAspectRatio="none"
      role="img"
      aria-label={`${label}: ${fmt(first?.value ?? 0)} → ${fmt(last?.value ?? 0)} over ${points.length} commits`}
    >
      <path d={areaPath} fill={stroke} fill-opacity="0.12" />
      <path d={linePath} fill="none" stroke={stroke} stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round" />
    </svg>
    <div class="growth-chart-rail" aria-hidden="true">
      {ticks.map(({ p, left, width: w, y }) => (
        <div
          class="gc-tick"
          tabindex="0"
          style={`left: ${left.toFixed(3)}%; width: ${w.toFixed(3)}%; --gc-y: ${(y ?? 0).toFixed(2)}%;`}
        >
          <span class="gc-dot"></span>
          <span class="gc-rule"></span>
          <span class="tt" role="tooltip">
            <span class="tt-line">{fmtDate(p.timestamp)}</span>
            <span class="tt-line">{fmt(p.value)}</span>
          </span>
        </div>
      ))}
    </div>
  </div>
  <div class="growth-chart-footer">
    <span>{first ? new Date(first.timestamp).toISOString().slice(0, 10) : ""}</span>
    <span>{last ? new Date(last.timestamp).toISOString().slice(0, 10) : ""}</span>
  </div>
</div>

<style>
  .growth-chart {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .growth-chart-header {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    font-size: 0.85rem;
  }

  .growth-chart-value {
    font-variant-numeric: tabular-nums;
    font-weight: 700;
    font-size: 1rem;
    color: var(--gc-stroke);
  }

  .growth-chart-label {
    color: var(--muted, #888);
  }

  .growth-chart-plot {
    position: relative;
    width: 100%;
  }

  .growth-chart svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .growth-chart-rail {
    position: absolute;
    inset: 0;
  }

  .gc-tick {
    position: absolute;
    top: 0;
    height: 100%;
  }
  .gc-tick:focus { outline: none; }

  .gc-dot {
    position: absolute;
    left: 50%;
    top: var(--gc-y);
    transform: translate(-50%, -50%);
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--gc-stroke);
    border: 2px solid oklch(0.18 0.005 235);
    box-shadow: 0 0 0 1px var(--gc-stroke);
    opacity: 0;
    pointer-events: none;
    transition: opacity 60ms ease-out;
  }
  .gc-rule {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 1px;
    background: rgba(255, 255, 255, 0.18);
    transform: translateX(-50%);
    opacity: 0;
    pointer-events: none;
    transition: opacity 60ms ease-out;
  }
  .gc-tick:hover .gc-dot,
  .gc-tick:focus-within .gc-dot,
  .gc-tick:hover .gc-rule,
  .gc-tick:focus-within .gc-rule {
    opacity: 1;
  }

  .gc-tick > .tt {
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%) translateY(-2px);
    background: oklch(0.28 0.008 235);
    color: oklch(0.95 0.01 235);
    padding: 0.3rem 0.55rem;
    border-radius: 4px;
    border: 1px solid oklch(0.42 0.012 235);
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.5);
    font-size: 0.72rem;
    font-weight: 500;
    line-height: 1.3;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 60ms ease-out, transform 60ms ease-out;
    z-index: 100;
  }
  .gc-tick > .tt::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 4px solid transparent;
    border-top-color: oklch(0.28 0.008 235);
  }
  .gc-tick:hover > .tt,
  .gc-tick:focus-within > .tt {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  .gc-tick > .tt .tt-line { display: block; }
  .gc-tick > .tt .tt-line + .tt-line {
    margin-top: 0.15rem;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
  }

  .growth-chart-footer {
    display: flex;
    justify-content: space-between;
    font-size: 0.7rem;
    color: var(--muted, #888);
    font-variant-numeric: tabular-nums;
  }
</style>
