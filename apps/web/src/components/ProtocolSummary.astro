---
import type { Protocol, LoadedAssessment, AssessmentSliceId, LoadedSubmission } from "@defipunkd/registry";
import { getProtocolMetadata } from "@defipunkd/registry";
import { EM_DASH, formatTvl, primaryChain } from "../lib/format";
import { assessProtocol, cexAssessment, isUncertain, type SliceAssessment } from "../lib/rationale";
import RiskMatrix from "./RiskMatrix.astro";
import { deriveTier, type TierInput } from "../lib/tier";
import type { PizzaSliceId } from "../lib/pizza";

interface Props {
  protocol: Protocol;
  assessments?: Map<AssessmentSliceId, LoadedAssessment>;
  submissions?: Map<AssessmentSliceId, LoadedSubmission[]>;
  idPrefix?: string;
}
const { protocol, assessments, submissions, idPrefix = "" } = Astro.props;
const idp = idPrefix ? `${idPrefix}-` : "";

const headerSlices: SliceAssessment[] = protocol.category === "CEX" ? cexAssessment() : assessProtocol(protocol, assessments, submissions);

let tierInput: TierInput | undefined;
if ((assessments && assessments.size > 0) || (submissions && submissions.size > 0)) {
  tierInput = {};
  if (assessments) {
    const tentativeBySlice = new Map<string, boolean>();
    for (const s of headerSlices) tentativeBySlice.set(s.id, !!s.tentative);
    for (const [sliceId, a] of assessments.entries()) {
      tierInput[sliceId as PizzaSliceId] = {
        models: a.models,
        merged_at: a.merged_at,
        human_signoff: a.human_signoff ?? null,
        tentative: tentativeBySlice.get(sliceId) ?? false,
      };
    }
  }
  if (submissions) {
    for (const [sliceId, arr] of submissions.entries()) {
      const existing = tierInput[sliceId as PizzaSliceId] ?? {};
      tierInput[sliceId as PizzaSliceId] = { ...existing, submissionCount: arr.length };
    }
  }
}
const protocolTier = deriveTier(tierInput);

const GRADE_FILL: Record<string, string> = {
  gray: "oklch(0.55 0.015 235)",
  green: "oklch(0.60 0.130 150)",
  orange: "oklch(0.65 0.120 75)",
  red: "oklch(0.52 0.170 22)",
};

function tentativeGrade(s: SliceAssessment): string {
  if (!s.partial || !s.partialModelGrades || s.partialModelGrades.length === 0) return s.grade;
  // Tentative pizza fill: pick the most-severe grade across submissions so the
  // visual bias is "warn first, confirm later". Severity: red > orange > gray > green.
  const order: Record<string, number> = { red: 0, orange: 1, gray: 2, green: 3 };
  const sorted = [...s.partialModelGrades].sort(
    (a, b) => (order[a.grade] ?? 9) - (order[b.grade] ?? 9),
  );
  return sorted[0]?.grade ?? "gray";
}
const PIZZA_VIEW = 360;
const PIZZA_CENTER = PIZZA_VIEW / 2;
const PIZZA_RADIUS = 140;
const PIZZA_LABEL_RADIUS = 165;
const SHORT_LABEL: Record<string, string> = {
  control: "Control",
  "ability-to-exit": "Exit",
  autonomy: "Autonomy",
  access: "Open Access",
  verifiability: "Verifiable",
};
const PIZZA_CR = 12;
const PIZZA_TIP_R = 8;
const pizzaSlices = headerSlices.map((s, i) => {
  const fillGrade = tentativeGrade(s);
  const a = (2 * Math.PI) / headerSlices.length;
  const a0 = -Math.PI / 2 + i * a;
  const a1 = a0 + a;
  const aMid = a0 + a / 2;
  const da = Math.min(PIZZA_CR / PIZZA_RADIUS, a / 2 - 0.01);
  const Ax = PIZZA_CENTER + (PIZZA_RADIUS - PIZZA_CR) * Math.cos(a0);
  const Ay = PIZZA_CENTER + (PIZZA_RADIUS - PIZZA_CR) * Math.sin(a0);
  const Bx = PIZZA_CENTER + PIZZA_RADIUS * Math.cos(a0 + da);
  const By = PIZZA_CENTER + PIZZA_RADIUS * Math.sin(a0 + da);
  const Cx = PIZZA_CENTER + PIZZA_RADIUS * Math.cos(a1 - da);
  const Cy = PIZZA_CENTER + PIZZA_RADIUS * Math.sin(a1 - da);
  const Dx = PIZZA_CENTER + (PIZZA_RADIUS - PIZZA_CR) * Math.cos(a1);
  const Dy = PIZZA_CENTER + (PIZZA_RADIUS - PIZZA_CR) * Math.sin(a1);
  const Tx0 = PIZZA_CENTER + PIZZA_TIP_R * Math.cos(a0);
  const Ty0 = PIZZA_CENTER + PIZZA_TIP_R * Math.sin(a0);
  const Tx1 = PIZZA_CENTER + PIZZA_TIP_R * Math.cos(a1);
  const Ty1 = PIZZA_CENTER + PIZZA_TIP_R * Math.sin(a1);
  const labelX = PIZZA_CENTER + PIZZA_LABEL_RADIUS * Math.cos(aMid);
  const labelY = PIZZA_CENTER + PIZZA_LABEL_RADIUS * Math.sin(aMid);
  return {
    assessment: s,
    fillGrade,
    d: `M${Tx0.toFixed(2)},${Ty0.toFixed(2)} L${Ax.toFixed(2)},${Ay.toFixed(2)} A${PIZZA_CR},${PIZZA_CR} 0 0 1 ${Bx.toFixed(2)},${By.toFixed(2)} A${PIZZA_RADIUS},${PIZZA_RADIUS} 0 0 1 ${Cx.toFixed(2)},${Cy.toFixed(2)} A${PIZZA_CR},${PIZZA_CR} 0 0 1 ${Dx.toFixed(2)},${Dy.toFixed(2)} L${Tx1.toFixed(2)},${Ty1.toFixed(2)} A${PIZZA_TIP_R},${PIZZA_TIP_R} 0 0 1 ${Tx0.toFixed(2)},${Ty0.toFixed(2)} Z`,
    labelLeftPct: (labelX / PIZZA_VIEW) * 100,
    labelTopPct: (labelY / PIZZA_VIEW) * 100,
    shortLabel: SHORT_LABEL[s.id] ?? s.label,
  };
});

const primary = primaryChain(protocol.tvl_by_chain) ?? protocol.chains[0] ?? null;
const CHAIN_LIMIT = 5;
const shownChains = protocol.chains.slice(0, CHAIN_LIMIT);
const extraChains = Math.max(0, protocol.chains.length - CHAIN_LIMIT);

function safeHost(url: string | null): string | null {
  if (!url) return null;
  try {
    return new URL(url).hostname.replace(/^www\./, "");
  } catch {
    return url;
  }
}

const metadata = getProtocolMetadata(protocol.slug);

const upgradeability = metadata?.upgradeability ?? null;
const bugBountyUrl = metadata?.bug_bounty_url ?? null;
const governanceForum = metadata?.governance_forum ?? null;
const docsUrl = metadata?.docs_url ?? null;
const bugBountyHost = safeHost(bugBountyUrl);
const governanceHost = safeHost(governanceForum);
const docsHost = safeHost(docsUrl);

const upgradeabilityLabel: Record<string, string> = {
  immutable: "Immutable",
  upgradeable: "Upgradeable",
  mixed: "Mixed",
  unknown: "Unknown",
};

const rawAbout = metadata?.about?.trim() || "";
const isPlaceholderAbout = /^awaiting\s+defi@home\s+description/i.test(rawAbout);
const curatedAbout = rawAbout && !isPlaceholderAbout ? rawAbout : null;
const aboutFallback = (() => {
  const cat = protocol.category ? protocol.category.toLowerCase() : "protocol";
  const where = primary ? ` on ${primary}` : "";
  return `${protocol.name} is a ${cat} ${protocol.category ? "protocol" : ""}${where}.`.replace(/\s+/g, " ").trim();
})();
const about = curatedAbout ?? aboutFallback;
const aboutUnknown = !curatedAbout;
---
<section class="summary" id="overview">
  <div class="hero">
    <div class="top-strip">
      <div class="top-item tvl">
        <span class="k">TVL</span>
        <span class="v mono tabular">{formatTvl(protocol.tvl)}</span>
      </div>
      <span class="sep" aria-hidden="true">·</span>
      <div class="top-item">
        <span class="k">Type</span>
        <span class="v">{protocol.category || EM_DASH}</span>
      </div>
      <span class="sep" aria-hidden="true">·</span>
      <div class="top-item chains">
        <span class="k">Chain{protocol.chains.length === 1 ? "" : "s"}</span>
        <span class="v">
          {shownChains.length > 0 ? shownChains.join(", ") : EM_DASH}
          {extraChains > 0 && <span class="chip">+{extraChains}</span>}
        </span>
      </div>
    </div>

    <div class="risk-row">
      <div class="pizza" aria-hidden="false">
        <svg viewBox={`0 0 ${PIZZA_VIEW} ${PIZZA_VIEW}`} role="img" aria-label="Risk pizza" preserveAspectRatio="xMidYMid meet">
          {/* IDs are document-global in inline SVG; namespace them with
              idPrefix so a family page rendering ProtocolSummary for each
              child doesn't collide on the second/third/fourth deployment. */}
          <defs>
            <radialGradient id={`${idp}pie-ao`} cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#000000" stop-opacity="0.25" />
              <stop offset="55%" stop-color="#000000" stop-opacity="0.12" />
              <stop offset="100%" stop-color="#000000" stop-opacity="0" />
            </radialGradient>
            <pattern id={`${idp}partial-hatch`} patternUnits="userSpaceOnUse" width="7" height="7" patternTransform="rotate(135)">
              <rect width="7" height="7" fill="rgba(0,0,0,0)" />
              <line x1="0" y1="0" x2="0" y2="7" stroke="rgba(255,255,255,0.3)" stroke-width="3" />
            </pattern>
          </defs>
          {pizzaSlices.map(({ assessment, fillGrade, d }) => (
            <a href={`#${idp}${assessment.id}`} data-pizza-slice={assessment.id} class="pizza-slice">
              <path d={d} fill={GRADE_FILL[fillGrade]} stroke="var(--surface)" stroke-width="6" stroke-linejoin="round">
                <title>{`${assessment.label} — ${assessment.partial ? `tentative ${fillGrade === "gray" ? "unknown" : fillGrade} (${assessment.models?.length ?? 0}/3 models submitted)` : assessment.tentative ? `tentative ${assessment.grade === "gray" ? "unknown" : assessment.grade}` : assessment.grade === "gray" ? "unknown" : assessment.grade}`}</title>
              </path>
            </a>
          ))}
          <circle cx={PIZZA_CENTER} cy={PIZZA_CENTER} r={PIZZA_RADIUS} fill={`url(#${idp}pie-ao)`} style="mix-blend-mode: hard-light" pointer-events="none" />
          {/* Hatch overlay rendered AFTER the radial gradient circle so the
              hard-light blend doesn't crush the white stripes against gray /
              orange slice fills. Pointer-events disabled so the underlying
              <a class="pizza-slice"> still receives hover/click. */}
          {pizzaSlices.filter(({ assessment }) => isUncertain(assessment)).map(({ assessment, d }) => (
            <path d={d} fill={`url(#${idp}partial-hatch)`} stroke="none" pointer-events="none" class="pizza-hatch" data-pizza-hatch={assessment.id} />
          ))}
        </svg>
        {pizzaSlices.map(({ assessment, labelLeftPct, labelTopPct, shortLabel }) => (
          <span class="pizza-label" data-pizza-label={assessment.id} style={`left:${labelLeftPct}%;top:${labelTopPct}%`}>
            {shortLabel}
          </span>
        ))}
      </div>
      <RiskMatrix slices={headerSlices} variant="full" tier={protocolTier} idPrefix={idPrefix} />
    </div>

    <div class="about-row">
      <div class="control">
        <div class="k">Control criteria</div>
        <div class="pills">
          <span class="pill">
            Upgradeability
            {upgradeability ? (
              <span class={`pill-val grade-${upgradeability}`}>{upgradeabilityLabel[upgradeability]}</span>
            ) : (
              <span class="pill-dash">{EM_DASH}</span>
            )}
          </span>
          <span class="pill">
            Bug bounty
            {bugBountyUrl ? (
              <a href={bugBountyUrl} class="pill-link" rel="noreferrer" target="_blank">{bugBountyHost}</a>
            ) : (
              <span class="pill-dash">{EM_DASH}</span>
            )}
          </span>
          <span class="pill">
            Governance forum
            {governanceForum ? (
              <a href={governanceForum} class="pill-link" rel="noreferrer" target="_blank">{governanceHost}</a>
            ) : (
              <span class="pill-dash">{EM_DASH}</span>
            )}
          </span>
          <span class="pill">
            Docs
            {docsUrl ? (
              <a href={docsUrl} class="pill-link" rel="noreferrer" target="_blank">{docsHost}</a>
            ) : (
              <span class="pill-dash">{EM_DASH}</span>
            )}
          </span>
        </div>
      </div>

      <div class="about">
        <div class="k">About</div>
        <p class:list={["body", { muted: aboutUnknown }]}>{about}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .summary { margin-top: 1rem; }
  .hero {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    background: var(--surface);
    border: 1px solid var(--surface-raised);
    border-radius: 4px;
  }

  .top-strip {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.6rem 1rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--surface-raised);
  }
  .top-item { display: inline-flex; align-items: baseline; gap: 0.5rem; min-width: 0; }
  .top-item .k {
    color: var(--text-muted);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .top-item .v {
    color: var(--text);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.2;
  }
  .top-item.tvl .v { font-size: 1.6rem; font-weight: 700; letter-spacing: -0.01em; }
  .top-item.chains .v { word-break: break-word; }
  .sep { color: var(--text-muted); opacity: 0.5; }

  .risk-row {
    display: grid;
    grid-template-columns: minmax(0, 320px) minmax(0, 1fr);
    gap: 1.25rem 1.75rem;
    align-items: center;
  }
  .pizza {
    position: relative;
    width: 100%;
    max-width: 320px;
    aspect-ratio: 1 / 1;
    margin: 0 auto;
  }
  .pizza svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  .pizza-slice { cursor: pointer; }
  .pizza-slice path { transition: opacity 150ms ease, transform 150ms ease; transform-origin: 50% 50%; transform-box: fill-box; }
  .pizza-hatch { transition: opacity 150ms ease; }
  .pizza:has(.pizza-slice:hover) .pizza-slice:not(:hover) path { opacity: 0.3; }
  /* Hatches sit above the radial overlay (so hard-light blending doesn't
     crush them); when a sibling slice is hovered, dim the matching hatch
     too so it stays visually paired with its colored wedge. */
  .pizza:has([data-pizza-slice="control"]:hover) .pizza-hatch:not([data-pizza-hatch="control"]),
  .pizza:has([data-pizza-slice="ability-to-exit"]:hover) .pizza-hatch:not([data-pizza-hatch="ability-to-exit"]),
  .pizza:has([data-pizza-slice="autonomy"]:hover) .pizza-hatch:not([data-pizza-hatch="autonomy"]),
  .pizza:has([data-pizza-slice="open-access"]:hover) .pizza-hatch:not([data-pizza-hatch="open-access"]),
  .pizza:has([data-pizza-slice="verifiability"]:hover) .pizza-hatch:not([data-pizza-hatch="verifiability"]) {
    opacity: 0.3;
  }
  .pizza-label {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 5rem;
    text-align: center;
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--text-muted);
    line-height: 1.2;
    pointer-events: none;
    transition: color 150ms ease;
  }
  .pizza:has([data-pizza-slice="control"]:hover) [data-pizza-label="control"],
  .pizza:has([data-pizza-slice="ability-to-exit"]:hover) [data-pizza-label="ability-to-exit"],
  .pizza:has([data-pizza-slice="autonomy"]:hover) [data-pizza-label="autonomy"],
  .pizza:has([data-pizza-slice="open-access"]:hover) [data-pizza-label="open-access"],
  .pizza:has([data-pizza-slice="verifiability"]:hover) [data-pizza-label="verifiability"] {
    color: var(--text);
  }
  /* Slice hover highlights the matching matrix row */
  .risk-row:has([data-pizza-slice="control"]:hover) :global([data-slice-row="control"]),
  .risk-row:has([data-pizza-slice="ability-to-exit"]:hover) :global([data-slice-row="ability-to-exit"]),
  .risk-row:has([data-pizza-slice="autonomy"]:hover) :global([data-slice-row="autonomy"]),
  .risk-row:has([data-pizza-slice="open-access"]:hover) :global([data-slice-row="open-access"]),
  .risk-row:has([data-pizza-slice="verifiability"]:hover) :global([data-slice-row="verifiability"]) {
    background: color-mix(in oklab, var(--accent-link) 15%, transparent);
    outline: 1px solid color-mix(in oklab, var(--accent-link) 45%, transparent);
  }

  .about-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
    gap: 1.25rem 1.5rem;
    padding-top: 0.5rem;
  }
  .k {
    color: var(--text-muted);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 0.35rem;
  }
  .body {
    margin: 0;
    color: var(--text);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .body.muted { color: var(--text-muted); font-style: italic; }

  .chip {
    margin-left: 0.4rem;
    padding: 0 0.4rem;
    background: var(--surface-raised);
    border-radius: 999px;
    color: var(--text-muted);
    font-size: 0.7rem;
    font-weight: 500;
    vertical-align: middle;
  }

  .pills { display: flex; flex-wrap: wrap; gap: 0.45rem; }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.65rem;
    border: 1px solid var(--surface-raised);
    border-radius: 999px;
    color: var(--text);
    font-size: 0.8rem;
    font-weight: 500;
  }
  .pill-dash { color: var(--text-muted); }
  .pill-val { color: var(--text); font-weight: 600; }
  .pill-val.grade-immutable { color: var(--grade-green); }
  .pill-val.grade-upgradeable { color: var(--grade-orange); }
  .pill-val.grade-mixed { color: var(--grade-orange); }
  .pill-val.grade-unknown { color: var(--text-muted); }
  .pill-link {
    color: var(--accent-link);
    text-decoration: none;
    font-weight: 500;
    max-width: 14ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .pill-link:hover { text-decoration: underline; }

  @media (max-width: 860px) {
    .risk-row { grid-template-columns: 1fr; }
    .pizza { max-width: 260px; }
  }
  @media (max-width: 720px) {
    .hero { padding: 0.75rem; gap: 0.9rem; }
    .about-row { grid-template-columns: 1fr; }
    .top-item.tvl .v { font-size: 1.4rem; }
  }
</style>

<style is:global>
  /* Matrix-row hover dims non-matching pizza slices, mirroring pizza→matrix hover.
     Lives in a global block because [data-slice-row] is rendered by RiskMatrix
     (different scope), and `:global()` inside `:has()` is not reliably scoped. */
  .risk-row:has([data-slice-row="control"]:hover) .pizza-slice:not([data-pizza-slice="control"]) path,
  .risk-row:has([data-slice-row="ability-to-exit"]:hover) .pizza-slice:not([data-pizza-slice="ability-to-exit"]) path,
  .risk-row:has([data-slice-row="autonomy"]:hover) .pizza-slice:not([data-pizza-slice="autonomy"]) path,
  .risk-row:has([data-slice-row="open-access"]:hover) .pizza-slice:not([data-pizza-slice="open-access"]) path,
  .risk-row:has([data-slice-row="verifiability"]:hover) .pizza-slice:not([data-pizza-slice="verifiability"]) path,
  .risk-row:has([data-slice-row="control"]:hover) .pizza-hatch:not([data-pizza-hatch="control"]),
  .risk-row:has([data-slice-row="ability-to-exit"]:hover) .pizza-hatch:not([data-pizza-hatch="ability-to-exit"]),
  .risk-row:has([data-slice-row="autonomy"]:hover) .pizza-hatch:not([data-pizza-hatch="autonomy"]),
  .risk-row:has([data-slice-row="open-access"]:hover) .pizza-hatch:not([data-pizza-hatch="open-access"]),
  .risk-row:has([data-slice-row="verifiability"]:hover) .pizza-hatch:not([data-pizza-hatch="verifiability"]) {
    opacity: 0.3;
  }
  .risk-row:has([data-slice-row="control"]:hover) [data-pizza-label="control"],
  .risk-row:has([data-slice-row="ability-to-exit"]:hover) [data-pizza-label="ability-to-exit"],
  .risk-row:has([data-slice-row="autonomy"]:hover) [data-pizza-label="autonomy"],
  .risk-row:has([data-slice-row="open-access"]:hover) [data-pizza-label="open-access"],
  .risk-row:has([data-slice-row="verifiability"]:hover) [data-pizza-label="verifiability"] {
    color: var(--text);
  }
  /* Direct hover on a matrix row uses the same accent treatment as
     pizza→row hover, so both directions are visually identical. */
  .risk-row [data-slice-row]:hover {
    background: color-mix(in oklab, var(--accent-link) 15%, transparent);
    outline: 1px solid color-mix(in oklab, var(--accent-link) 45%, transparent);
  }
  .risk-row [data-slice-row]:hover .row-link {
    background: transparent;
  }
</style>
