---
import type { Protocol } from "@defipunkd/registry";
import { EM_DASH, formatTvl, primaryChain } from "../lib/format";
import { verifiabilityGrade } from "../lib/verifiability";
import { dependenciesGrade } from "../lib/dependencies";
import { pizzaGradesFor, GRADE_FILL } from "../lib/pizza";
import { assessProtocol, cexAssessment, type SliceAssessment } from "../lib/rationale";

interface Props {
  protocol: Protocol;
}
const { protocol } = Astro.props;

const grades = pizzaGradesFor(
  protocol.category,
  verifiabilityGrade(!!(protocol.github && protocol.github.length > 0), protocol.audit_count ?? 0),
  dependenciesGrade(protocol.category, protocol.forked_from),
);

const headerSlices: SliceAssessment[] = protocol.category === "CEX" ? cexAssessment() : assessProtocol(protocol);
const PZ_VIEW = 360;
const PZ_CENTER = PZ_VIEW / 2;
const PZ_RADIUS = 150;
const headerSlicePaths = headerSlices.map((s, i) => {
  const a = (2 * Math.PI) / headerSlices.length;
  const a0 = -Math.PI / 2 + i * a;
  const a1 = a0 + a;
  const x0 = PZ_CENTER + PZ_RADIUS * Math.cos(a0);
  const y0 = PZ_CENTER + PZ_RADIUS * Math.sin(a0);
  const x1 = PZ_CENTER + PZ_RADIUS * Math.cos(a1);
  const y1 = PZ_CENTER + PZ_RADIUS * Math.sin(a1);
  return {
    assessment: s,
    d: `M${PZ_CENTER},${PZ_CENTER} L${x0},${y0} A${PZ_RADIUS},${PZ_RADIUS} 0 0,1 ${x1},${y1} Z`,
  };
});

const primary = primaryChain(protocol.tvl_by_chain) ?? protocol.chains[0] ?? null;
const extraChains = Math.max(0, protocol.chains.length - 1);

function safeHost(url: string | null): string | null {
  if (!url) return null;
  try {
    return new URL(url).hostname.replace(/^www\./, "");
  } catch {
    return url;
  }
}
const websiteHost = safeHost(protocol.website);

const firstGithub = protocol.github && protocol.github.length > 0 ? protocol.github[0]! : null;
const githubShort = firstGithub ? firstGithub.replace(/^https?:\/\/(www\.)?github\.com\//, "") : null;

const about = (() => {
  const cat = protocol.category ? protocol.category.toLowerCase() : "protocol";
  const where = primary
    ? ` on ${primary}${extraChains > 0 ? ` and ${extraChains} other chain${extraChains === 1 ? "" : "s"}` : ""}`
    : "";
  return `${protocol.name} is a ${cat} ${protocol.category ? "protocol" : ""}${where}.`.replace(/\s+/g, " ").trim();
})();
---
<section class="summary">
  <div class="grid">
    <div class="cell">
      <div class="k">Total value locked</div>
      <div class="v mono tabular">{formatTvl(protocol.tvl)}</div>
    </div>

    <div class="cell">
      <div class="k">Stage</div>
      <div class="v muted">{EM_DASH}</div>
      <a href="#stage" class="sub">not yet assessed</a>
    </div>

    <div class="cell">
      <div class="k">Chain{protocol.chains.length === 1 ? "" : "s"}</div>
      <div class="v">
        {primary ?? EM_DASH}
        {extraChains > 0 && <span class="chip">+{extraChains}</span>}
      </div>
    </div>

    <div class="cell pizza-cell">
      <div class="hdr-rosette-wrap">
        <div class="hdr-rosette">
          <svg viewBox={`0 0 ${PZ_VIEW} ${PZ_VIEW}`} role="img" aria-label="Risk pizza" preserveAspectRatio="xMidYMid meet">
            {headerSlicePaths.map(({ assessment, d }) => (
              <a href={`#${assessment.id}`} data-hdr-slice={assessment.id} class="hdr-slice">
                <path d={d} fill={GRADE_FILL[assessment.grade]} stroke="var(--surface)" stroke-width="2">
                  <title>{`${assessment.label} \u2014 ${assessment.grade === "gray" ? "unknown" : assessment.grade}`}</title>
                </path>
              </a>
            ))}
          </svg>
        </div>
        <div class="hdr-tip-slot">
          <div class="hdr-tip-default">
            <span>Hover a slice</span>
          </div>
          {headerSlices.map((s) => (
            <div class:list={["hdr-tip", `grade-${s.grade}`]} data-hdr-tip={s.id}>
              <div class="hdr-tip-label">{s.label}</div>
              <div class="hdr-tip-headline">{s.headline}</div>
              <p class="hdr-tip-rationale">{s.rationale}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="cell">
      <div class="k">Type</div>
      <div class="v">{protocol.category || EM_DASH}</div>
    </div>

    <div class="cell">
      <div class="k">Website</div>
      <div class="v">
        {protocol.website ? (
          <a href={protocol.website} class="link" rel="noreferrer" target="_blank">{websiteHost ?? protocol.website}</a>
        ) : (
          <span class="muted">{EM_DASH}</span>
        )}
      </div>
    </div>

    <div class="cell">
      <div class="k">GitHub</div>
      <div class="v">
        {firstGithub ? (
          <a href={firstGithub} class="link" rel="noreferrer" target="_blank">{githubShort}</a>
        ) : (
          <span class="muted">{EM_DASH}</span>
        )}
      </div>
    </div>

    <div class="cell wide control">
      <div class="k">Control criteria</div>
      <div class="pills">
        <span class="pill">Immutable<span class="pill-dash">{EM_DASH}</span></span>
        <span class="pill">Pausable<span class="pill-dash">{EM_DASH}</span></span>
        <span class="pill">Upgradeable<span class="pill-dash">{EM_DASH}</span></span>
      </div>
    </div>

    <div class="cell wide about">
      <div class="k">About</div>
      <div class="v body">{about}</div>
    </div>
  </div>
</section>

<style>
  .summary { margin-top: 1rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.25rem 1.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--surface);
    border: 1px solid var(--surface-raised);
    border-radius: 4px;
    align-items: start;
  }
  .cell { min-width: 0; }
  .pizza-cell {
    grid-column: 4;
    grid-row: 1 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hdr-rosette-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
  }
  .hdr-rosette {
    position: relative;
    width: 100%;
    max-width: 140px;
    aspect-ratio: 1 / 1;
  }
  .hdr-rosette svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  .hdr-slice { cursor: pointer; }
  .hdr-slice path { transition: opacity 150ms ease; }
  .hdr-rosette:has(.hdr-slice:hover) .hdr-slice:not(:hover) path { opacity: 0.25; }

  .hdr-tip-slot {
    display: grid;
    width: 100%;
    min-height: 3.5rem;
  }
  .hdr-tip,
  .hdr-tip-default {
    grid-area: 1 / 1;
    font-size: 0.72rem;
    line-height: 1.4;
    color: var(--text-muted);
    text-align: center;
    transition: opacity 150ms ease;
  }
  .hdr-tip { opacity: 0; pointer-events: none; }
  .hdr-tip-default {
    font-style: italic;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hdr-rosette-wrap:has(.hdr-slice:hover) .hdr-tip-default { opacity: 0; }
  .hdr-tip-label {
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--text-muted);
  }
  .hdr-tip.grade-green .hdr-tip-label { color: var(--grade-green); }
  .hdr-tip.grade-orange .hdr-tip-label { color: var(--grade-orange); }
  .hdr-tip.grade-red .hdr-tip-label { color: var(--grade-red); }
  .hdr-tip-headline { color: var(--text); font-size: 0.78rem; font-weight: 600; margin: 0.1rem 0; }
  .hdr-tip-rationale { color: var(--text-muted); font-size: 0.7rem; margin: 0; line-height: 1.4; }

  .hdr-rosette-wrap:has([data-hdr-slice="control"]:hover) [data-hdr-tip="control"] { opacity: 1; }
  .hdr-rosette-wrap:has([data-hdr-slice="ability-to-exit"]:hover) [data-hdr-tip="ability-to-exit"] { opacity: 1; }
  .hdr-rosette-wrap:has([data-hdr-slice="dependencies"]:hover) [data-hdr-tip="dependencies"] { opacity: 1; }
  .hdr-rosette-wrap:has([data-hdr-slice="access"]:hover) [data-hdr-tip="access"] { opacity: 1; }
  .hdr-rosette-wrap:has([data-hdr-slice="verifiability"]:hover) [data-hdr-tip="verifiability"] { opacity: 1; }
  .wide.control {
    grid-column: 1 / 3;
    grid-row: 3;
    padding-top: 1rem;
    border-top: 1px solid var(--surface-raised);
  }
  .wide.about {
    grid-column: 3 / 5;
    grid-row: 3;
    padding-top: 1rem;
    border-top: 1px solid var(--surface-raised);
  }

  .k {
    color: var(--text-muted);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.3rem;
  }
  .v {
    color: var(--text);
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.3;
    word-break: break-word;
    overflow-wrap: anywhere;
  }
  .v.body { font-size: 0.88rem; font-weight: 400; color: var(--text-muted); line-height: 1.5; }
  .muted { color: var(--text-muted); }
  .sub {
    display: inline-block;
    margin-top: 0.2rem;
    font-size: 0.72rem;
    color: var(--accent-link);
    text-decoration: none;
    letter-spacing: 0.02em;
  }
  .sub:hover { text-decoration: underline; }
  .link { color: var(--accent-link); font-size: 0.95rem; font-weight: 500; }
  .chip {
    margin-left: 0.4rem;
    padding: 0 0.4rem;
    background: var(--surface-raised);
    border-radius: 999px;
    color: var(--text-muted);
    font-size: 0.7rem;
    font-weight: 500;
    vertical-align: middle;
  }

  .pills { display: flex; flex-wrap: wrap; gap: 0.45rem; }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.65rem;
    border: 1px solid var(--surface-raised);
    border-radius: 999px;
    color: var(--text);
    font-size: 0.8rem;
    font-weight: 500;
  }
  .pill-dash { color: var(--text-muted); }

  @media (max-width: 720px) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem 1.25rem;
      padding: 1rem;
    }
    .pizza-cell { grid-column: 1 / -1; grid-row: auto; }
    .wide.control, .wide.about {
      grid-column: 1 / -1;
      grid-row: auto;
      padding-top: 1rem;
    }
  }
</style>
