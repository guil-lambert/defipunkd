---
import type { Protocol, ProvenanceTag, LoadedAssessment, AssessmentSliceId } from "@defipunkd/registry";
import { getProtocolMetadata } from "@defipunkd/registry";
import { auditorDomain, EM_DASH, formatUtc, parseHallmarks } from "../lib/format";
import ProtocolLogo from "./ProtocolLogo.astro";
import ChildrenTable from "./ChildrenTable.astro";
import RiskAnalysis from "./RiskAnalysis.astro";
import StagePreview from "./StagePreview.astro";
import ProtocolSummary from "./ProtocolSummary.astro";
import ProvTag from "./ProvTag.astro";

interface Props {
  protocol: Protocol;
  snapshotGeneratedAt: string;
  children: Protocol[];
  assessments?: Map<AssessmentSliceId, LoadedAssessment>;
}
const { protocol, snapshotGeneratedAt, children, assessments } = Astro.props;
const hasFamily = children.length > 0;
const prov = protocol._provenance;
const hallmarks = parseHallmarks(protocol.hallmarks);
const auditsProv: ProvenanceTag | null = prov.audit_links ?? prov.audit_count ?? null;

const metadata = getProtocolMetadata(protocol.slug);
// Prefer quorum-refreshed metadata over DeFiLlama when the registry field
// is still unset via curation. Curated overlays still win — don't overwrite
// a human edit with an LLM refresh.
const useMetaGithub = metadata?.github && metadata.github.length > 0 && prov.github !== "curated";
const githubUrls = useMetaGithub ? metadata!.github! : (protocol.github ?? []);
const githubProvTag = useMetaGithub ? "defi@home" : (prov.github ?? null);

const useMetaAudits = metadata?.audits && metadata.audits.length > 0 && prov.audit_links !== "curated";
const auditsProvTag = useMetaAudits ? "defi@home" : auditsProv;

const upgradeabilityLabel: Record<string, string> = {
  immutable: "Immutable",
  upgradeable: "Upgradeable",
  mixed: "Mixed (some immutable, some upgradeable)",
  unknown: "Unknown",
};

// "Updated" row reflects whichever is more recent: the DeFiLlama snapshot
// or the latest quorum-merged assessment for this protocol.
let latestQuorumAt: string | null = null;
if (assessments) {
  for (const a of assessments.values()) {
    if (a.merged_at && (!latestQuorumAt || a.merged_at > latestQuorumAt)) {
      latestQuorumAt = a.merged_at;
    }
  }
}
const updatedAt = latestQuorumAt && latestQuorumAt > snapshotGeneratedAt
  ? latestQuorumAt
  : snapshotGeneratedAt;
const updatedSource: "defi@home" | "defillama" = updatedAt === latestQuorumAt ? "defi@home" : "defillama";

---
<script>
  const nav = document.querySelector<HTMLElement>(".side-nav");
  if (nav) {
    const links = Array.from(nav.querySelectorAll<HTMLAnchorElement>("a[href^='#']"));
    const entries = links
      .map((a) => {
        const id = a.getAttribute("href")!.slice(1);
        const target = document.getElementById(id);
        return target ? { a, target } : null;
      })
      .filter((x): x is { a: HTMLAnchorElement; target: HTMLElement } => x !== null);

    // #top is the page's main element; treat it as the "before any section" state,
    // not as a section to scroll-spy on.
    const topLink = entries.find((e) => e.target.id === "top")?.a ?? null;
    const sections = entries.filter((e) => e.target.id !== "top");

    const setActive = () => {
      const line = window.innerHeight * 0.25;
      let chosen: HTMLAnchorElement | null = null;
      for (const { a, target } of sections) {
        if (target.getBoundingClientRect().top <= line) chosen = a;
      }
      if (!chosen) chosen = topLink;
      for (const { a } of entries) a.classList.toggle("active", a === chosen);
    };

    let queued = false;
    const onScroll = () => {
      if (queued) return;
      queued = true;
      requestAnimationFrame(() => { queued = false; setActive(); });
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
    setActive();
  }
</script>
<aside class="side-nav" aria-label="Page sections">
  <a href="/" class="brand" aria-label="DeFiPunkd — back to index">
    <svg class="brand-logo" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M3 3h4v2h-2v6h2v2h-4zM13 3h-4v2h2v6h-2v2h4zM7 6h2v2h-2zM7 9h2v2h-2z" fill="currentColor"/>
    </svg>
    <span class="brand-word">DeFiPunk<span class="brand-mark">d</span></span>
  </a>
  <div class="nav-links">
    <a href="#top">Top</a>
    <a href="#summary">Summary</a>
    <a href="#risk-analysis">Risk analysis</a>
    <a href="#stage">Stage</a>
    {hasFamily && <a href="#family">Family members</a>}
  </div>
</aside>
<main class="detail" id="top">
  <header class="head">
    <div class="title">
      <ProtocolLogo src={protocol.logo} name={protocol.name} size={40} />
      <div>
        <h1>{protocol.name}</h1>
        <p class="subtitle">
          {protocol.category || EM_DASH}
          {protocol.parent_slug && (
            <>
              {" · child of "}
              <a href={`/protocol/${protocol.parent_slug}`} class="link">{protocol.parent_slug}</a>
            </>
          )}
        </p>
      </div>
    </div>
  </header>

  <ProtocolSummary protocol={protocol} assessments={assessments} />

  <section id="summary" class="summary-section">
    <h2>Summary</h2>

    <dl class="fields two-col">
      <div class="field">
        <dt>Website</dt>
        <dd>{protocol.website ? <a href={protocol.website} class="link" rel="noreferrer" target="_blank">{protocol.website}</a> : <span class="muted">unknown</span>}</dd>
        <dd class="prov">{protocol.website && prov.website ? (<ProvTag tag={prov.website} slug={protocol.slug} />) : (<span class="muted">{EM_DASH}</span>)}</dd>
      </div>

      <div class="field">
        <dt>Twitter</dt>
        <dd>{protocol.twitter ? <a href={`https://twitter.com/${protocol.twitter}`} class="link" rel="noreferrer" target="_blank">@{protocol.twitter}</a> : <span class="muted">unknown</span>}</dd>
        <dd class="prov">{protocol.twitter && prov.twitter ? (<ProvTag tag={prov.twitter} slug={protocol.slug} />) : (<span class="muted">{EM_DASH}</span>)}</dd>
      </div>

      <div class="field">
        <dt>GitHub</dt>
        <dd>
          {githubUrls.length > 0 ? (
            <ul class="bare">
              {githubUrls.map((g) => (<li><a href={g} class="link" rel="noreferrer" target="_blank">{g}</a></li>))}
            </ul>
          ) : (<span class="muted">unknown</span>)}
        </dd>
        <dd class="prov">{githubUrls.length > 0 && githubProvTag ? (<ProvTag tag={githubProvTag} slug={protocol.slug} />) : (<span class="muted">{EM_DASH}</span>)}</dd>
      </div>

      <div class="field">
        <dt>Audits</dt>
        <dd>
          {useMetaAudits ? (
            <details>
              <summary class="clickable">{metadata!.audits!.length} audit{metadata!.audits!.length === 1 ? "" : "s"}</summary>
              <ul class="bare audits">
                {metadata!.audits!.map((a) => (
                  <li>
                    <a href={a.url} class="link" rel="noreferrer" target="_blank">{a.firm}</a>
                    {a.date && <span class="muted"> {EM_DASH} {a.date}</span>}
                  </li>
                ))}
              </ul>
            </details>
          ) : protocol.audit_count === 0 && protocol.audit_links.length === 0 ? (
            <span class="muted">unknown</span>
          ) : (
            <details>
              <summary class="clickable">{protocol.audit_count} audit{protocol.audit_count === 1 ? "" : "s"}</summary>
              <ul class="bare audits">
                {protocol.audit_links.map((l) => (
                  <li><a href={l} class="link" rel="noreferrer" target="_blank">{auditorDomain(l) ?? l}</a></li>
                ))}
              </ul>
            </details>
          )}
        </dd>
        <dd class="prov">{auditsProvTag ? (<ProvTag tag={auditsProvTag} slug={protocol.slug} />) : (<span class="muted">{EM_DASH}</span>)}</dd>
      </div>

      <div class="field">
        <dt>Docs</dt>
        <dd>{metadata?.docs_url ? <a href={metadata.docs_url} class="link" rel="noreferrer" target="_blank">{metadata.docs_url}</a> : <span class="muted">unknown</span>}</dd>
        <dd class="prov">{metadata?.docs_url ? (<ProvTag tag="defi@home" />) : (<span class="muted">{EM_DASH}</span>)}</dd>
      </div>

      <div class="field">
        <dt>Governance forum</dt>
        <dd>{metadata?.governance_forum ? <a href={metadata.governance_forum} class="link" rel="noreferrer" target="_blank">{metadata.governance_forum}</a> : <span class="muted">unknown</span>}</dd>
        <dd class="prov">{metadata?.governance_forum ? (<ProvTag tag="defi@home" />) : (<span class="muted">{EM_DASH}</span>)}</dd>
      </div>

      <div class="field">
        <dt>Voting token</dt>
        <dd>
          {metadata?.voting_token ? (
            <>
              {metadata.voting_token.symbol && <span class="mono">{metadata.voting_token.symbol} </span>}
              <span class="mono muted">{metadata.voting_token.chain}:</span>
              <span class="mono">{metadata.voting_token.address}</span>
            </>
          ) : <span class="muted">unknown</span>}
        </dd>
        <dd class="prov">{metadata?.voting_token ? (<ProvTag tag="defi@home" />) : (<span class="muted">{EM_DASH}</span>)}</dd>
      </div>

      <div class="field">
        <dt>Bug bounty</dt>
        <dd>{metadata?.bug_bounty_url ? <a href={metadata.bug_bounty_url} class="link" rel="noreferrer" target="_blank">{metadata.bug_bounty_url}</a> : <span class="muted">unknown</span>}</dd>
        <dd class="prov">{metadata?.bug_bounty_url ? (<ProvTag tag="defi@home" />) : (<span class="muted">{EM_DASH}</span>)}</dd>
      </div>

      <div class="field">
        <dt>Security contact</dt>
        <dd>{metadata?.security_contact ? <span class="mono">{metadata.security_contact}</span> : <span class="muted">unknown</span>}</dd>
        <dd class="prov">{metadata?.security_contact ? (<ProvTag tag="defi@home" />) : (<span class="muted">{EM_DASH}</span>)}</dd>
      </div>

      <div class="field">
        <dt>Deployed contracts</dt>
        <dd>{metadata?.deployed_contracts_doc ? <a href={metadata.deployed_contracts_doc} class="link" rel="noreferrer" target="_blank">{metadata.deployed_contracts_doc}</a> : <span class="muted">unknown</span>}</dd>
        <dd class="prov">{metadata?.deployed_contracts_doc ? (<ProvTag tag="defi@home" />) : (<span class="muted">{EM_DASH}</span>)}</dd>
      </div>

      <div class="field">
        <dt>Upgradeability</dt>
        <dd>{metadata?.upgradeability ? upgradeabilityLabel[metadata.upgradeability] : <span class="muted">unknown</span>}</dd>
        <dd class="prov">{metadata?.upgradeability ? (<ProvTag tag="defi@home" />) : (<span class="muted">{EM_DASH}</span>)}</dd>
      </div>

      <div class="field">
        <dt>Review status</dt>
        <dd><span class="muted">listed</span></dd>
        <dd class="prov"><ProvTag tag="defillama" slug={protocol.slug} /></dd>
      </div>

      <div class="field wide">
        <dt>Hallmarks</dt>
        <dd>
          {hallmarks.length === 0 ? (<span class="muted">unknown</span>) : (
            <ul class="bare">
              {hallmarks.map((h) => (
                <li class="hallmark">
                  <span class="muted ts">{formatUtc(new Date(h.unixTs * 1000).toISOString())}</span>
                  {h.description}
                </li>
              ))}
            </ul>
          )}
        </dd>
        <dd class="prov">{hallmarks.length > 0 && prov.hallmarks ? (<ProvTag tag={prov.hallmarks} slug={protocol.slug} />) : (<span class="muted">{EM_DASH}</span>)}</dd>
      </div>

      <div class="field">
        <dt>Updated</dt>
        <dd>{formatUtc(updatedAt)}</dd>
        <dd class="prov"><ProvTag tag={updatedSource} slug={protocol.slug} /></dd>
      </div>
    </dl>
  </section>

  <RiskAnalysis protocol={protocol} snapshotGeneratedAt={snapshotGeneratedAt} assessments={assessments} />

  <StagePreview protocol={protocol} />

  <ChildrenTable children={children} />
</main>

<style>
  .detail { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; color: var(--text); scroll-margin-top: 1rem; }
  .summary-section {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 2px solid var(--brand-oxblood);
  }
  .summary-section > h2 { margin: 0 0 0.5rem 0; color: var(--text); font-size: 1.25rem; scroll-margin-top: 1rem; }
  .side-nav {
    position: fixed;
    top: 5rem;
    left: max(1rem, calc(50% - 550px - 1in - 140px));
    width: 140px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.75rem 0.9rem;
    background: var(--surface);
    border: 1px solid var(--surface-raised);
    border-radius: 4px;
    z-index: 10;
  }
  .nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 0.75rem;
    margin-top: 0.25rem;
    border-top: 1px solid var(--surface-raised);
  }
  .nav-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    padding: 0.1rem 0 0.1rem 0.55rem;
    margin-left: -0.55rem;
    box-shadow: inset 2px 0 0 0 transparent;
    transition: color 120ms ease-out, box-shadow 120ms ease-out;
  }
  .nav-links a:hover { color: var(--text); }
  .nav-links a.active {
    color: var(--text);
    box-shadow: inset 2px 0 0 0 var(--brand-oxblood);
  }
  @media (max-width: 1280px) { .side-nav { display: none; } }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .brand:hover { color: var(--text); }
  .brand-logo {
    width: 1em;
    height: 1em;
    flex-shrink: 0;
    color: var(--brand-oxblood);
  }
  .brand-mark { color: var(--brand-oxblood); }
  .head { display: flex; gap: 1.5rem; align-items: flex-start; }
  .title { display: flex; gap: 0.75rem; align-items: center; }
  h1 { margin: 0; color: var(--text); font-size: 1.75rem; }
  .subtitle { color: var(--text-muted); margin: 0.25rem 0 0 0; }
  .fields.two-col {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0 1.75rem;
    margin: 0.25rem 0 0 0;
    padding: 0;
    font-size: 0.95rem;
  }
  @media (max-width: 720px) {
    .fields.two-col { grid-template-columns: 1fr; }
  }
  .field {
    display: grid;
    grid-template-columns: minmax(10rem, 14rem) minmax(0, 1fr) max-content;
    gap: 0 1rem;
    align-items: baseline;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--surface-raised);
  }
  .field.wide { grid-column: 1 / -1; }
  .field dt {
    color: var(--text-muted);
    font-weight: 500;
    margin: 0;
  }
  .field dd {
    color: var(--text);
    margin: 0;
    min-width: 0;
    word-break: break-word;
    overflow-wrap: anywhere;
  }
  .field dd.prov { text-align: right; }
  .muted { color: var(--text-muted); }
  .link { color: var(--accent-link); }
  .bare { margin: 0; padding: 0; list-style: none; }
  .audits { padding-top: 0.5rem; }
  .audits li { padding: 0.15rem 0; }
  .hallmark { padding: 0.2rem 0; color: var(--text); }
  .ts { margin-right: 8px; }
  .clickable { cursor: pointer; }
</style>
