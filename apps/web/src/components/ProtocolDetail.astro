---
import type { Protocol, ProvenanceTag, LoadedAssessment, AssessmentSliceId } from "@defipunkd/registry";
import { getProtocolMetadata } from "@defipunkd/registry";
import { auditorDomain, EM_DASH, formatUtc, parseHallmarks } from "../lib/format";
import ProtocolLogo from "./ProtocolLogo.astro";
import SideNav from "./SideNav.astro";
import ChildrenTable from "./ChildrenTable.astro";
import RiskAnalysis from "./RiskAnalysis.astro";
import StagePreview from "./StagePreview.astro";
import ProtocolSummary from "./ProtocolSummary.astro";
import ProvTag from "./ProvTag.astro";
import HallmarksTimeline from "./HallmarksTimeline.astro";

interface Props {
  protocol: Protocol;
  snapshotGeneratedAt: string;
  children: Protocol[];
  assessments?: Map<AssessmentSliceId, LoadedAssessment>;
}
const { protocol, snapshotGeneratedAt, children, assessments } = Astro.props;
const hasFamily = children.length > 0;
const hasHallmarks = parseHallmarks(protocol.hallmarks).length > 0;
const prov = protocol._provenance;
const hallmarks = parseHallmarks(protocol.hallmarks);
const auditsProv: ProvenanceTag | null = prov.audit_links ?? prov.audit_count ?? null;

const metadata = getProtocolMetadata(protocol.slug);
const useMetaGithub = metadata?.github && metadata.github.length > 0 && prov.github !== "curated";
const githubUrls = useMetaGithub ? metadata!.github! : (protocol.github ?? []);
const githubProvTag = useMetaGithub ? "defi@home" : (prov.github ?? null);

const useMetaAudits = metadata?.audits && metadata.audits.length > 0 && prov.audit_links !== "curated";
const auditsProvTag = useMetaAudits ? "defi@home" : auditsProv;

const upgradeabilityLabel: Record<string, string> = {
  immutable: "Immutable",
  upgradeable: "Upgradeable",
  mixed: "Mixed (some immutable, some upgradeable)",
  unknown: "Unknown",
};

let latestQuorumAt: string | null = null;
if (assessments) {
  for (const a of assessments.values()) {
    if (a.merged_at && (!latestQuorumAt || a.merged_at > latestQuorumAt)) {
      latestQuorumAt = a.merged_at;
    }
  }
}
const updatedAt = latestQuorumAt && latestQuorumAt > snapshotGeneratedAt
  ? latestQuorumAt
  : snapshotGeneratedAt;
const updatedSource: "defi@home" | "defillama" = updatedAt === latestQuorumAt ? "defi@home" : "defillama";

const twitterProv = prov.twitter ?? null;
const websiteProv = prov.website ?? null;

const linksSources = Array.from(new Set([
  protocol.website && websiteProv ? websiteProv : null,
  protocol.twitter && twitterProv ? twitterProv : null,
  githubUrls.length > 0 ? githubProvTag : null,
  metadata?.docs_url ? "defi@home" : null,
  metadata?.governance_forum ? "defi@home" : null,
].filter((x): x is string => !!x)));

const securitySources = Array.from(new Set([
  auditsProvTag ?? null,
  metadata?.bug_bounty_url ? "defi@home" : null,
  metadata?.security_contact ? "defi@home" : null,
].filter((x): x is string => !!x)));

const technicalSources = Array.from(new Set([
  metadata?.voting_token ? "defi@home" : null,
  metadata?.deployed_contracts_doc ? "defi@home" : null,
  metadata?.upgradeability ? "defi@home" : null,
].filter((x): x is string => !!x)));

const provenanceSources = Array.from(new Set([
  "defillama",
  updatedSource,
].filter((x): x is string => !!x)));

const navLinks = [
  { href: "#overview", label: "Overview" },
  ...(hasHallmarks ? [{ href: "#hallmarks", label: "Hallmarks" }] : []),
  { href: "#risk-analysis", label: "Risk analysis" },
  { href: "#reference", label: "Reference" },
  ...(hasFamily ? [{ href: "#family", label: "Family members" }] : []),
];
---
<SideNav links={navLinks} contentMaxWidth={1100} />
<main class="detail" id="top">
  <a href="/" class="back-home" aria-label="Back to DeFiPunkd">
    <span class="back-arrow" aria-hidden="true">←</span>
    <svg class="back-logo" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M3 3h4v2h-2v6h2v2h-4zM13 3h-4v2h2v6h-2v2h4zM7 6h2v2h-2zM7 9h2v2h-2z" fill="currentColor"/>
    </svg>
    <span class="back-word">DeFiPunk<span class="back-mark">d</span></span>
  </a>
  <header class="head">
    <div class="title">
      <ProtocolLogo src={protocol.logo} name={protocol.name} size={40} />
      <div>
        <h1>{protocol.name}</h1>
        <p class="subtitle">
          {protocol.category || EM_DASH}
          {protocol.parent_slug && (
            <>
              {" · child of "}
              <a href={`/protocol/${protocol.parent_slug}`} class="link">{protocol.parent_slug}</a>
            </>
          )}
        </p>
      </div>
    </div>
  </header>

  <ProtocolSummary protocol={protocol} assessments={assessments} />

  <HallmarksTimeline hallmarks={hallmarks} />

  <RiskAnalysis protocol={protocol} snapshotGeneratedAt={snapshotGeneratedAt} assessments={assessments} />

  <section id="reference" class="reference-section">
    <h2>Reference</h2>

    {/* LINKS */}
    <div class="group">
      <div class="group-head">
        <h3>Links</h3>
        {linksSources.length > 0 && (
          <div class="group-sources">
            {linksSources.map((t) => (<ProvTag tag={t} slug={protocol.slug} />))}
          </div>
        )}
      </div>
      <dl class="fields two-col">
        {protocol.website && (
          <div class="field">
            <dt>Website</dt>
            <dd><a href={protocol.website} class="link" rel="noreferrer" target="_blank">{protocol.website}</a></dd>
          </div>
        )}
        {protocol.twitter && (
          <div class="field">
            <dt>Twitter</dt>
            <dd><a href={`https://twitter.com/${protocol.twitter}`} class="link" rel="noreferrer" target="_blank">@{protocol.twitter}</a></dd>
          </div>
        )}
        {githubUrls.length > 0 && (
          <div class="field">
            <dt>GitHub</dt>
            <dd>
              {githubUrls.length === 1 ? (
                <a href={githubUrls[0]} class="link" rel="noreferrer" target="_blank">{githubUrls[0]}</a>
              ) : (
                <details>
                  <summary class="clickable">{githubUrls.length} repositories</summary>
                  <ul class="bare">
                    {githubUrls.map((g) => (<li><a href={g} class="link" rel="noreferrer" target="_blank">{g}</a></li>))}
                  </ul>
                </details>
              )}
            </dd>
          </div>
        )}
        {metadata?.docs_url && (
          <div class="field">
            <dt>Docs</dt>
            <dd><a href={metadata.docs_url} class="link" rel="noreferrer" target="_blank">{metadata.docs_url}</a></dd>
          </div>
        )}
        {metadata?.governance_forum && (
          <div class="field">
            <dt>Governance forum</dt>
            <dd><a href={metadata.governance_forum} class="link" rel="noreferrer" target="_blank">{metadata.governance_forum}</a></dd>
          </div>
        )}
      </dl>
    </div>

    {/* SECURITY — always show these rows (absence is signal) */}
    <div class="group">
      <div class="group-head">
        <h3>Security</h3>
        {securitySources.length > 0 && (
          <div class="group-sources">
            {securitySources.map((t) => (<ProvTag tag={t} slug={protocol.slug} />))}
          </div>
        )}
      </div>
      <dl class="fields two-col">
        <div class="field">
          <dt>Audits</dt>
          <dd>
            {useMetaAudits ? (
              <details>
                <summary class="clickable">{metadata!.audits!.length} audit{metadata!.audits!.length === 1 ? "" : "s"}</summary>
                <ul class="bare audits">
                  {metadata!.audits!.map((a) => (
                    <li>
                      <a href={a.url} class="link" rel="noreferrer" target="_blank">{a.firm}</a>
                      {a.date && <span class="muted"> {EM_DASH} {a.date}</span>}
                    </li>
                  ))}
                </ul>
              </details>
            ) : protocol.audit_count === 0 && protocol.audit_links.length === 0 ? (
              <span class="muted">unknown</span>
            ) : (
              <details>
                <summary class="clickable">{protocol.audit_count} audit{protocol.audit_count === 1 ? "" : "s"}</summary>
                <ul class="bare audits">
                  {protocol.audit_links.map((l) => (
                    <li><a href={l} class="link" rel="noreferrer" target="_blank">{auditorDomain(l) ?? l}</a></li>
                  ))}
                </ul>
              </details>
            )}
          </dd>
        </div>
        <div class="field">
          <dt>Bug bounty</dt>
          <dd>{metadata?.bug_bounty_url ? <a href={metadata.bug_bounty_url} class="link" rel="noreferrer" target="_blank">{metadata.bug_bounty_url}</a> : <span class="muted">unknown</span>}</dd>
        </div>
        <div class="field">
          <dt>Security contact</dt>
          <dd>{metadata?.security_contact ? <span class="mono">{metadata.security_contact}</span> : <span class="muted">unknown</span>}</dd>
        </div>
      </dl>
    </div>

    {/* TECHNICAL */}
    {(metadata?.voting_token || metadata?.deployed_contracts_doc || metadata?.upgradeability) && (
      <div class="group">
        <div class="group-head">
          <h3>Technical</h3>
          {technicalSources.length > 0 && (
            <div class="group-sources">
              {technicalSources.map((t) => (<ProvTag tag={t} slug={protocol.slug} />))}
            </div>
          )}
        </div>
        <dl class="fields two-col">
          {metadata?.voting_token && (
            <div class="field">
              <dt>Voting token</dt>
              <dd>
                {metadata.voting_token.symbol && <span class="mono">{metadata.voting_token.symbol} </span>}
                <span class="mono muted">{metadata.voting_token.chain}:</span>
                <span class="mono">{metadata.voting_token.address}</span>
              </dd>
            </div>
          )}
          {metadata?.deployed_contracts_doc && (
            <div class="field">
              <dt>Deployed contracts</dt>
              <dd><a href={metadata.deployed_contracts_doc} class="link" rel="noreferrer" target="_blank">{metadata.deployed_contracts_doc}</a></dd>
            </div>
          )}
          {metadata?.upgradeability && (
            <div class="field">
              <dt>Upgradeability</dt>
              <dd>{upgradeabilityLabel[metadata.upgradeability]}</dd>
            </div>
          )}
        </dl>
      </div>
    )}

    {/* PROVENANCE */}
    <div class="group">
      <div class="group-head">
        <h3>Provenance</h3>
        {provenanceSources.length > 0 && (
          <div class="group-sources">
            {provenanceSources.map((t) => (<ProvTag tag={t} slug={protocol.slug} />))}
          </div>
        )}
      </div>
      <dl class="fields two-col">
        <div class="field">
          <dt>Review status</dt>
          <dd><span class="muted">listed</span></dd>
        </div>
        <div class="field">
          <dt>Updated</dt>
          <dd>{formatUtc(updatedAt)}</dd>
        </div>
      </dl>
    </div>
  </section>

  <StagePreview protocol={protocol} />

  <ChildrenTable children={children} />
</main>

<style>
  .detail { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; color: var(--text); scroll-margin-top: 1rem; }
  .reference-section {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 2px solid var(--brand-oxblood);
  }
  .reference-section > h2 { margin: 0 0 1rem 0; color: var(--text); font-size: 2.25rem; scroll-margin-top: 1rem; }
  .group + .group { margin-top: 1.5rem; }
  .group-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.35rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--surface-raised);
  }
  .group-head h3 {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--text-muted);
  }
  .group-sources {
    display: inline-flex;
    gap: 0.35rem;
    align-items: baseline;
    opacity: 0.55;
    transition: opacity 120ms ease;
  }
  .group:hover .group-sources { opacity: 1; }

  .back-home {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 0.9rem;
    color: var(--text);
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.015em;
    text-decoration: none;
  }
  .back-arrow { color: var(--text-muted); font-weight: 500; }
  .back-logo { width: 1em; height: 1em; flex-shrink: 0; color: var(--brand-oxblood); }
  .back-word { color: var(--text); }
  .back-mark { color: var(--brand-oxblood); }
  .back-home:hover .back-arrow { color: var(--text); }
  @media (min-width: 1501px) {
    /* Side nav already exposes a home link at this width */
    .back-home { display: none; }
  }
  .head { display: flex; gap: 1.5rem; align-items: flex-start; }
  .title { display: flex; gap: 0.75rem; align-items: center; }
  h1 { margin: 0; color: var(--text); font-size: 1.75rem; }
  .subtitle { color: var(--text-muted); margin: 0.25rem 0 0 0; }

  .fields.two-col {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0 1.75rem;
    margin: 0;
    padding: 0;
    font-size: 0.95rem;
  }
  .field {
    display: grid;
    grid-template-columns: minmax(9rem, 12rem) minmax(0, 1fr);
    gap: 0 1rem;
    align-items: baseline;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--surface-raised);
  }
  .field dt { color: var(--text-muted); font-weight: 500; margin: 0; }
  .field dd {
    color: var(--text);
    margin: 0;
    min-width: 0;
    word-break: break-word;
    overflow-wrap: anywhere;
  }
  .muted { color: var(--text-muted); }
  .link { color: var(--accent-link); }
  .bare { margin: 0; padding: 0; list-style: none; }
  .audits { padding-top: 0.5rem; }
  .audits li { padding: 0.15rem 0; }
  .clickable { cursor: pointer; }

  @media (max-width: 720px) {
    .detail { padding: 1.5rem 0.9rem; }
    .fields.two-col { grid-template-columns: 1fr; }
    .head { flex-wrap: wrap; gap: 0.75rem; }
    .field {
      grid-template-columns: 1fr;
      gap: 0.1rem;
    }
    .field dt { font-size: 0.85rem; }
  }
</style>
