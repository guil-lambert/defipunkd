---
import type { Protocol, LoadedAssessment, AssessmentSliceId, LoadedSubmission } from "@defipunkd/registry";
import { getEnrichment } from "@defipunkd/registry";
import { EM_DASH, parseHallmarks } from "../lib/format";
import ProtocolLogo from "./ProtocolLogo.astro";
import SideNav from "./SideNav.astro";
import ChildrenTable from "./ChildrenTable.astro";
import RiskAnalysis from "./RiskAnalysis.astro";
import StagePreview from "./StagePreview.astro";
import ProtocolSummary from "./ProtocolSummary.astro";
import HallmarksTimeline from "./HallmarksTimeline.astro";
import TvlSurface from "./TvlSurface.astro";
import ProtocolReferences from "./ProtocolReferences.astro";
import DataQualityBanner from "./DataQualityBanner.astro";

interface Props {
  protocol: Protocol;
  snapshotGeneratedAt: string;
  children: Protocol[];
  assessments?: Map<AssessmentSliceId, LoadedAssessment>;
  submissions?: Map<AssessmentSliceId, LoadedSubmission[]>;
}
const { protocol, snapshotGeneratedAt, children, assessments, submissions } = Astro.props;
const enrichment = getEnrichment(protocol.slug);
const hasFamily = children.length > 0;
const hallmarks = parseHallmarks(protocol.hallmarks);
const hasHallmarks = hallmarks.length > 0;

let latestQuorumAt: string | null = null;
if (assessments) {
  for (const a of assessments.values()) {
    if (a.merged_at && (!latestQuorumAt || a.merged_at > latestQuorumAt)) {
      latestQuorumAt = a.merged_at;
    }
  }
}
const updatedAt = latestQuorumAt && latestQuorumAt > snapshotGeneratedAt
  ? latestQuorumAt
  : snapshotGeneratedAt;
const updatedSource: "defi@home" | "defillama" = updatedAt === latestQuorumAt ? "defi@home" : "defillama";

const hasTvlSurface =
  (!!enrichment.adapter && (enrichment.adapter.static_addresses?.length ?? 0) > 0)
  || ((submissions?.get("discovery")?.length ?? 0) > 0);
const navLinks = [
  { href: "#overview", label: "Overview" },
  ...(hasHallmarks ? [{ href: "#hallmarks", label: "Hallmarks" }] : []),
  { href: "#risk-analysis", label: "Risk analysis" },
  ...(hasTvlSurface ? [{ href: "#tvl-surface", label: "Contract surface" }] : []),
  { href: "#reference", label: "References" },
  ...(hasFamily ? [{ href: "#family", label: "Family members" }] : []),
  { href: "#stage", label: "Stage" },
];
---
<SideNav links={navLinks} contentMaxWidth={1100} />
<main class="detail" id="top">
  <a href="/" class="back-home" aria-label="Back to DeFiPunk'd">
    <span class="back-arrow" aria-hidden="true">←</span>
    <svg class="back-logo" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M3 3h4v2h-2v6h2v2h-4zM13 3h-4v2h2v6h-2v2h4zM7 6h2v2h-2zM7 9h2v2h-2z" fill="currentColor"/>
    </svg>
    <span class="back-word">DeFiPunk'<span class="back-mark">d</span></span>
  </a>
  <header class="head">
    <div class="title">
      <ProtocolLogo src={protocol.logo} name={protocol.name} size={40} />
      <div>
        <h1>{protocol.name}</h1>
        <p class="subtitle">
          {protocol.category || EM_DASH}
          {protocol.parent_slug && (
            <>
              {" · child of "}
              <a href={`/protocol/${protocol.parent_slug}`} class="link">{protocol.parent_slug}</a>
            </>
          )}
        </p>
      </div>
    </div>
  </header>

  <DataQualityBanner protocol={protocol} assessments={assessments} submissions={submissions} />

  <ProtocolSummary protocol={protocol} assessments={assessments} submissions={submissions} />

  <HallmarksTimeline hallmarks={hallmarks} />

  <RiskAnalysis protocol={protocol} snapshotGeneratedAt={snapshotGeneratedAt} assessments={assessments} submissions={submissions} children={children} />

  <TvlSurface enrichment={enrichment} submissions={submissions} />

  <ProtocolReferences protocol={protocol} updatedAt={updatedAt} updatedSource={updatedSource} />

  <StagePreview protocol={protocol} />

  <ChildrenTable children={children} />
</main>

<style>
  .detail { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; color: var(--text); scroll-margin-top: 1rem; }

  .back-home {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 0.9rem;
    color: var(--text);
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.015em;
    text-decoration: none;
  }
  .back-arrow { color: var(--text-muted); font-weight: 500; }
  .back-logo { width: 1em; height: 1em; flex-shrink: 0; color: var(--brand-oxblood); }
  .back-word { color: var(--text); }
  .back-mark { color: var(--brand-oxblood); }
  .back-home:hover .back-arrow { color: var(--text); }
  @media (min-width: 1501px) {
    /* Side nav already exposes a home link at this width */
    .back-home { display: none; }
  }
  .head { display: flex; gap: 1.5rem; align-items: flex-start; }
  .title { display: flex; gap: 0.75rem; align-items: center; }
  h1 { margin: 0; color: var(--text); font-size: 1.75rem; }
  .subtitle { color: var(--text-muted); margin: 0.25rem 0 0 0; }
  .link { color: var(--accent-link); }

  @media (max-width: 720px) {
    .detail { padding: 1.5rem 0.9rem; }
    .head { flex-wrap: wrap; gap: 0.75rem; }
  }
</style>
