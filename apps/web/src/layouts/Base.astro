---
import "@fontsource-variable/ibm-plex-sans";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  image?: string;
}

const { title = "DeFiPunk'd", description = "Transparency registry for DeFi protocols.", noindex = false, image = "/og.png" } = Astro.props;
const site = Astro.site ?? new URL("https://defipunkd.com");
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImage = new URL(image, site).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {noindex && <meta name="robots" content="noindex" />}
  </head>
  <body>
    <div class="flex-grow"><slot /></div>
    <Footer />
    <Analytics />
    <SpeedInsights />
  </body>
</html>

<style is:global>
  :root {
    --font-sans: "IBM Plex Sans Variable";
    --font-mono: "IBM Plex Mono";
  }
  body {
    margin: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  .flex-grow { flex: 1; }
</style>
