---
export const prerender = true;
import { listProtocols, getAssessments, getSubmissions } from "@defipunkd/registry";
import type { GradeColor } from "../lib/verifiability";
import Base from "../layouts/Base.astro";
import LandingTable from "../components/LandingTable.svelte";
import { bucketCategory } from "../lib/category-map";
import { primaryChain } from "../lib/format";
import { buildNodes, chainTvlFromNodes, tabCountsFromNodes, type LandingRow } from "../lib/landing";
import { verifiabilityGrade } from "../lib/verifiability";
import { autonomyGrade } from "../lib/autonomy";
import { deriveTier, type TierInput } from "../lib/tier";
import { type PizzaSliceId } from "../lib/pizza";
import { assessProtocol, cexAssessment } from "../lib/rationale";

const protocols = listProtocols();
const assessments = getAssessments();
const submissions = getSubmissions();
const unmapped = new Set<string>();

const rows: LandingRow[] = protocols.map((p) => {
  bucketCategory(p.category, (raw) => unmapped.add(raw));
  const bySlice = assessments.get(p.slug);
  const assessment_grades = bySlice
    ? Object.fromEntries(
        Array.from(bySlice.entries()).map(([sliceId, a]) => [
          sliceId,
          (a.grade === "unknown" ? "gray" : a.grade) as GradeColor,
        ]),
      )
    : undefined;
  const subBySlice = submissions.get(p.slug);
  const sliceList = p.category === "CEX" ? cexAssessment() : assessProtocol(p, bySlice, subBySlice);
  let tierInput: TierInput | undefined;
  if (bySlice || subBySlice) {
    tierInput = {};
    if (bySlice) {
      const tentativeBySlice = new Map<string, boolean>();
      for (const s of sliceList) tentativeBySlice.set(s.id, !!s.tentative);
      for (const [sliceId, a] of bySlice.entries()) {
        tierInput[sliceId as PizzaSliceId] = {
          models: a.models,
          merged_at: a.merged_at,
          human_signoff: a.human_signoff ?? null,
          tentative: tentativeBySlice.get(sliceId) ?? false,
        };
      }
    }
    if (subBySlice) {
      for (const [sliceId, arr] of subBySlice.entries()) {
        const existing = tierInput[sliceId as PizzaSliceId] ?? {};
        tierInput[sliceId as PizzaSliceId] = {
          ...existing,
          submissionCount: arr.length,
        };
      }
    }
  }
  const tier = deriveTier(tierInput);
  const slice_summary = sliceList.map((s) => ({
    id: s.id,
    label: s.label,
    grade: s.grade,
    headline: s.short_headline || s.headline || "",
    partial: s.partial,
  }));
  return {
    slug: p.slug,
    name: p.name,
    category: p.category,
    chains: p.chains,
    primary_chain: primaryChain(p.tvl_by_chain) ?? p.chains[0] ?? null,
    tvl: p.tvl,
    tvl_by_chain: p.tvl_by_chain,
    is_dead: p.is_dead,
    is_parent: p.is_parent,
    parent_slug: p.parent_slug,
    delisted_at: p.delisted_at,
    logo: p.logo,
    verifiability_grade: verifiabilityGrade(!!(p.github && p.github.length > 0), p.audit_count ?? 0),
    autonomy_grade: autonomyGrade(p.category, p.forked_from),
    assessment_grades,
    slice_summary,
    tier,
  };
});

// For parent rows without their own assessments, inherit slice_summary from the
// largest-TVL child so the hover popover still has meaningful content.
{
  const childrenByParent = new Map<string, LandingRow[]>();
  for (const r of rows) {
    if (!r.parent_slug) continue;
    const bucket = childrenByParent.get(r.parent_slug) ?? [];
    bucket.push(r);
    childrenByParent.set(r.parent_slug, bucket);
  }
  for (const r of rows) {
    if (!r.is_parent) continue;
    // Always inherit slice_summary from the largest-TVL child for parents,
    // since the parent itself does not carry per-slice assessments.
    const kids = childrenByParent.get(r.slug);
    if (!kids || kids.length === 0) continue;
    const best = [...kids].sort((a, b) => (b.tvl ?? -1) - (a.tvl ?? -1))[0];
    if (best) {
      r.slice_summary = best.slice_summary;
      r.slice_summary_source_name = best.name;
      r.verifiability_grade = best.verifiability_grade;
      r.autonomy_grade = best.autonomy_grade;
      r.assessment_grades = best.assessment_grades;
    }
  }
}

if (unmapped.size > 0) {
  console.warn(
    `[landing] ${unmapped.size} unmapped categorie(s) bucketed into Others: ${[...unmapped].sort().join(", ")}`,
  );
}

const nodes = buildNodes(rows);
const counts = tabCountsFromNodes(nodes);
const chainTvl = chainTvlFromNodes(nodes);
const live = counts.All ?? 0;
---
<Base>
  <main class="page">
    <header class="hero">
      <h1>
        <svg class="logo" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M3 3h4v2h-2v6h2v2h-4zM13 3h-4v2h2v6h-2v2h4zM7 6h2v2h-2zM7 9h2v2h-2z" fill="currentColor"/>
        </svg>
        <span>DeFiPunk'<span class="mark">d</span></span>
      </h1>
      <p class="subtitle">
        {live.toLocaleString()} live protocols · {protocols.length.toLocaleString()} total ·{" "}
        <a href="/methodology">methodology</a> · <a href="/contribute">contribute</a>
      </p>
    </header>
    <LandingTable client:load nodes={nodes} tabCounts={counts} chainTvl={chainTvl} />
  </main>
</Base>

<style>
  .page { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; }
  .hero { margin-bottom: 1.5rem; }
  h1 { margin: 0; display: inline-flex; align-items: center; gap: 0.4rem; line-height: 1; flex-wrap: nowrap; }
  .logo { width: 1em; height: 1em; flex-shrink: 0; color: var(--brand-oxblood); }
  h1 .mark { color: var(--brand-oxblood); }
  .subtitle { color: var(--text-muted); margin-top: 0.25rem; }
</style>
