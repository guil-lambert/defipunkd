---
import { listProtocols } from "@defipunkd/registry";
import Base from "../layouts/Base.astro";
import LandingTable from "../components/LandingTable.svelte";
import { bucketCategory } from "../lib/category-map";
import { primaryChain } from "../lib/format";
import { buildNodes, tabCountsFromNodes, type LandingRow } from "../lib/landing";
import { verifiabilityGrade } from "../lib/verifiability";
import { dependenciesGrade } from "../lib/dependencies";

const protocols = listProtocols();
const unmapped = new Set<string>();

const rows: LandingRow[] = protocols.map((p) => {
  bucketCategory(p.category, (raw) => unmapped.add(raw));
  return {
    slug: p.slug,
    name: p.name,
    category: p.category,
    chains: p.chains,
    primary_chain: primaryChain(p.tvl_by_chain) ?? p.chains[0] ?? null,
    tvl: p.tvl,
    is_dead: p.is_dead,
    is_parent: p.is_parent,
    parent_slug: p.parent_slug,
    delisted_at: p.delisted_at,
    logo: p.logo,
    verifiability_grade: verifiabilityGrade(!!(p.github && p.github.length > 0), p.audit_count ?? 0),
    dependencies_grade: dependenciesGrade(p.category, p.forked_from),
  };
});

if (unmapped.size > 0) {
  console.warn(
    `[landing] ${unmapped.size} unmapped categorie(s) bucketed into Others: ${[...unmapped].sort().join(", ")}`,
  );
}

const nodes = buildNodes(rows);
const counts = tabCountsFromNodes(nodes);
const live = counts.All ?? 0;
---
<Base>
  <main class="page">
    <header class="hero">
      <h1>
        <svg class="logo" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M3 3h4v2h-2v6h2v2h-4zM13 3h-4v2h2v6h-2v2h4zM7 6h2v2h-2zM7 9h2v2h-2z" fill="currentColor"/>
        </svg>
        DeFiPunkd
      </h1>
      <p class="subtitle">
        {live.toLocaleString()} live protocols · {protocols.length.toLocaleString()} total ·{" "}
        <a href="/methodology">methodology</a>
      </p>
    </header>
    <LandingTable client:load nodes={nodes} tabCounts={counts} />
  </main>
</Base>

<style>
  .page { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; }
  .hero { margin-bottom: 1.5rem; }
  h1 { margin: 0; display: flex; align-items: center; gap: 0.4rem; }
  .logo { width: 1em; height: 1em; flex-shrink: 0; }
  .subtitle { color: var(--text-muted); margin-top: 0.25rem; }
</style>
