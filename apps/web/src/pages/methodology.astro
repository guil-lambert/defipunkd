---
export const prerender = true;
import Base from "../layouts/Base.astro";
import PizzaChart from "../components/PizzaChart.astro";
import SideNav from "../components/SideNav.astro";
import { PIZZA_SLICES } from "../lib/pizza";

const SLICE_DESCRIPTIONS: Record<string, string> = {
  control:
    "Who holds admin privileges, how contracts can be upgraded, and how quickly. Combines the old chain-ownership and upgradeability questions \u2014 a single assessment per protocol rather than per chain, since a one-chain-red / mainnet-green split is more misleading than useful.",
  "ability-to-exit":
    "Whether users can exit on their own terms if the protocol team disappears or acts adversarially.",
  dependencies:
    "Third-party protocols the contracts rely on: oracles, bridges, yield wrappers, stable issuers, and collateral counterparties. The Kelp\u2009\u2194\u2009Aave unwind is a recent reminder that collateral exposure is just another dependency, so it lives in this slice rather than alone.",
  access:
    "Whether the protocol depends on privileged operators, off-chain infrastructure, whitelists, or regional restrictions to function.",
  verifiability:
    "Whether anyone outside the team can independently verify what the code does: open-source status, audit quality and scope, bytecode-to-source correspondence at the deployed address, and whether post-audit changes were themselves reviewed.",
};
---
<Base title="Methodology · defipunkd">
  <SideNav contentMaxWidth={800} links={[
    { href: "#data-source", label: "Data source" },
    { href: "#risk-pizza", label: "Risk pizza" },
    { href: "#what-is-graded-today", label: "Graded today" },
    { href: "#audits", label: "Audits" },
    { href: "#defi-at-home", label: "DEFI@home" },
    { href: "#stages", label: "Stages" },
    { href: "#corrections", label: "Corrections" },
  ]} />
  <main class="page">
    <h1>Methodology</h1>
    <p class="lede">defipunkd is a registry, not a rating. No protocol on this site has been reviewed.</p>

    <h2 id="data-source">Where the data comes from</h2>
    <p>
      Every protocol is seeded from <a href="https://defillama.com/" rel="noreferrer" target="_blank">DeFiLlama</a> via <code>pnpm sync</code>, which writes the full list into a committed JSON snapshot. Human curators can override individual fields by dropping a JSON file into <code>data/overlays/</code> and opening a PR.
    </p>
    <p>
      Every field displays a provenance tag so you always know where the value came from: <code>[defillama]</code> for the raw DeFiLlama value, <code>[curated]</code> for a human-authored overlay, <code>[defillama-parent]</code> when a child protocol inherits a field (github, twitter, website) from its parent protocol because DeFiLlama only records the value at the family level, and <code>[:]</code> — the DeFiPunkd logo itself — for anything attested by the DEFI@home quorum. The glyph only appears where there is evidence behind it; an em-dash means unsourced.
    </p>
    <p>defipunkd mirrors DeFiLlama: if DeFiLlama delists a protocol, defipunkd delists it after a 14-day grace window.</p>

    <h2 id="risk-pizza">The 5-slice risk pizza</h2>
    <p>
      defipunkd uses the five assessment dimensions from{" "}
      <a href="https://github.com/deficollective/defiscan-v2" rel="noreferrer" target="_blank">DeFiScan v2</a>: <strong>Control</strong>, <strong>Ability to exit</strong>, <strong>Dependencies</strong>, <strong>Access</strong>, and <strong>Verifiability</strong>. At Phase 0 every slice is gray — nothing has been reviewed. The slices exist now so the shape of future assessments is already visible.
    </p>
    <div class="pizza-row">
      <PizzaChart size="lg" />
      <ul class="slice-list">
        {PIZZA_SLICES.map((s) => (
          <li>
            <strong>{s.label}</strong><br />
            <span class="muted">{SLICE_DESCRIPTIONS[s.id]}</span>
          </li>
        ))}
      </ul>
    </div>

    <h2 id="what-is-graded-today">What is graded today</h2>
    <p>
      Only <strong>Verifiability</strong> currently carries a real color on the pizza. The rule is a deliberately coarse first-pass heuristic from raw DeFiLlama signals:
    </p>
    <ul>
      <li><strong class="green">green</strong> — protocol has a GitHub repo <em>and</em> at least one audit</li>
      <li><strong class="orange">orange</strong> — it has one but not the other</li>
      <li><strong class="red">red</strong> — neither</li>
    </ul>
    <p>
      For family rows (Uniswap, Aave, Morpho, …) the family's slice takes the grade of the highest-TVL child so a small outlier deployment doesn't drag a well-graded family down. A thorough Verifiability assessment in a later phase will replace this with auditor-reputation weighting, scope review, and source-to-bytecode correspondence.
    </p>
    <p>
      <strong>Dependencies</strong> is graded with a simple category-based first pass plus an opportunistic <code>forkedFrom</code> check:
    </p>
    <ul>
      <li><strong class="red">red</strong> — protocol category is <em>Liquid Staking</em>, <em>RWA Lending</em>, or one of the bridge categories (<em>Bridge</em>, <em>Canonical Bridge</em>, <em>Cross Chain Bridge</em>, <em>Bridge Aggregator</em>). These categories carry unavoidable external-protocol, validator, or counterparty risk by construction.</li>
      <li><strong class="orange">orange</strong> — DeFiLlama records a non-empty <code>forkedFrom</code> lineage, i.e. the contracts inherit their base logic from another protocol's codebase. DeFiLlama's fork-lineage data is largely paywalled, so this signal currently covers only a handful of protocols — real fork detection is Phase-2 work.</li>
      <li><strong class="gray">gray</strong> — neither signal fires. Most protocols sit here until deeper dependency analysis lands.</li>
    </ul>
    <p>
      <strong>Control</strong>, <strong>Ability to exit</strong>, and <strong>Access</strong> all render gray — no automated heuristic grades them yet. In particular, <strong>Access</strong> (whether the protocol is permissioned, uses whitelists, geo-restricts users, or depends on off-chain operators to function) is not a signal DeFiLlama carries in a usable form, so at Phase 0 we simply surface it as unknown and will populate it when crawler workers read the project's own docs and frontend (Phase 1) and when onchain discovery flags whitelist-gated entry points (Phase 2).
    </p>

    <h2 id="audits">Audits and source code feed Verifiability</h2>
    <p>
      Each protocol detail page shows the raw audit count, expandable list of audit links, and the project's GitHub repositories. These feed the Verifiability slice, not a slice of their own: an audit count is a famously weak signal in isolation — auditor quality, report scope, and whether post-audit changes were reviewed matter far more than the integer. GitHub is surfaced so you can check whether the deployed addresses match the published source. At Phase 0 the data is raw and the slice stays gray; a future phase will grade auditor reputation and source-to-bytecode correspondence as part of the Verifiability assessment.
    </p>

    <h2 id="defi-at-home">DEFI@home — distributed assessment</h2>
    <p>
      defipunkd does not run crawlers and does not hand-curate every protocol. The slice grades that aren't produced by the deterministic heuristics above are filled in by <strong>DEFI@home</strong>: a distributed, BOINC-style process where any number of independent auditors run a pinned prompt through the LLM of their choice (Claude, ChatGPT, Gemini, …) and submit the JSON output as a pull request.
    </p>
    <p>
      Each protocol page exposes an <strong>Audit this slice yourself</strong> button under every Risk-analysis card. The button copies a prompt with the snapshot timestamp, chains, GitHub repos, and audit links already pinned in, so re-runs remain verifiable against a fixed evidence set. Submissions must match <a href="https://github.com/guil-lambert/defipunkd/blob/main/data/schema/slice-assessment.v2.json" rel="noreferrer" target="_blank">slice-assessment.v2.json</a>: every claim cites a block explorer, a repo at a pinned commit SHA, or an audit PDF.
    </p>
    <p>
      Determinism comes from <strong>consensus across independent re-runs</strong>, not from any single LLM output. A quorum bot merges an assessment into <code>data/assessments/</code> once ≥3 contributors (using different models or accounts) agree on grade and overlapping evidence; disagreements open a per-(slug, slice) aggregation issue. A scheduled GitHub Action also runs the prompts via the Anthropic SDK as a "third voice" so coverage doesn't depend on volunteer traffic alone. See <a href="/contribute">/contribute</a> for the full flow.
    </p>

    <h2 id="stages">Stages</h2>
    <p>
      Stage badges arrive with Phase 3 of the project, at which point defipunkd adopts <a href="https://docs.defiscan.info/" rel="noreferrer" target="_blank">DeFiScan v2's stage framework</a> verbatim. Until then, every protocol shows an em-dash in the Stage column.
    </p>

    <h2 id="corrections">Corrections</h2>
    <p>
      Spotted a wrong field? Open an issue or a PR on <a href="https://github.com/guil-lambert/defipunkd" rel="noreferrer" target="_blank">github.com/guil-lambert/defipunkd</a>.
    </p>
  </main>
</Base>

<style>
  .page {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    color: var(--text);
    line-height: 1.6;
  }
  h1 { margin-bottom: 0.5rem; }
  .lede { color: var(--text-muted); margin-top: 0; }
  h2 {
    color: var(--text);
    border-bottom: 1px solid var(--surface-raised);
    padding-bottom: 0.5rem;
    margin-top: 2rem;
  }
  h2#what-is-graded-today { scroll-margin-top: 1rem; }
  code, strong { color: var(--text); }
  a { color: var(--accent-link); }
  .pizza-row {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    flex-wrap: wrap;
  }
  .slice-list {
    list-style: none;
    padding: 0;
    margin: 0;
    flex: 1;
    min-width: 300px;
  }
  .slice-list li {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--surface-raised);
  }
  .muted { color: var(--text-muted); font-size: 0.9rem; }
  .green { color: var(--grade-green); }
  .orange { color: var(--grade-orange); }
  .red { color: var(--grade-red); }
  .gray { color: var(--grade-gray); }
</style>
