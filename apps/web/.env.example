# Alchemy RPC key — required for /api/contract/read and /api/safe/owners.
# https://dashboard.alchemy.com → Apps → API key
ALCHEMY_API_KEY=

# Etherscan v2 multichain key — required for /api/contract/abi (and the
# enrichment CLIs). Optional in dev; without it, /api/contract/abi falls
# back to Sourcify only.
# https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
